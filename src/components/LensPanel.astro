    margin: 0;
    max-width: 64ch;
  }
  :global(.lc-safety-register .lc-route-link) {
    color: var(--safety-ink);
    font-weight: 600;
    text-decoration: none;
  }
  :global(.lc-fu-link),
  :global(.lc-route-link) {
    color: var(--primary);
    font-weight: 600;
    text-decoration: none;
  }

  /* short-circuit — a calm pointer to the graded page */
  :global(.lc-shortcircuit) {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
  }
  :global(.lc-sc-line) {

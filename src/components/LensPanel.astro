</style>

<script>
  // The card DOM-building is the SHARED, framework-free renderer (CHK-7.2) — the textContent-only path
  // that authors no medical prose. Importing it here keeps the safety-critical render in one file.
  import { renderLensCard, type LensCardAssessment } from '../lib/lens/render-card.ts';

  // REAL pipeline milestones (CHK-7.4): the engine streams these as SSE events. Each maps to an honest
  // stage label; counts (sources, claims) come from the event, never fabricated. The FALLBACK sequence
  // is used only when the stream is unavailable (a JSON-only response) so the bar still moves.
  const STAGE_ORDER = ['resolving', 'searching', 'sources', 'extracting', 'verifying', 'composing'];
  const FALLBACK_STAGES = [
    'Understanding your query…',
    'Searching published sources…',
    'Reading what the studies say…',
    'Verifying each claim against its source…',
    'Composing the assessment…',
  ];
  const STAGE_MS = 1600;

  const roots = document.querySelectorAll<HTMLElement>('[data-lens]');
  roots.forEach((root) => {
    const form = root.querySelector<HTMLFormElement>('[data-lens-form]');
    const input = root.querySelector<HTMLTextAreaElement>('[data-lens-input]');
    const send = root.querySelector<HTMLButtonElement>('[data-lens-send]');
    const progress = root.querySelector<HTMLElement>('[data-lens-progress]');
    const resolvedEl = root.querySelector<HTMLElement>('[data-lens-resolved]');
    const stageEl = root.querySelector<HTMLElement>('[data-lens-stage]');
    const barEl = root.querySelector<HTMLElement>('[data-lens-bar]');
    const cardRegion = root.querySelector<HTMLElement>('[data-lens-card]');
    const examples = root.querySelector<HTMLElement>('[data-lens-examples]');
    if (!form || !input || !send || !progress || !resolvedEl || !stageEl || !barEl || !cardRegion) return;

    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    let busy = false;
    let fallbackTimer: ReturnType<typeof setInterval> | null = null;

    const setBusy = (b: boolean) => {
      busy = b;
      send.disabled = b;
      input.disabled = b;
    };

    const showNotice = (text: string) => {
      cardRegion.innerHTML = ''; // clear only
      const p = document.createElement('div');
      p.className = 'notice';
      p.setAttribute('role', 'status');
      p.textContent = text; // island copy, plain text
      cardRegion.appendChild(p);
      cardRegion.focus?.();
    };

    // Move the bar to a fraction of the way through the known milestone order (real progress).
    const setBar = (fraction: number) => {
      barEl.style.width = Math.max(0, Math.min(100, Math.round(fraction * 100))) + '%';
    };

    const startProgress = () => {
      cardRegion.innerHTML = '';
      resolvedEl.hidden = true;
      resolvedEl.textContent = '';
      progress.hidden = false;
      stageEl.textContent = 'Understanding your query…';
      setBar(reduce ? 1 : 0.05);
    };

    const stopProgress = () => {
      if (fallbackTimer) {
        clearInterval(fallbackTimer);
        fallbackTimer = null;
      }
      progress.hidden = true;
      barEl.style.width = '0';
    };

    // Apply ONE real streamed event to the progress UI. Counts shown are the engine's real ones.
    const applyEvent = (event: any) => {
      if (!event || typeof event.type !== 'string') return;
      const idx = STAGE_ORDER.indexOf(event.type === 'resolved' ? 'resolving' : event.type);
      if (idx >= 0 && !reduce) setBar((idx + 1) / (STAGE_ORDER.length + 1));
      switch (event.type) {
        case 'resolved': {
          const r = event.resolved;
          // Structural "X → Y" (sanitised names only) — persists while the rest of the pipeline runs.
          if (r && (r.resolvedName || r.subject)) {
            const arrow = r.resolvedName && r.resolvedName !== r.subject ? `${r.subject} → ${r.resolvedName}` : r.subject;
            resolvedEl.textContent = arrow;
            resolvedEl.hidden = false;
          }
          stageEl.textContent = 'Searching published sources…';
          break;
        }
        case 'searching':
          stageEl.textContent = 'Searching published sources…';
          break;
        case 'sources':
          stageEl.textContent =
            typeof event.count === 'number'
              ? `Read ${event.count} source${event.count === 1 ? '' : 's'}…`
              : 'Reading sources…';
          break;
        case 'extracting':
          stageEl.textContent = 'Reading what the studies say…';
          break;
        case 'verifying':
          stageEl.textContent =
            typeof event.total === 'number' && event.total > 0
              ? `Verifying ${event.total} claim${event.total === 1 ? '' : 's'} against ${event.total === 1 ? 'its source' : 'their sources'}…`
              : 'Verifying each claim against its source…';
          break;
        case 'composing':
          stageEl.textContent = 'Composing the assessment…';
          if (!reduce) setBar(0.95);
          break;
      }
    };

    // Fallback timed stepper for a non-streaming (JSON) response — the bar still advances honestly.
    const startFallbackStepper = () => {
      if (reduce) return;
      let i = 0;
      stageEl.textContent = FALLBACK_STAGES[0];
      fallbackTimer = setInterval(() => {
        i = Math.min(i + 1, FALLBACK_STAGES.length - 1);
        stageEl.textContent = FALLBACK_STAGES[i];
        setBar((i + 1) / (FALLBACK_STAGES.length + 1));
        if (i >= FALLBACK_STAGES.length - 1 && fallbackTimer) {
          clearInterval(fallbackTimer);
          fallbackTimer = null;
        }
      }, STAGE_MS);
    };

    // Parse an SSE byte stream frame-by-frame, applying events and resolving with the final assessment.
    const consumeStream = async (res: Response): Promise<LensCardAssessment | null> => {
      const reader = res.body?.getReader();
      if (!reader) return null;
      const decoder = new TextDecoder();
      let buffer = '';
      let done: LensCardAssessment | null = null;
      // eslint-disable-next-line no-constant-condition
      while (true) {
        const { value, done: streamDone } = await reader.read();
        if (streamDone) break;
        buffer += decoder.decode(value, { stream: true });
        const frames = buffer.split('\n\n');
        buffer = frames.pop() ?? ''; // keep the trailing partial frame
        for (const frame of frames) {
          const dataLines = frame
            .split('\n')
            .filter((l) => l.startsWith('data:'))
            .map((l) => l.slice(5).trim());
          if (!dataLines.length) continue;
          let msg: any;
          try {
            msg = JSON.parse(dataLines.join(''));
          } catch {
            continue;
          }
          if (msg.kind === 'event') applyEvent(msg.event);
          else if (msg.kind === 'done') done = msg.assessment as LensCardAssessment;
          else if (msg.kind === 'error') throw new Error('stream-error');
        }
      }
      return done;
    };

    const submit = async () => {
      if (busy) return;
      const value = input.value.trim();
      if (!value) {
        showNotice('Type a product name, an ingredient, or paste a supplement-facts panel to research.');
        input.focus();
        return;
      }
      if (value.length > 4000) {
        showNotice('That’s longer than the Lens can take in one go. Trim it to the ingredients you want checked and try again.');
        return;
      }
      setBusy(true);
      startProgress();
      try {
        const res = await fetch('/api/lens', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', Accept: 'text/event-stream' },
          body: JSON.stringify({ input: value }),
        });
        if (res.status === 503) {
          stopProgress();
          showNotice('The Lens isn’t available right now. You can still browse the graded tier board and each remedy’s cited evidence in the meantime.');
          return;
        }
        if (res.status === 429) {
          stopProgress();
          showNotice('You’re going a little faster than the Lens can keep up with — give it a moment and try again. Nothing you entered is lost.');
          return;
        }
        if (res.status === 413) {
          stopProgress();
          showNotice('That’s longer than the Lens can take in one go. Trim it to the ingredients you want checked and try again.');
          return;
        }
        if (res.status === 400) {
          stopProgress();
          showNotice('Type a product name, an ingredient, or paste a supplement-facts panel to research.');
          return;
        }
        if (!res.ok) {
          stopProgress();
          showNotice('Something went wrong researching that. You can try again, or browse Somnary’s graded evidence directly. This is educational, not medical advice.');
          return;
        }

        let assessment: LensCardAssessment | null = null;
        const contentType = res.headers.get('content-type') || '';
        if (contentType.includes('text/event-stream') && res.body) {
          assessment = await consumeStream(res);
        } else {
          // Non-streaming fallback (JSON): step the fallback bar while we await, then render.
          startFallbackStepper();
          assessment = (await res.json()) as LensCardAssessment;
        }
        stopProgress();
        if (!assessment) {
          showNotice('Something went wrong researching that. You can try again, or browse Somnary’s graded evidence directly. This is educational, not medical advice.');
          return;
        }
        renderLensCard(assessment, cardRegion);
        cardRegion.focus?.();
      } catch {
        stopProgress();
        showNotice('Something went wrong reaching the Lens. You can try again, or browse Somnary’s graded evidence directly. This is educational, not medical advice.');
      } finally {
        setBusy(false);
      }
    };

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      void submit();
    });
    // Cmd/Ctrl+Enter submits from the textarea; plain Enter inserts a newline (labels can be multi-line).
    input.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' && (e.metaKey || e.ctrlKey)) {
        e.preventDefault();
        void submit();
      }
      if (e.key === 'Escape') input.blur();
    });

    // Example seed chips — fill the box and research (the research loop stays one click away).
    examples?.querySelectorAll<HTMLButtonElement>('[data-example]').forEach((chip) => {
      chip.addEventListener('click', () => {
        const q = chip.getAttribute('data-example') || '';
        if (!q || busy) return;
        input.value = q;
        void submit();
      });
    });

    // Deep-link: ?q=<query> (from the homepage on-ramp / ⌘K palette handoff) → prefill + auto-submit.
    try {
      const q = new URLSearchParams(window.location.search).get('q');
      if (q && q.trim()) {
        input.value = q.trim().slice(0, 4000);
        void submit();
      }
    } catch {
      /* URL unavailable — non-fatal; the empty prompt still works */
    }
  });
</script>

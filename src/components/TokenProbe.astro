---
// CHK-0.3 token probe. A throwaway specimen proving the DESIGN_SYSTEM tokens are wired
// into the styling layer: every value here is a NAMED token (Tailwind token utility or a
// var(--token)) — no raw hex, no raw px. Not the real tier badge (that's CHK-2.3); this
// stays a neutral probe so we don't jump ahead in the build order.

// Full class strings written literally so Tailwind's JIT scanner detects them.
const tiers = [
  { letter: 'S', cls: 'bg-tier-s-tint border-tier-s text-tier-s-ink' },
  { letter: 'A', cls: 'bg-tier-a-tint border-tier-a text-tier-a-ink' },
  { letter: 'B', cls: 'bg-tier-b-tint border-tier-b text-tier-b-ink' },
  { letter: 'C', cls: 'bg-tier-c-tint border-tier-c text-tier-c-ink' },
  { letter: 'D', cls: 'bg-tier-d-tint border-tier-d text-tier-d-ink' },
  { letter: 'F', cls: 'bg-tier-f-tint border-tier-f text-tier-f-ink' },
];
---

<section class="bg-surface border border-line rounded-lg p-6 font-body text-ink">
  <p class="font-mono text-xs text-ink-faint">design tokens · wired</p>

  {/* tier spectrum via Tailwind token utilities */}
  <div class="flex flex-wrap gap-2 mt-4">
    {tiers.map((t) => (
      <span class={`inline-flex items-center justify-center font-display text-lg border rounded-sm px-4 py-3 ${t.cls}`}>
        {t.letter}
      </span>
    ))}
  </div>

  {/* type families + scale via tokens */}
  <p class="font-display text-2xl mt-5">newsreader display, lowercase.</p>
  <p class="font-body text-base text-ink-soft mt-2">hanken grotesk body copy at the base scale.</p>

  {/* accents — text uses -ink variants only (base hues fail AA as text) */}
  <div class="flex flex-wrap gap-2 mt-4">
    <span class="font-mono text-xs px-3 py-2 rounded-pill bg-lavender-tint text-lavender-ink">lavender</span>
    <span class="font-mono text-xs px-3 py-2 rounded-pill bg-sage-tint text-sage-ink">sage</span>
  </div>

  {/* same tokens reached via raw var() to prove the CSS custom properties resolve too */}
  <p style="color:var(--ink-faint);font-family:var(--font-mono);font-size:var(--text-xs);letter-spacing:var(--tracking-label);margin-top:var(--sp-5)">
    VAR() PATH RESOLVES
  </p>
</section>

---
// Evidence-gate chip by id — DESIGN_SYSTEM §2.3. Built during CHK-1.1 (front-loaded from CHK-2.3).
// Looks the gate up in evidence-gates.ts (so label + meaning are never hardcoded at call sites)
// and renders the shared presentational GateChip. Used by the methodology gate glossary + tier rows.
import { getGate, type GateId } from '../lib/evidence-gates';
import GateChip from './GateChip.astro';

interface Props {
  id: GateId;
}
const { id } = Astro.props;
const gate = getGate(id);
---

<GateChip label={gate.label} variant={gate.variant} title={gate.meaning} />

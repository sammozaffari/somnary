---
// Command palette — DESIGN_SYSTEM §2.13, CHK-4.2. The keyboard-first search surface: a nav trigger
// + a modal overlay (combobox/listbox) that lazy-loads /search-index.json and ranks with the SAME
// pure ranker as the crawlable /search page (src/lib/search-rank). Opens on ⌘K / Ctrl+K / "/";
// closes on Esc / scrim / route change; focus returns to the trigger. Motion is scrim-fade + modal
// rise only (no scale), disabled under reduced motion. Tier is text (aria-label), never color-only.
---

<button
  type="button"
  class="search-trigger"
  aria-haspopup="dialog"
  aria-label="Search (press ⌘K)"
  data-search-open
>
  <span class="st-mag" aria-hidden="true">⌕</span>
  <span class="st-label">Search</span>
  <kbd class="st-hint" aria-hidden="true">⌘K</kbd>
</button>

<div class="search-overlay" data-search-overlay hidden>
  <div class="scrim" data-search-scrim></div>
  <div class="palette" role="dialog" aria-modal="true" aria-label="Search Somnary">
    <div class="p-input-row">
      <span class="p-mag" aria-hidden="true">⌕</span>
      <input
        type="text"
        class="p-input"
        role="combobox"
        aria-expanded="false"
        aria-controls="p-listbox"
        aria-autocomplete="list"
        aria-label="Search remedies, outcomes, and symptoms"
        placeholder="A remedy, a compound, an outcome, a symptom…"
        autocomplete="off"
        spellcheck="false"
        data-search-input
      />
    </div>
    <ul id="p-listbox" class="p-list" role="listbox" aria-label="Search results" data-search-list></ul>
    <div class="p-answer" data-pask-answer hidden aria-live="polite">
      <p class="pa-status" data-pask-status></p>
      <div class="pa-body" data-pask-body></div>
      <p class="pa-routes" data-pask-routes hidden></p>
      <p class="pa-privacy">
        Your question is sent to a third-party AI service (OpenRouter, or Google’s Gemini API).
        Don’t include personal or identifying details.
      </p>
    </div>
    <p class="p-hint" data-search-hint>Type to search · ↑↓ to move · enter to open · esc to close</p>
  </div>
</div>

<style>
  /* trigger */
  .search-trigger {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    height: 32px;
    padding: 0 var(--sp-3);
    background: var(--surface);
    border: var(--border-hairline);
    border-radius: var(--r-pill);
    cursor: pointer;
    color: var(--muted);
    transition: border-color var(--dur-fast) var(--ease-soft);
  }
  .search-trigger:hover {
    border-color: var(--mineral);
  }
  .search-trigger:focus-visible {
    outline: none;
    box-shadow: var(--ring);
  }
  .st-mag {
    font-size: var(--text-base);
    line-height: 1;
  }
  .st-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
  }
  .st-hint {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--muted);
    background: var(--stone);
    border-radius: var(--r-xs);
    padding: 1px 5px;
  }

  /* overlay + scrim */
  .search-overlay {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: flex;
    justify-content: center;
    align-items: flex-start;
    padding: 12vh 16px 16px;
  }
  .search-overlay[hidden] {
    display: none;
  }
  .scrim {
    position: fixed;
    inset: 0;
    background: color-mix(in srgb, var(--ink) 30%, transparent);
    animation: p-scrim var(--dur-base) var(--ease-settle);
  }
  @keyframes p-scrim {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  /* palette modal */
  .palette {
    position: relative;
    width: 100%;
    max-width: 640px;
    max-height: 70vh;
    display: flex;
    flex-direction: column;
    background: var(--surface);
    border: var(--border-strong);
    border-radius: var(--r-lg);
    box-shadow: var(--shadow-lift);
    overflow: hidden;
    animation: p-rise var(--dur-base) var(--ease-settle);
  }
  @keyframes p-rise {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .p-input-row {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    padding: var(--sp-4) var(--sp-5);
    border-bottom: var(--border-hairline);
  }
  .p-mag {
    color: var(--muted);
    font-size: var(--text-lg);
    line-height: 1;
  }
  .p-input {
    flex: 1;
    min-width: 0;
    border: none;
    background: var(--paper);
    border-radius: var(--r-sm);
    padding: var(--sp-2) var(--sp-3);
    font-family: var(--font-body);
    font-size: 18px;
    color: var(--ink);
  }
  .p-input:focus {
    outline: none;
    box-shadow: var(--ring);
  }

  .p-list {
    list-style: none;
    margin: 0;
    padding: var(--sp-2);
    overflow-y: auto;
    flex: 1;
  }
  .p-list:empty {
    display: none;
  }
  .p-list :global(.p-group) {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    color: var(--muted);
    padding: var(--sp-3) var(--sp-3) var(--sp-2);
  }
  .p-list :global(.p-row) {
    display: grid;
    grid-template-columns: 38px 1fr auto;
    gap: var(--sp-3);
    align-items: center;
    padding: var(--sp-3);
    border-radius: var(--r-md);
    cursor: pointer;
  }
  .p-list :global(.p-row[aria-selected='true']) {
    background: var(--stone);
  }
  .p-list :global(.p-badge) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 26px;
    height: 26px;
    border-radius: var(--r-sm);
    flex: none;
  }
  .p-list :global(.p-glyph) {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 16px;
    line-height: 1;
    transform: translateY(var(--grade-optical-shift));
  }
  .p-list :global(.p-main) {
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 1px;
  }
  .p-list :global(.p-name) {
    font-size: var(--text-base);
    color: var(--ink);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .p-list :global(.p-cat) {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    color: var(--muted);
  }
  .p-list :global(.p-grade) {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    color: var(--muted);
  }

  /* ask row (CHK-6.7) — one more option at the end of the listbox; primary-tinted so it reads as
     "hand this to the assistant", never as another search result */
  .p-list :global(.p-askrow .p-badge) {
    background: var(--primary-soft);
    border: 1px solid var(--primary);
    color: var(--primary);
  }
  .p-list :global(.p-askrow .p-name) {
    white-space: normal;
  }

  /* inline answer panel (CHK-6.7) — same register as the remedy-page AskPanel answer card */
  .p-answer {
    border-top: var(--border-hairline);
    padding: var(--sp-4) var(--sp-5);
    overflow-y: auto;
    max-height: 40vh;
  }
  .p-answer[hidden] {
    display: none;
  }
  .pa-status {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    font-weight: 600;
    color: var(--ink);
    margin: 0 0 var(--sp-3);
  }
  .pa-body :global(p) {
    font-size: var(--text-sm);
    line-height: var(--lh-base);
    color: var(--ink);
    margin: 0 0 var(--sp-3);
  }
  .pa-body :global(p.pa-head) {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    color: var(--muted);
    margin: 0 0 var(--sp-1);
  }
  .pa-body :global(a.ask-cref) {
    color: var(--primary);
    text-decoration: none;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
  }
  .pa-routes {
    margin: 0 0 var(--sp-3);
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2) var(--sp-4);
  }
  .pa-routes[hidden] {
    display: none;
  }
  .pa-routes :global(a) {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    color: var(--primary);
    text-decoration: none;
  }
  .pa-routes :global(a:focus-visible) {
    outline: none;
    box-shadow: var(--ring);
    border-radius: var(--r-sm);
  }
  .pa-privacy {
    font-size: var(--text-xs);
    line-height: var(--lh-sm);
    color: var(--muted);
    margin: 0;
  }

  .p-hint,
  .p-empty {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    color: var(--muted);
    padding: var(--sp-3) var(--sp-5);
    margin: 0;
    border-top: var(--border-hairline);
  }
  .p-empty[hidden] {
    display: none;
  }

  @media (max-width: 640px) {
    .st-label,
    .st-hint {
      display: none;
    }
    .search-trigger {
      width: 44px;
      height: 44px;
      justify-content: center;
      padding: 0;
    }
    .search-overlay {
      padding: 8vh 8px 8px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .scrim,
    .palette {
      animation: none;
    }
  }
</style>

<script>
  import { searchDocsScored, shouldOfferAsk, type SearchDoc } from '../lib/search-rank';

  interface AskCitation {
    n: number;
    href: string;
  }
  interface AskResponse {
    status: 'answered' | 'refused' | 'no-evidence' | 'error';
    answer: string;
    citations: AskCitation[];
    route: { href: string; label: string } | null;
    answeredFrom?: { name: string; url: string };
    links?: Array<{ href: string; label: string }>;
  }

  const trigger = document.querySelector<HTMLButtonElement>('[data-search-open]');
  const overlay = document.querySelector<HTMLElement>('[data-search-overlay]');
  const scrim = document.querySelector<HTMLElement>('[data-search-scrim]');
  const input = document.querySelector<HTMLInputElement>('[data-search-input]');
  const list = document.querySelector<HTMLUListElement>('[data-search-list]');
  const hint = document.querySelector<HTMLElement>('[data-search-hint]');
  const askAnswer = document.querySelector<HTMLElement>('[data-pask-answer]');
  const askStatus = document.querySelector<HTMLElement>('[data-pask-status]');
  const askBody = document.querySelector<HTMLElement>('[data-pask-body]');
  const askRoutes = document.querySelector<HTMLElement>('[data-pask-routes]');
  if (trigger && overlay && scrim && input && list && hint && askAnswer && askStatus && askBody && askRoutes) {
    let docs: SearchDoc[] | null = null;
    let loading = false;
    let options: SearchDoc[] = []; // flat, in rendered order
    let askOffered = false; // CHK-6.7: one extra "ask the assistant" option at the end
    let asking = false;
    let active = -1;
    const total = () => options.length + (askOffered ? 1 : 0);

    const KIND_LABEL: Record<string, string> = {
      remedy: 'Remedies',
      intervention: 'Interventions',
      outcome: 'Outcomes',
      context: 'Context',
    };

    const loadDocs = async () => {
      if (docs || loading) return;
      loading = true;
      try {
        const res = await fetch('/search-index.json');
        docs = (await res.json()) as SearchDoc[];
      } catch {
        docs = [];
      }
      loading = false;
      if (!overlay.hidden) run(input.value); // re-run if user already typed
    };

    const esc = (s: string) =>
      s.replace(/[&<>"']/g, (c) =>
        ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' })[c] as string,
      );

    const badge = (tier: string) => {
      const t = tier.toLowerCase();
      return (
        `<span class="p-badge" style="background:var(--grade-${t}-tint);border:1px solid var(--grade-${t});color:var(--grade-${t})">` +
        `<span class="p-glyph" aria-hidden="true">${esc(tier)}</span></span>`
      );
    };

    const render = () => {
      // group in rendered order (by kind); options[] stays flat for keyboard nav
      const groups = new Map<string, SearchDoc[]>();
      for (const d of options) (groups.get(d.kind) ?? groups.set(d.kind, []).get(d.kind)!).push(d);
      let html = '';
      let i = 0;
      for (const [kind, rows] of groups) {
        html += `<li class="p-group" role="presentation">${esc(KIND_LABEL[kind] ?? kind)} · ${rows.length}</li>`;
        for (const d of rows) {
          html +=
            `<li id="p-opt-${i}" class="p-row" role="option" aria-selected="${i === active}" data-i="${i}" data-url="${esc(d.url)}" aria-label="grade ${esc(d.tier)}, ${esc(d.name)}">` +
            badge(d.tier) +
            `<span class="p-main"><span class="p-name">${esc(d.name)}</span><span class="p-cat">${esc(d.category)}</span></span>` +
            `<span class="p-grade">grade ${esc(d.tier)}</span></li>`;
          i++;
        }
      }
      if (askOffered) {
        const q = input.value.trim();
        html += `<li class="p-group" role="presentation">Assistant</li>`;
        html +=
          `<li id="p-opt-${i}" class="p-row p-askrow" role="option" aria-selected="${i === active}" data-i="${i}" data-ask-row aria-label="Ask Somnary's assistant: ${esc(q)}">` +
          `<span class="p-badge" aria-hidden="true"><span class="p-glyph">?</span></span>` +
          `<span class="p-main"><span class="p-name">${asking ? 'Thinking…' : `Ask: “${esc(q)}”`}</span>` +
          `<span class="p-cat">answers only from Somnary’s cited pages</span></span>` +
          `<span class="p-grade">ask ↵</span></li>`;
      }
      list.innerHTML = html;
      input.setAttribute('aria-expanded', total() ? 'true' : 'false');
      const q = input.value.trim();
      if (q && total() === 0) {
        hint.textContent = 'No matches — try a compound, an outcome, or a symptom';
      } else {
        hint.textContent = 'Type to search · ↑↓ to move · enter to open · esc to close';
      }
      syncActive();
    };

    const syncActive = () => {
      const rows = list.querySelectorAll<HTMLElement>('.p-row');
      rows.forEach((r) => r.setAttribute('aria-selected', r.dataset.i === String(active) ? 'true' : 'false'));
      if (active >= 0 && rows[active]) {
        input.setAttribute('aria-activedescendant', `p-opt-${active}`);
        rows[active].scrollIntoView({ block: 'nearest' });
      } else {
        input.removeAttribute('aria-activedescendant');
      }
    };

    const resetAnswer = () => {
      askAnswer.hidden = true;
      askStatus.textContent = '';
      askBody.innerHTML = '';
      askRoutes.hidden = true;
      askRoutes.innerHTML = '';
    };

    const STATUS_LABEL: Record<AskResponse['status'], string> = {
      answered: 'From Somnary’s cited evidence',
      refused: 'This needs a person, not a page',
      'no-evidence': 'Not in Somnary’s reviewed evidence',
      error: 'Could not answer',
    };

    // Same escaping + [n] → footnote-href pattern as AskPanel.astro (the remedy-page assistant).
    const renderAnswer = (res: AskResponse) => {
      askAnswer.hidden = false;
      askStatus.textContent = STATUS_LABEL[res.status] ?? '';
      const byN = new Map(res.citations.map((c) => [String(c.n), c]));
      const paragraphs = res.answer.split(/\n{2,}/).filter((p) => p.trim());
      askBody.innerHTML = paragraphs
        .map((p) => {
          const linked = esc(p).replace(/\[(\d{1,3})\]/g, (m, d) => {
            const c = byN.get(d);
            return c ? `<a class="ask-cref" href="${esc(c.href)}">[${esc(d)}]</a>` : m;
          });
          const head = linked.match(/^([A-Z][^:]{2,40}):\s*/);
          if (head) return `<p class="pa-head">${head[1]}</p><p>${linked.slice(head[0].length)}</p>`;
          return `<p>${linked}</p>`;
        })
        .join('');
      const routeLinks: Array<{ href: string; label: string }> = [];
      if (res.answeredFrom) routeLinks.push({ href: res.answeredFrom.url, label: `From the ${res.answeredFrom.name} page` });
      if (res.route) routeLinks.push(res.route);
      for (const l of res.links ?? []) routeLinks.push(l);
      if (routeLinks.length) {
        askRoutes.hidden = false;
        askRoutes.innerHTML = routeLinks.map((l) => `<a href="${esc(l.href)}">→ ${esc(l.label)}</a>`).join('');
      } else {
        askRoutes.hidden = true;
        askRoutes.innerHTML = '';
      }
    };

    const doAsk = async () => {
      const question = input.value.trim();
      if (asking || question.length < 3) return;
      asking = true;
      render();
      resetAnswer();
      askAnswer.hidden = false;
      askStatus.textContent = 'Thinking…';
      try {
        const res = await fetch('/api/search-ask', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ question }),
        });
        if (!res.ok) {
          renderAnswer({
            status: 'error',
            answer: 'Something went wrong reaching the assistant. You can browse the tier board or a remedy page instead. This is educational, not medical advice.',
            citations: [],
            route: null,
          });
          return;
        }
        renderAnswer((await res.json()) as AskResponse);
      } catch {
        renderAnswer({
          status: 'error',
          answer: 'Something went wrong reaching the assistant. You can browse the tier board or a remedy page instead. This is educational, not medical advice.',
          citations: [],
          route: null,
        });
      } finally {
        asking = false;
        render();
      }
    };

    let timer: number | undefined;
    const run = (q: string) => {
      if (!docs) {
        loadDocs();
        return;
      }
      const scored = searchDocsScored(q, docs);
      options = scored.map((r) => r.doc);
      askOffered = shouldOfferAsk(q, scored[0]?.score ?? 0, scored.length);
      resetAnswer();
      active = total() ? 0 : -1;
      render();
    };

    const open = () => {
      if (!overlay.hidden) return;
      overlay.hidden = false;
      loadDocs();
      input.value = '';
      options = [];
      askOffered = false;
      active = -1;
      resetAnswer();
      render();
      input.focus();
    };
    const close = () => {
      if (overlay.hidden) return;
      overlay.hidden = true;
      input.value = '';
      options = [];
      askOffered = false;
      active = -1;
      resetAnswer();
      trigger.focus();
    };

    const move = (delta: number) => {
      const n = total();
      if (!n) return;
      active = (active + delta + n) % n;
      syncActive();
    };
    const choose = () => {
      if (askOffered && active === options.length) {
        doAsk();
        return;
      }
      const d = options[active];
      if (d) window.location.href = d.url;
    };

    trigger.addEventListener('click', open);
    scrim.addEventListener('click', close);

    // Click on the ask row submits the question (result rows stay keyboard-driven, as before).
    list.addEventListener('click', (e) => {
      if ((e.target as HTMLElement)?.closest('[data-ask-row]')) doAsk();
    });

    input.addEventListener('input', () => {
      window.clearTimeout(timer);
      timer = window.setTimeout(() => run(input.value), 80);
    });

    // keyboard inside the palette
    overlay.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        e.preventDefault();
        close();
      } else if (e.key === 'ArrowDown') {
        e.preventDefault();
        move(1);
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        move(-1);
      } else if (e.key === 'Enter') {
        e.preventDefault();
        choose();
      } else if (e.key === 'Tab') {
        e.preventDefault(); // trap: keep focus on the input (options are arrow-navigated)
        input.focus();
      }
    });

    // global open shortcuts: ⌘K / Ctrl+K, and "/" when not typing in a field
    document.addEventListener('keydown', (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 'k') {
        e.preventDefault();
        overlay.hidden ? open() : close();
      } else if (
        e.key === '/' &&
        overlay.hidden &&
        !/^(input|textarea|select)$/i.test((e.target as HTMLElement)?.tagName) &&
        !(e.target as HTMLElement)?.isContentEditable
      ) {
        e.preventDefault();
        open();
      }
    });
  }
</script>

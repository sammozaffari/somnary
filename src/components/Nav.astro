---
// Sticky top nav — DESIGN_SYSTEM §3 global chrome. Wordmark left; section links right.
// The ⌘K search trigger is intentionally deferred to CHK-4.2 (slot left below). Only links
// to pages that exist today are rendered, to avoid 404s; add more as routes land.
import Wordmark from './Wordmark.astro';
import SearchPalette from './SearchPalette.astro';
import SessionNav from './account/SessionNav.astro';

// CHK-7.3c — /lens is the primary AI nav entry (the Lens is the AI front door). /guide is DROPPED from
// the top nav (the homepage carries the demoted "Talk it through" secondary line); /guide stays
// reachable by URL and internal links — this only demotes it from the global chrome.
const links = [
  { href: '/start-here', label: 'Start here' },
  { href: '/tiers', label: 'Remedies' },
  { href: '/lens', label: 'Lens' },
  { href: '/label-checker', label: 'Label checker' },
  { href: '/compare', label: 'Compare' },
  { href: '/sleep-habits', label: 'Sleep habits' },
  { href: '/safety', label: 'Safety' },
  { href: '/methodology', label: 'Methodology' },
];
const path = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<nav class="nav" aria-label="Primary">
  <Wordmark />
  <ul class="links">
    {
      links.map((l) => {
        const current = path === l.href.replace(/\/$/, '');
        return (
          <li>
            <a href={l.href} aria-current={current ? 'page' : undefined} class:list={['link', { current }]}>
              {l.label}
            </a>
          </li>
        );
      })
    }
    <li><SearchPalette /></li>
    {/* Signed-in indicator (CHK-6.9c): hidden by default; revealed only for a real session.
        Adds NO sign-in CTA — no login wall in the global chrome. */}
    <SessionNav />
  </ul>
</nav>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 50;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-5);
    height: 64px;
    padding: 0 var(--sp-7);
    /* §3: translucent paper + blur + hairline rule. */
    background: color-mix(in srgb, var(--paper) 86%, transparent);
    backdrop-filter: blur(10px);
    border-bottom: var(--border-hairline);
  }
  .links {
    display: flex;
    align-items: center;
    gap: var(--sp-5);
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .link {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    color: var(--muted);
    text-decoration: none;
    transition: color var(--dur-fast) var(--ease-soft);
  }
  .link:hover,
  .link.current {
    color: var(--ink);
  }
  @media (max-width: 640px) {
    .nav {
      padding: 0 var(--sp-5);
    }
  }
</style>

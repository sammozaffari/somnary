---
// Sources — DESIGN_SYSTEM §4 block 9. The numbered footnote list; every entry resolves to a real
// PubMed / DOI / registry link via the shared builder (src/lib/cite.ts), the same mapping the
// CHK-0.5 resolver validates. Rendered server-side so all citation detail is in the HTML and
// crawlable even with JS off (the popover is progressive enhancement on top of this). No
// rel="sponsored" anywhere — independence non-negotiable.
import { sourceUrl, sourceIdLabel, sourceTypeLabel, type CiteSource } from '../lib/cite';

interface Props {
  sources: CiteSource[];
}
const { sources } = Astro.props;
const ordered = [...sources].sort((a, b) => a.n - b.n);
---

<ol class="sources">
  {
    ordered.map((s) => (
      <li id={`source-${s.n}`} class="source">
        <span class="num" aria-hidden="true">{s.n}</span>
        <div class="body">
          <p class="s-type">{sourceTypeLabel(s.type)}</p>
          <p class="s-title">{s.title}</p>
          <p class="s-line">{s.sourceLine}</p>
          <p class="s-finding">{s.finding}</p>
          <a class="s-link" href={sourceUrl(s)} target="_blank" rel="noopener noreferrer">
            {sourceIdLabel(s)} ↗
          </a>
        </div>
      </li>
    ))
  }
</ol>

<style>
  .sources {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--sp-5);
  }
  .source {
    display: grid;
    grid-template-columns: 32px 1fr;
    gap: var(--sp-4);
    padding-top: var(--sp-5);
    border-top: var(--border-hairline);
  }
  .source:first-child {
    border-top: none;
    padding-top: 0;
  }
  .num {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--muted);
  }
  .body {
    min-width: 0;
  }
  .s-type {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--eucalyptus);
    margin: 0 0 var(--sp-2);
  }
  .s-title {
    font-family: var(--font-display);
    font-size: var(--text-md);
    line-height: var(--lh-lg);
    color: var(--ink);
    margin: 0 0 var(--sp-2);
  }
  .s-line {
    font-size: var(--text-sm);
    color: var(--muted);
    margin: 0 0 var(--sp-2);
  }
  .s-finding {
    font-size: var(--text-sm);
    line-height: var(--lh-sm);
    color: var(--muted);
    margin: 0 0 var(--sp-3);
  }
  .s-link {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--primary);
    text-decoration: none;
  }
  .s-link:focus-visible {
    outline: none;
    box-shadow: var(--ring);
    border-radius: var(--r-sm);
  }
</style>

---
// Remedy lead block — CHK-2.1 (strategy doc 03 "decision-first lead"; DESIGN_SYSTEM §11.3).
// The decision-first opener on every remedy page: the grade-anchored decision-translation line
// ("Grade A · Strong — <translation>") and a compact best-for / not-for / biggest-risk /
// studied-dose grid. The grade MARK lives in the hero label row above (GradeStamp, §11.3) —
// the emblem/badge column retired with the hero plates: the hero IS the remedy, and this block
// keeps the grade in plain text so never-color-alone holds twice on every page. It reuses ONLY
// already-cited structured fields from the remedy — it introduces NO new factual claims
// (CLAUDE.md: citations are data).
//
// Graceful empties (CLAUDE.md conservative safety): the not-for and biggest-risk rows are OMITTED
// entirely when absent. A blank or "no risk" row must never render — absence must never read as
// "this is safe". best-for and studied-dose render "not established" when unknown (an unknown
// value, not a hidden risk); the studied-dose row is omitted for interventions, which have no dose.
//
// Legible without color alone (DESIGN §3): the grade renders as plain text (letter + tier word)
// in the translation line; every decision row is labeled in text.
import type { TierId } from '../lib/tiers';
import { getTier } from '../lib/tiers';

interface Props {
  tier: TierId;
  format?: 'supplement' | 'intervention';
  bestFor: string[];
  notFor: string[];
  biggestRisk: string | null;
  studiedDose: string | null;
  reviewDate: string;
}
const { tier, format = 'supplement', bestFor, notFor, biggestRisk, studiedDose, reviewDate } =
  Astro.props;
const t = getTier(tier);

const bestForText = bestFor.length ? bestFor.join(' · ') : null;
const notForText = notFor.length ? notFor.join(' · ') : null;
const showDose = format !== 'intervention';
---

<section class="lead" aria-label="Grade and decision summary">
  <div class="decision">
    <p class="translation">
      <strong class="gline">Grade {tier} · {t.name}</strong> — {t.decisionTranslation}
    </p>

    <dl class="grid">
      <div class="drow">
        <dt class="dlabel">Best for</dt>
        <dd class="dvalue">{bestForText ?? <em class="unknown">Not established</em>}</dd>
      </div>

      {notForText && (
        <div class="drow">
          <dt class="dlabel">Not for</dt>
          <dd class="dvalue">{notForText}</dd>
        </div>
      )}

      {biggestRisk && (
        <div class="drow">
          <dt class="dlabel">Biggest risk</dt>
          <dd class="dvalue">{biggestRisk}</dd>
        </div>
      )}

      {showDose && (
        <div class="drow">
          <dt class="dlabel">Studied dose</dt>
          <dd class="dvalue">{studiedDose ?? <em class="unknown">Not established</em>}</dd>
        </div>
      )}
    </dl>

    <p class="review">
      Reviewed <time datetime={reviewDate}>{reviewDate}</time> · found an error?
      <a href="/methodology#corrections">corrections →</a>
    </p>
  </div>
</section>

<style>
  .lead {
    padding: var(--sp-7);
    background: var(--surface);
    border: var(--border-hairline);
    border-radius: var(--r-xl);
  }

  .decision {
    min-width: 0;
  }
  .translation {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    line-height: var(--lh-lg);
    color: var(--ink);
    margin: 0 0 var(--sp-5);
    max-width: 60ch;
  }
  /* grade in plain text, anchoring the translation (never color alone — the stamp above is
     letter + word too) */
  .gline {
    font-weight: 700;
  }

  .grid {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
  }
  .drow {
    display: grid;
    grid-template-columns: 120px 1fr;
    gap: var(--sp-5);
    align-items: baseline;
    padding: var(--sp-3) 0;
    border-top: var(--border-hairline);
  }
  .dlabel {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    color: var(--muted);
    margin: 0;
  }
  .dvalue {
    font-size: var(--text-base);
    line-height: var(--lh-base);
    color: var(--ink);
    margin: 0;
  }
  .unknown {
    color: var(--muted);
    font-style: italic;
  }

  .review {
    margin: var(--sp-5) 0 0;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    color: var(--muted);
  }
  .review a {
    color: var(--primary);
    text-decoration: none;
  }
  .review a:hover {
    text-decoration: underline;
  }

  @media (max-width: 640px) {
    .lead {
      padding: var(--sp-6);
    }
  }
</style>

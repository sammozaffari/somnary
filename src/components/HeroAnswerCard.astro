---
// Hero answer card — CHK home-hero (design doc 2026-07-13). A LIVE remedy answer in the
// first screen: grade + verdict + biggest-risk + read-more, for each popular-check remedy.
// All cards are server-rendered at build time from remedy frontmatter (crawlable, no fetch,
// no framework island). The first slug's card is visible; the rest carry `hidden` and are
// revealed by the popular-check pills acting as a switcher (inline script in index.astro).
// No-JS: the pills stay plain <a> links to /r/{slug}; this card block is real HTML content
// with melatonin's answer fully rendered.
//
// Guardrails (CLAUDE.md): every line is VERBATIM already-cited frontmatter — introduces NO
// new claim. biggestRisk renders in the vermilion safety register (safety in the first
// screen). No dose, no recommendation. No --action here (the oxblood budget is spent once on
// the hero primary CTA); the read-more is a plain --primary text link.
import { getCollection } from 'astro:content';
import RemedyEmblem from './RemedyEmblem.astro';
import { getTier } from '../lib/tiers';

interface Props {
  slugs: string[]; // ordered popular-check slugs; slugs[0] is the default-visible card
}
const { slugs } = Astro.props;

const all = await getCollection('remedies', (e) => !e.data.draft);
const bySlug = new Map(all.map((e) => [e.id, e]));

// Resolve in the given order; skip any slug that isn't a real remedy (never a dead card).
const cards = slugs
  .map((slug) => bySlug.get(slug))
  .filter((e): e is NonNullable<typeof e> => Boolean(e))
  .map((e) => ({
    slug: e.id,
    name: e.data.name,
    tier: e.data.tier,
    tierWord: getTier(e.data.tier).name,
    oneLineVerdict: e.data.oneLineVerdict,
    biggestRisk: e.data.biggestRisk,
  }));
---

<div class="answer-stack">
  {
    cards.map((c, i) => (
      <article class="answer-card" data-answer-card={c.slug} hidden={i !== 0}>
        <header class="ac-head">
          <RemedyEmblem slug={c.slug} tier={c.tier} name={c.name} size="spot" decorative />
          <div class="ac-id">
            <h3 class="ac-name">{c.name}</h3>
            <p class="ac-grade">Grade {c.tier} · {c.tierWord}</p>
          </div>
        </header>
        <p class="ac-verdict">{c.oneLineVerdict}</p>
        {c.biggestRisk && (
          <p class="ac-risk">
            <span class="ac-risk-label">Biggest risk</span>
            <span class="ac-risk-text">{c.biggestRisk}</span>
          </p>
        )}
        <a class="ac-link" href={`/r/${c.slug}`}>
          Read the full evidence <span aria-hidden="true">→</span>
        </a>
      </article>
    ))
  }
</div>

<style>
  .answer-stack {
    /* no-JS: one card visible at a time; the block sizes to whichever is shown */
    display: block;
  }
  .answer-card {
    display: flex;
    flex-direction: column;
    gap: var(--sp-4);
    background: var(--surface);
    border: var(--border-hairline);
    border-radius: var(--r-xl);
    padding: var(--sp-6);
    box-shadow: var(--shadow-sm);
  }
  .answer-card[hidden] {
    display: none;
  }

  /* JS-upgraded crossfade: stack every card in one grid cell (container sizes to the
     tallest, so no height jump) and dissolve between them as the spotlight advances. */
  .answer-stack.is-live {
    display: grid;
  }
  .answer-stack.is-live .answer-card {
    grid-area: 1 / 1;
    opacity: 0;
    visibility: hidden;
    transition:
      opacity var(--dur-slow) var(--ease-settle),
      visibility var(--dur-slow) var(--ease-settle);
  }
  .answer-stack.is-live .answer-card.is-active {
    opacity: 1;
    visibility: visible;
  }
  @media (prefers-reduced-motion: reduce) {
    .answer-stack.is-live .answer-card {
      transition: none;
    }
  }

  .ac-head {
    display: flex;
    align-items: center;
    gap: var(--sp-5);
  }
  .ac-id {
    display: flex;
    flex-direction: column;
    gap: var(--sp-1);
    min-width: 0;
  }
  /* adjacent text grade (§11.1: the seal letter is never the only grade) */
  .ac-grade {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    color: var(--muted);
    margin: 0;
  }
  .ac-name {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    line-height: var(--lh-xl);
    letter-spacing: var(--tracking-tight);
    color: var(--ink);
    margin: 0;
  }
  .ac-verdict {
    font-size: var(--text-md);
    line-height: var(--lh-md);
    color: var(--ink);
    margin: 0;
  }

  /* biggest risk — vermilion safety register, DISTINCT from oxblood (§ safety) */
  .ac-risk {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
    background: var(--warning-bg);
    border: 1px solid var(--vermilion);
    border-radius: var(--r-md);
    padding: var(--sp-4);
    margin: 0;
  }
  .ac-risk-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    color: var(--safety-ink);
  }
  .ac-risk-text {
    font-size: var(--text-sm);
    line-height: var(--lh-sm);
    color: var(--ink);
  }

  .ac-link {
    align-self: flex-start;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    color: var(--primary);
    text-decoration: none;
  }
  .ac-link:hover {
    text-decoration: underline;
  }
  .ac-link:focus-visible {
    outline: none;
    box-shadow: var(--ring);
    border-radius: var(--r-xs);
  }
</style>

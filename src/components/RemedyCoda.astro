---
// Remedy coda plate — DESIGN_SYSTEM §11.3 (coda addendum, owner-ratified 2026-07-19).
// The closing image at the bottom of each remedy page: the HERO's world an hour later and
// closer to the ground, everything settled toward sleep (melatonin north star approved
// 2026-07-19; family brief in docs/plans/2026-07-19-remedy-coda-plates-prompt.md). The page
// paper melts INTO the plate from above — the hero's melt, mirrored — and the band ends in
// a hard cut, seating like a framed print against the footer's paper gap + hairline (§11.3).
// A short band, not a second hero: the reader enters through the hero and leaves through
// its coda.
//
// Same rules as the hero: pure art, no type on the plate ever, decorative (alt="" — this is
// atmosphere, not content), the page never depends on it (a missing coda renders nothing, so
// the remaining plates light up as pure asset commits as the batch lands). Bottom-of-page:
// lazy-loaded, never competes with the hero LCP.
import { Image } from 'astro:assets';

interface Props {
  slug: string;
}
const { slug } = Astro.props;

const codas = import.meta.glob<{ default: ImageMetadata }>('../assets/remedy-codas/*.webp', {
  eager: true,
});
const plate = codas[`../assets/remedy-codas/${slug}.webp`]?.default;

// Per-plate focal point — codas render as a short wide band, so the slice matters. Family
// rule keeps the top third calm (it feeds the melt-in) and detail low; the default favors
// the lower-middle of the plate.
const FOCAL: Record<string, string> = {
  melatonin: 'center 45%', // horizon thread + the top of the moon path
};
const focal = FOCAL[slug] ?? 'center 55%';
---

{
  plate && (
    <div class="coda" aria-hidden="true">
      <Image
        src={plate}
        alt=""
        widths={[828, 1400, 2048, 2880]}
        sizes="100vw"
        loading="lazy"
        style={`object-position:${focal}`}
      />
    </div>
  )
}

<style>
  .coda {
    position: relative;
    height: 28vh;
    min-height: 200px;
    overflow: hidden;
    /* seat flush on the footer hairline (owner, 2026-07-19): the Footer opens with
       margin-top --sp-10; this negative bottom margin collapses with it to exactly 0,
       so the plate's hard cut lands directly on the hairline — no paper gap. */
    margin-bottom: calc(-1 * var(--sp-10));
    /* the melt-in: the page paper dissolves into the plate from above — the hero's mask,
       mirrored. Alpha mask (not a painted fade): the body background is a gradient. */
    -webkit-mask-image: linear-gradient(to bottom, transparent 0%, #000 45%);
    mask-image: linear-gradient(to bottom, transparent 0%, #000 45%);
  }
  .coda img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (max-width: 640px) {
    .coda {
      height: 22vh;
      min-height: 160px;
    }
  }
</style>

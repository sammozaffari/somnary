---
// Grade badge — DESIGN_SYSTEM v2 §3. Filled grade color, WHITE Archivo glyph.
// Header (big) variant uses the ratified gradient fill (grade → darker anchor).
// Glyph sizes are kept in the "large text" band (≥18.66px bold) so white-on-grade-C
// (3.64:1) clears WCAG AA large (3:1) at every size. Always paired with a text grade
// label / aria-label — never color alone (§3, §10).
import type { TierId } from '../lib/tiers';

interface Props {
  tier: TierId;
  size?: 'inline' | 'card' | 'header' | 'lead';
}
const { tier, size = 'card' } = Astro.props;

// box / glyph / radius per size. glyph ≥19px (large-text band) at inline and up.
// `lead` is the remedy lead-block "big badge" (DESIGN §3: 152×152, letter 112, gradient fill).
const SIZES = {
  inline: { box: 30,  glyph: 19,  radius: 'var(--r-sm)', weight: 800, grad: false },
  card:   { box: 44,  glyph: 27,  radius: 'var(--r-sm)', weight: 800, grad: false },
  header: { box: 78,  glyph: 50,  radius: 'var(--r-lg)', weight: 900, grad: true },
  lead:   { box: 152, glyph: 112, radius: 'var(--r-lg)', weight: 900, grad: true },
} as const;
const s = SIZES[size];
const lc = tier.toLowerCase();

const fill = s.grad
  ? `linear-gradient(145deg, var(--grade-${lc}), var(--grade-${lc}-anchor))`
  : `var(--grade-${lc})`;

const boxStyle = [
  `width:${s.box}px`,
  `height:${s.box}px`,
  `border-radius:${s.radius}`,
  `background:${fill}`,
  s.grad ? 'box-shadow:0 22px 50px rgba(0,76,80,.23)' : 'box-shadow:inset 0 0 0 1px rgba(255,255,255,.22)',
  'color:#ffffff',
].join(';');
const glyphStyle = [
  'font-family:var(--font-display)',
  `font-weight:${s.weight}`,
  'line-height:1',
  `font-size:${s.glyph}px`,
  'letter-spacing:-0.06em',
  'transform:translateY(var(--grade-optical-shift))',
].join(';');
---

<span
  class="tier-badge"
  style={boxStyle}
  role="img"
  aria-label={`grade ${tier}`}
>
  <span style={glyphStyle} aria-hidden="true">{tier}</span>
</span>

<style>
  .tier-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex: none;
  }
</style>

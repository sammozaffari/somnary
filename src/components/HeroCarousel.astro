---
// Hero carousel — full-panel morphing above-the-fold (design 2026-07-15).
// One full-width panel; N slides stacked in a single grid cell (the panel sizes to the
// tallest slide, so no height jump) that crossfade as the carousel advances. Replaces the
// old two-column hero + right-card spotlight (HeroAnswerCard, now absorbed here).
//
// Three slide kinds:
//   • brand   — the page's single H1 + dek + CTAs. The oxblood --action CTA lives HERE and
//               ONLY here (§10 budget). Slide 1; visible with no JS.
//   • remedy  — icon + name + grade + one-line verdict + biggest-risk (vermilion register)
//               + read-more. Every line is VERBATIM already-cited frontmatter — no new claim,
//               no dose, no recommendation. Safety in the first screen.
//   • utility — a "useful way to use the site": icon chip + title + one line + a --primary link.
//
// No-JS / crawl: slide 1 renders fully; the rest are real HTML (with their own links and grade
// badges), so Google and no-JS users reach every route. Controls (dots + arrows) are a JS
// enhancement over that base. Auto-advance pauses on hover/focus and is off under reduced motion.
import { getCollection } from 'astro:content';
import TierBadge from './TierBadge.astro';
import RemedyIcon from './RemedyIcon.astro';
import { TIERS, getTier } from '../lib/tiers';
import type { TierId } from '../lib/tiers';
import type { SlideSpec } from '../lib/hero-slides';
import { Search, Compass, ShieldAlert, Package, Scale } from '@lucide/astro';

interface Props {
  slides: SlideSpec[];
}
const { slides } = Astro.props;

// Remedy data — same collection query the spotlight used; resolve verbatim frontmatter only.
const all = await getCollection('remedies', (e) => !e.data.draft);
const bySlug = new Map(all.map((e) => [e.id, e]));

// Utility-slide copy lives here (presentational hero content). Each routes to a real page.
const UTILITY = {
  situations: {
    Icon: Compass,
    title: 'Start from your sleep problem',
    copy: "Not sure which remedy? Route by what you're trying to fix, not by molecule.",
    href: '#situations',
    cta: 'Browse sleep problems',
  },
  blend: {
    Icon: Package,
    title: 'Bought a sleep blend?',
    copy: 'Decode the label before you trust it — proprietary blends, missing doses, studied-dose mismatch.',
    href: '/sleep-blends',
    cta: 'Decode a blend',
  },
  grades: {
    Icon: Scale,
    title: 'How our grades work',
    // negative disclaimer: the grade explicitly does NOT assert personal safety
    copy: 'A grade rates how strong the human evidence is — not whether a remedy is safe for you.', // FRAMING-LINT-OK
    href: '/methodology',
    cta: 'See the full S–F rubric',
  },
} as const;

// Resolve each spec to a renderable slide; drop any remedy slug that isn't real (never a dead slide).
type Resolved =
  | { kind: 'brand'; label: string }
  | {
      kind: 'remedy';
      label: string;
      slug: string;
      name: string;
      tier: TierId;
      oneLineVerdict: string;
      biggestRisk?: string;
    }
  | {
      kind: 'utility';
      label: string;
      Icon: (typeof UTILITY)[keyof typeof UTILITY]['Icon'];
      title: string;
      copy: string;
      href: string;
      cta: string;
      isGrades: boolean;
    };

const resolved: Resolved[] = slides
  .map((s): Resolved | null => {
    if (s.kind === 'brand') return { kind: 'brand', label: 'Overview' };
    if (s.kind === 'utility') {
      const u = UTILITY[s.key];
      return {
        kind: 'utility',
        label: u.title,
        Icon: u.Icon,
        title: u.title,
        copy: u.copy,
        href: u.href,
        cta: u.cta,
        isGrades: s.key === 'grades',
      };
    }
    const e = bySlug.get(s.slug);
    if (!e) return null;
    return {
      kind: 'remedy',
      label: e.data.name,
      slug: e.id,
      name: e.data.name,
      tier: e.data.tier,
      oneLineVerdict: e.data.oneLineVerdict,
      biggestRisk: e.data.biggestRisk ?? undefined,
    };
  })
  .filter((s): s is Resolved => s !== null);
---

<section
  class="hero-carousel"
  role="group"
  aria-roledescription="carousel"
  aria-label="Ways to use Somnary"
  data-hero-carousel
>
  <div class="hc-viewport">
    <div class="hc-stack">
      {
        resolved.map((s, i) => (
          <div
            class="hc-slide"
            data-slide
            role="group"
            aria-roledescription="slide"
            aria-label={`${i + 1} of ${resolved.length}: ${s.label}`}
            hidden={i !== 0}
          >
            {s.kind === 'brand' && (
              <div class="hc-brand">
                <p class="hc-eyebrow">Independent · evidence-graded · reader-funded</p>
                <h1 class="hc-headline">Check a sleep remedy before you take it</h1>
                <p class="hc-dek">
                  Every sleep supplement, graded on real science — not the hype on the label.
                </p>
                <div class="hc-cta-row">
                  <a class="hc-cta hc-cta-action" href="/search">
                    <Search size={16} strokeWidth={2} aria-hidden="true" /> Check a remedy
                  </a>
                  <a class="hc-cta hc-cta-secondary" href="#situations">
                    <Compass size={16} strokeWidth={2} aria-hidden="true" /> Start from your sleep problem
                  </a>
                  <a class="hc-cta hc-cta-ghost" href="/safety">
                    <ShieldAlert size={16} strokeWidth={2} aria-hidden="true" /> Read safety red flags
                  </a>
                </div>
              </div>
            )}

            {s.kind === 'remedy' && (
              <div class="hc-remedy">
                <header class="hc-remedy-head" style={`--g:var(--grade-${s.tier.toLowerCase()})`}>
                  {/* plate + stamp (§11.2) at hero scale — the big linocut IS the hero; the grade
                      is pressed on as an assessor's stamp (letter + tier word, grade color, −3°). */}
                  <div class="hc-plate">
                    <span class="hc-plate-art"><RemedyIcon slug={s.slug} size="fill" /></span>
                    <span
                      class="hc-stamp"
                      role="img"
                      aria-label={`grade ${s.tier}, ${getTier(s.tier).name}`}
                    >
                      <b>{s.tier}</b> {getTier(s.tier).name}
                    </span>
                  </div>
                  <div class="hc-id">
                    <h2 class="hc-name">{s.name}</h2>
                    {/* plain-language decode of the grade (the stamp already shows the letter +
                        tier word) — verbatim decisionTranslation from lib/tiers, never invented */}
                    <p class="hc-grade">{getTier(s.tier).decisionTranslation}</p>
                    <p class="hc-verdict">{s.oneLineVerdict}</p>
                  </div>
                </header>
                {s.biggestRisk && (
                  <p class="hc-risk">
                    <span class="hc-risk-label">Biggest risk</span>
                    <span class="hc-risk-text">{s.biggestRisk}</span>
                  </p>
                )}
                <a class="hc-link" href={`/r/${s.slug}`} aria-label={`Read the full evidence on ${s.name}`}>
                  Read the full evidence <span aria-hidden="true">→</span>
                </a>
              </div>
            )}

            {s.kind === 'utility' && (
              <div class="hc-utility">
                <span class="hc-util-icon">
                  <s.Icon size={30} strokeWidth={1.75} aria-hidden="true" />
                </span>
                <h2 class="hc-util-title">{s.title}</h2>
                {s.isGrades && (
                  <ul class="hc-legend" aria-hidden="true">
                    {TIERS.map((t) => (
                      <li class="hc-legend-item">
                        <TierBadge tier={t.id} size="card" />
                      </li>
                    ))}
                  </ul>
                )}
                <p class="hc-util-copy">{s.copy}</p>
                <a class="hc-link" href={s.href}>
                  {s.cta} <span aria-hidden="true">→</span>
                </a>
              </div>
            )}
          </div>
        ))
      }
    </div>
  </div>

  <div class="hc-controls" data-hc-controls hidden>
    <button class="hc-arrow" type="button" data-hc-prev aria-label="Previous slide">
      <span aria-hidden="true">‹</span>
    </button>
    <div class="hc-dots" role="group" aria-label="Choose a slide">
      {
        resolved.map((s, i) => (
          <button
            class="hc-dot"
            type="button"
            data-hc-dot={i}
            aria-label={`Show ${s.label}`}
          >
            <span class="visually-hidden">{s.label}</span>
          </button>
        ))
      }
    </div>
    <button class="hc-arrow" type="button" data-hc-next aria-label="Next slide">
      <span aria-hidden="true">›</span>
    </button>
  </div>

  <p class="visually-hidden" aria-live="polite" data-hc-live></p>
</section>

<style>
  .hero-carousel {
    margin-bottom: var(--sp-7);
  }

  /* the morphing panel: one surface card; slides stack in a single grid cell */
  .hc-viewport {
    background: var(--surface);
    border: var(--border-hairline);
    border-radius: var(--r-xl);
    box-shadow: var(--shadow-sm);
    padding: var(--sp-6) var(--sp-7);
    overflow: hidden;
  }
  .hc-stack {
    display: block; /* no-JS: one slide visible, block sizes to it */
  }
  .hc-slide[hidden] {
    display: none;
  }

  /* JS-upgraded crossfade: every slide in one grid cell (panel sizes to the tallest), dissolve.
     The explicit minmax(0, 1fr) column is load-bearing: without it the single implicit grid
     column sizes to the widest slide's max-content and blows past the viewport on mobile
     (slides were rendering 427px wide inside a ~294px panel and clipping). */
  .hc-stack.is-live {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
  }
  .hc-stack.is-live .hc-slide {
    grid-area: 1 / 1;
    min-width: 0;
    /* center content vertically so the shorter slides sit balanced in the panel (whose height
       is set by the tallest, remedy, slide) rather than bottom-heavy */
    display: flex;
    flex-direction: column;
    justify-content: center;
    opacity: 0;
    visibility: hidden;
    /* incoming slide rests a touch low and lifts as it fades in — a crisp fade-and-lift */
    transform: translateY(var(--sp-3));
    transition:
      opacity var(--dur-base) var(--ease-soft),
      transform var(--dur-base) var(--ease-settle),
      visibility var(--dur-base) var(--ease-soft);
  }
  .hc-stack.is-live .hc-slide.is-active {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }
  @media (prefers-reduced-motion: reduce) {
    .hc-stack.is-live .hc-slide {
      transition: none;
      transform: none;
    }
  }

  /* content column — comfortable measure, so the morph reads as one object. The remedy slide
     is uncapped so its biggest-risk register spans the full panel width; only its verdict text
     keeps a readable measure (below). */
  .hc-brand,
  .hc-utility {
    max-width: 62ch;
  }

  /* brand slide */
  .hc-eyebrow {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    color: var(--muted);
    margin: 0;
  }
  .hc-headline {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    font-weight: 700;
    line-height: var(--lh-3xl);
    letter-spacing: var(--tracking-tight);
    color: var(--ink);
    margin: var(--sp-4) 0 var(--sp-5);
    max-width: 18ch;
  }
  .hc-dek {
    font-size: var(--text-md);
    line-height: var(--lh-md);
    color: var(--muted);
    margin: 0 0 var(--sp-6);
  }
  .hc-cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-3);
  }
  .hc-cta {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    min-height: var(--sp-7);
    padding: 0 var(--sp-5);
    border-radius: var(--r-pill);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    text-decoration: none;
    transition: transform var(--dur-fast) var(--ease-soft);
  }
  .hc-cta :global(svg) {
    flex: none;
  }
  .hc-cta:hover {
    transform: translateY(-1px);
  }
  .hc-cta:focus-visible {
    outline: none;
    box-shadow: var(--ring);
  }
  /* --action (oxblood): spent ONCE (the hero primary CTA) — §10 budget */
  .hc-cta-action {
    background: var(--action);
    color: var(--action-ink);
  }
  .hc-cta-secondary {
    background: var(--surface);
    color: var(--ink);
    border: var(--border-strong);
  }
  .hc-cta-ghost {
    background: transparent;
    color: var(--ink);
    border: var(--border-hairline);
  }

  /* remedy slide — the big linocut is the protagonist (§11.2 plate + stamp, hero scale) */
  .hc-remedy {
    display: flex;
    flex-direction: column;
    gap: var(--sp-5);
  }
  .hc-remedy-head {
    display: flex;
    align-items: center;
    gap: var(--sp-7);
    flex-wrap: wrap;
  }
  /* specimen plate: a soft-oxblood field holding the linocut big; the stamp sits in the corner */
  .hc-plate {
    position: relative;
    flex: none;
    display: grid;
    place-items: center;
    width: 320px;
    height: 288px;
    background: var(--primary-soft);
    border: var(--border-hairline);
    border-radius: var(--r-lg);
  }
  .hc-plate-art {
    width: 216px;
    height: 216px;
    display: grid;
    place-items: center;
    color: var(--primary);
  }
  /* assessor's stamp (§11.2): grade letter + tier word, grade color, hand-pressed −3° */
  .hc-stamp {
    position: absolute;
    right: var(--sp-4);
    bottom: var(--sp-4);
    transform: rotate(-3deg);
    display: inline-flex;
    align-items: baseline;
    gap: var(--sp-2);
    padding: var(--sp-1) var(--sp-3);
    border: 1.5px solid var(--g);
    border-radius: var(--r-xs);
    background: rgba(255, 255, 255, 0.62);
    color: var(--g);
    font-size: var(--text-sm);
    font-weight: 800;
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    line-height: 1;
    white-space: nowrap;
  }
  .hc-stamp b {
    font-size: var(--text-md);
    font-weight: 900;
    letter-spacing: -0.02em;
  }
  .hc-id {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--sp-3);
    min-width: 0;
  }
  .hc-name {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    line-height: var(--lh-2xl);
    letter-spacing: var(--tracking-tight);
    color: var(--ink);
    margin: 0;
  }
  /* plain-language grade decode — the stamp carries the letter + tier word; this glosses it
     (e.g. "Interesting but uncertain; do not rely on it.") */
  .hc-grade {
    margin: 0;
    font-size: var(--text-sm);
    line-height: var(--lh-sm);
    color: var(--muted);
    max-width: 60ch;
  }
  .hc-verdict {
    font-size: var(--text-md);
    line-height: var(--lh-md);
    color: var(--ink);
    margin: 0;
    max-width: 62ch; /* keep the verdict readable beside the emblem */
  }
  /* biggest risk — vermilion safety register, DISTINCT from oxblood; spans the full panel */
  .hc-risk {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
    background: var(--warning-bg);
    /* safety-card border — vermilion-alpha, matching the sanctioned §5 pattern (safety.astro) */
    border: 1px solid color-mix(in srgb, var(--vermilion) 40%, transparent);
    border-radius: var(--r-md);
    padding: var(--sp-4);
    margin: 0;
  }
  .hc-risk-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    color: var(--safety-ink);
  }
  .hc-risk-text {
    font-size: var(--text-sm);
    line-height: var(--lh-sm);
    color: var(--ink);
  }

  /* utility slide */
  .hc-utility {
    display: flex;
    flex-direction: column;
    gap: var(--sp-4);
    align-items: flex-start;
  }
  /* bare oxblood affordance mark — no chip, matching the situation tiles */
  .hc-util-icon {
    display: inline-flex;
    color: var(--primary);
  }
  .hc-util-title {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    line-height: var(--lh-2xl);
    letter-spacing: var(--tracking-tight);
    color: var(--ink);
    margin: 0;
  }
  .hc-util-copy {
    font-size: var(--text-md);
    line-height: var(--lh-md);
    color: var(--muted);
    margin: 0;
  }
  .hc-legend {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-3);
    margin: 0;
    padding: 0;
  }

  /* shared read-more / cta text link — --primary, never the --action budget */
  .hc-link {
    align-self: flex-start;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    color: var(--primary);
    text-decoration: none;
  }
  .hc-link:hover {
    text-decoration: underline;
  }
  .hc-link:focus-visible {
    outline: none;
    box-shadow: var(--ring);
    border-radius: var(--r-xs);
  }

  /* controls — dots + arrows below the panel (JS only; hidden until upgraded) */
  .hc-controls {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--sp-4);
    margin-top: var(--sp-5);
  }
  .hc-controls[hidden] {
    display: none;
  }
  .hc-arrow {
    display: inline-grid;
    place-items: center;
    width: var(--sp-7);
    height: var(--sp-7);
    border-radius: var(--r-pill);
    background: var(--surface);
    border: var(--border-hairline);
    color: var(--ink);
    font-size: var(--text-lg);
    line-height: 1;
    cursor: pointer;
    transition: border-color var(--dur-fast) var(--ease-soft);
  }
  .hc-arrow:hover {
    border: var(--border-strong);
  }
  .hc-arrow:focus-visible {
    outline: none;
    box-shadow: var(--ring);
  }
  .hc-dots {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
  }
  .hc-dot {
    width: var(--sp-3);
    height: var(--sp-3);
    padding: 0;
    border-radius: var(--r-pill);
    background: var(--line);
    border: none;
    cursor: pointer;
    transition:
      background var(--dur-fast) var(--ease-soft),
      transform var(--dur-fast) var(--ease-soft);
  }
  .hc-dot:hover {
    background: var(--muted);
  }
  .hc-dot[aria-current='true'] {
    background: var(--primary);
    transform: scale(1.25);
  }
  .hc-dot:focus-visible {
    outline: none;
    box-shadow: var(--ring);
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (max-width: 640px) {
    .hc-viewport {
      padding: var(--sp-7) var(--sp-5);
    }
  }
</style>

---
// Wordmark — DESIGN_SYSTEM v2 (brand casing D3). Circular teal mark + "Somnary"
// logotype + teal period. Capitalized "Somnary." is the ratified mark (D3).
// Linked → wraps in <a> (focus ring applies); mark is decorative (aria-hidden).
interface Props {
  href?: string;
}
const { href = '/' } = Astro.props;
---

<a class="wordmark" href={href} aria-label="Somnary — home">
  <span class="mark" aria-hidden="true">S</span>
  <span class="logotype">Somnary<span class="dot">.</span></span>
</a>

<style>
  .wordmark {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    text-decoration: none;
  }
  /* filled teal disc with a white cap — prototype .brand-mark */
  .mark {
    display: grid;
    place-items: center;
    width: 27px;
    height: 27px;
    flex: none;
    border-radius: var(--r-pill);
    background: var(--primary);
    color: #ffffff;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 14px;
    line-height: 1;
  }
  .logotype {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 27px;
    letter-spacing: -0.04em;
    color: var(--ink);
    line-height: 1;
  }
  .dot {
    color: var(--primary);
  }
</style>

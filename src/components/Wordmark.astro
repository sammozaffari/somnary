---
// Wordmark — DESIGN_SYSTEM §2.1. Crescent mark + "somnary" logotype + lavender period.
// Linked → wraps in <a> (focus ring applies); mark is decorative (aria-hidden). No hover
// color change. Anatomy dimensions (18/14/-3px, 23px logotype) are literal per §2.1.
interface Props {
  href?: string;
}
const { href = '/' } = Astro.props;
---

<a class="wordmark" href={href} aria-label="somnary — home">
  <span class="mark" aria-hidden="true">
    <span class="mark-ink"></span>
    <span class="mark-cut"></span>
  </span>
  <span class="logotype">somnary<span class="dot">.</span></span>
</a>

<style>
  .wordmark {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    text-decoration: none;
  }
  /* crescent: an --ink disc with a --base disc punched over its top-right corner */
  .mark {
    position: relative;
    width: 18px;
    height: 18px;
    flex: none;
  }
  .mark-ink {
    position: absolute;
    inset: 0;
    background: var(--ink);
    border-radius: var(--r-pill);
  }
  .mark-cut {
    position: absolute;
    top: -3px;
    right: -3px;
    width: 14px;
    height: 14px;
    background: var(--base);
    border-radius: var(--r-pill);
  }
  .logotype {
    font-family: var(--font-display);
    font-size: 23px;
    letter-spacing: -0.01em;
    color: var(--ink);
    line-height: 1;
  }
  .dot {
    color: var(--lavender);
  }
</style>

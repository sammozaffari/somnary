---
// Wordmark — DESIGN_SYSTEM v3. The brand symbol is a crescent moon in a circular oxblood
// disc (D3 amended by owner 2026-07-08). In the nav the moon mark stands ALONE — the
// "Somnary" logotype text was dropped per owner 2026-07-09; the mark is enlarged to carry
// the brand on its own. The accessible name stays "Somnary" via aria-label so the link is
// still announced/read as the brand. Linked → wraps in <a> (focus ring applies).
interface Props {
  href?: string;
}
const { href = '/' } = Astro.props;
---

<a class="wordmark" href={href} aria-label="Somnary — home">
  <span class="mark" aria-hidden="true">
    <svg viewBox="0 0 24 24" fill="currentColor" role="img" aria-hidden="true">
      <path d="M21.752 15.002A9.72 9.72 0 0 1 18 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 0 0 3 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 0 0 9.002-5.998Z"/>
    </svg>
  </span>
</a>

<style>
  .wordmark {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    text-decoration: none;
  }
  /* filled oxblood disc carrying a white crescent moon — the standalone brand mark.
     Enlarged (was 27px) now that it carries the nav on its own. */
  .mark {
    display: grid;
    place-items: center;
    width: 40px;
    height: 40px;
    flex: none;
    border-radius: var(--r-pill);
    background: var(--primary);
    color: #ffffff;
    line-height: 1;
  }
  .mark svg {
    width: 23px;
    height: 23px;
  }
</style>

---
// Global site footer — DESIGN_SYSTEM §3 chrome. Carries the compact site-wide medical
// disclaimer (CHK-1.3 component), the independence line, and links to all four legal pages.
import Disclaimer from './Disclaimer.astro';

const legal = [
  { href: '/methodology', label: 'methodology' },
  { href: '/changelog', label: 'evidence log' },
  { href: '/disclaimer', label: 'disclaimer' },
  { href: '/terms', label: 'terms' },
  { href: '/privacy', label: 'privacy' },
  { href: '/disclosure', label: 'disclosure' },
];
// Educational context pages — not graded remedies. Kept in their own labelled group so they're
// site-wide discoverable (crawlable, no orphans) and never read as part of the graded catalog.
const context = [
  { href: '/when-to-see-a-doctor', label: 'when to see a doctor' },
  { href: '/medications-and-sleep-aids', label: 'medications & sleep aids' },
  { href: '/older-adults', label: 'older adults' },
  { href: '/jet-lag-shift-work', label: 'jet lag & shift work' },
  { href: '/anxiety-and-sleep', label: 'anxiety & sleep' },
  { href: '/melatonin-children', label: 'melatonin in children' },
  { href: '/melatonin-dose-timing', label: 'melatonin dose & timing' },
  { href: '/melatonin-gummies', label: 'melatonin gummies' },
  { href: '/melatonin-long-term', label: 'melatonin, long-term' },
  { href: '/ramelteon', label: 'ramelteon' },
  { href: '/sleep-blends', label: 'sleep blends' },
];
---

<footer class="footer">
  <div class="row">
    <span class="brand">Somnary</span>
    <p class="independence">zero affiliate links · zero brand money · reader-funded.</p>
  </div>
  <div class="disclaimer">
    <Disclaimer variant="compact" />
  </div>
  <nav class="reflinks" aria-label="context">
    <span class="group-label">context · not graded</span>
    <ul class="linkrow">
      {context.map((l) => (
        <li>
          <a href={l.href}>{l.label}</a>
        </li>
      ))}
    </ul>
  </nav>
  <ul class="legal" aria-label="legal">
    {legal.map((l) => (
      <li>
        <a href={l.href}>{l.label}</a>
      </li>
    ))}
  </ul>
</footer>

<style>
  .footer {
    border-top: var(--border-hairline);
    margin-top: var(--sp-10);
    padding: var(--sp-7) var(--sp-7) var(--sp-8);
    color: var(--muted);
  }
  .row {
    display: flex;
    align-items: baseline;
    gap: var(--sp-5);
    flex-wrap: wrap;
  }
  .brand {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--text-lg);
    color: var(--ink);
  }
  .independence {
    margin: 0;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--muted);
  }
  .disclaimer {
    margin: var(--sp-4) 0 0;
    max-width: 70ch;
  }
  .legal {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-4);
    margin: var(--sp-5) 0 0;
    padding: 0;
    list-style: none;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
  }
  .legal a {
    color: var(--muted);
    text-decoration: none;
    transition: color var(--dur-fast) var(--ease-soft);
  }
  .legal a:hover {
    color: var(--ink);
  }
  .reflinks {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: var(--sp-4);
    margin-top: var(--sp-6);
  }
  .group-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--eucalyptus);
  }
  .linkrow {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-4);
    margin: 0;
    padding: 0;
    list-style: none;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
  }
  .linkrow a {
    color: var(--muted);
    text-decoration: none;
    transition: color var(--dur-fast) var(--ease-soft);
  }
  .linkrow a:hover {
    color: var(--ink);
  }
  @media (max-width: 640px) {
    .footer {
      padding: var(--sp-6) var(--sp-5) var(--sp-7);
    }
  }
</style>

---
// Global site footer — DESIGN_SYSTEM §3 chrome. Carries the compact site-wide medical
// disclaimer (CHK-1.3 component), the independence line, and links to all four legal pages.
import Disclaimer from './Disclaimer.astro';

const legal = [
  { href: '/disclaimer', label: 'disclaimer' },
  { href: '/terms', label: 'terms' },
  { href: '/privacy', label: 'privacy' },
  { href: '/disclosure', label: 'disclosure' },
];
---

<footer class="footer">
  <div class="row">
    <span class="brand">somnary<span class="dot">.</span></span>
    <p class="independence">zero affiliate links · zero brand money · reader-funded.</p>
  </div>
  <div class="disclaimer">
    <Disclaimer variant="compact" />
  </div>
  <ul class="legal" aria-label="legal">
    {legal.map((l) => (
      <li>
        <a href={l.href}>{l.label}</a>
      </li>
    ))}
  </ul>
</footer>

<style>
  .footer {
    border-top: var(--border-hairline);
    margin-top: var(--sp-10);
    padding: var(--sp-7) var(--sp-7) var(--sp-8);
    color: var(--ink-faint);
  }
  .row {
    display: flex;
    align-items: baseline;
    gap: var(--sp-5);
    flex-wrap: wrap;
  }
  .brand {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    color: var(--ink);
  }
  .dot {
    color: var(--lavender);
  }
  .independence {
    margin: 0;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--ink-faint);
  }
  .disclaimer {
    margin: var(--sp-4) 0 0;
    max-width: 70ch;
  }
  .legal {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-4);
    margin: var(--sp-5) 0 0;
    padding: 0;
    list-style: none;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
  }
  .legal a {
    color: var(--ink-faint);
    text-decoration: none;
    transition: color var(--dur-fast) var(--ease-soft);
  }
  .legal a:hover {
    color: var(--ink);
  }
  @media (max-width: 640px) {
    .footer {
      padding: var(--sp-6) var(--sp-5) var(--sp-7);
    }
  }
</style>

---
// Global site footer — DESIGN_SYSTEM §3 chrome. Carries the site-wide medical disclaimer and
// the independence line. Legal targets (terms / privacy / disclosure) are created in CHK-1.2;
// until then they render as muted text, not dead links. The full disclaimer component is CHK-1.3.
const legal = ['terms', 'privacy', 'disclosure'];
---

<footer class="footer">
  <div class="row">
    <span class="brand">somnary<span class="dot">.</span></span>
    <p class="independence">zero affiliate links · zero brand money · reader-funded.</p>
  </div>
  <p class="disclaimer">
    educational, not medical advice. talk to a clinician before changing what you take,
    especially if you’re pregnant, on other medications, or managing a health condition.
  </p>
  <ul class="legal" aria-label="legal">
    {/* CHK-1.2 turns these into links to /terms, /privacy, /disclosure. */}
    {legal.map((l) => <li>{l}</li>)}
  </ul>
</footer>

<style>
  .footer {
    border-top: var(--border-hairline);
    margin-top: var(--sp-10);
    padding: var(--sp-7) var(--sp-7) var(--sp-8);
    color: var(--ink-faint);
  }
  .row {
    display: flex;
    align-items: baseline;
    gap: var(--sp-5);
    flex-wrap: wrap;
  }
  .brand {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    color: var(--ink);
  }
  .dot {
    color: var(--lavender);
  }
  .independence {
    margin: 0;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--ink-faint);
  }
  .disclaimer {
    margin: var(--sp-4) 0 0;
    max-width: 60ch;
    font-size: var(--text-sm);
    color: var(--ink-soft);
  }
  .legal {
    display: flex;
    gap: var(--sp-4);
    margin: var(--sp-5) 0 0;
    padding: 0;
    list-style: none;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
  }
  @media (max-width: 640px) {
    .footer {
      padding: var(--sp-6) var(--sp-5) var(--sp-7);
    }
  }
</style>

---
// A prominent, plain-language callout for the things worth knowing before deciding.
// tone: 'safety' = red safety register (liver/B6/pregnancy hazards); 'info' = eucalyptus
// informational register (e.g. glycine's food-vs-medicine + dose context — no health hazard).
interface Props {
  title: string;
  tone?: 'safety' | 'info';
  items: { label: string; body: string }[]; // body may contain <strong>
  foot?: string; // optional closing line (may contain HTML)
}
const { title, tone = 'safety', items, foot } = Astro.props;
const mark = tone === 'safety' ? '⚠' : 'ℹ';
---

<aside class:list={['callout', tone]} aria-labelledby="callout-title">
  <h2 class="callout-title" id="callout-title"><span class="callout-mark" aria-hidden="true">{mark}</span> {title}</h2>
  <dl class="callout-list">
    {items.map((it) => (
      <div class="callout-item">
        <dt>{it.label}</dt>
        <dd set:html={it.body} />
      </div>
    ))}
  </dl>
  {foot && <p class="callout-foot" set:html={foot} />}
</aside>

<style>
  .callout {
    border: var(--border-hairline);
    border-radius: var(--r-lg);
    padding: var(--sp-6) var(--sp-7);
    margin: 0 0 var(--sp-8);
    background: var(--surface);
  }
  .callout.safety {
    border-left: 3px solid var(--safety-ink, var(--vermilion));
  }
  .callout.info {
    border-left: 3px solid var(--eucalyptus, var(--primary));
  }
  .callout-title {
    display: flex;
    align-items: center;
    gap: var(--sp-2);
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--text-lg);
    line-height: var(--lh-lg);
    letter-spacing: var(--tracking-tight);
    margin: 0 0 var(--sp-5);
  }
  .callout.safety .callout-title {
    color: var(--safety-ink, var(--ink));
  }
  .callout.info .callout-title {
    color: var(--ink);
  }
  .callout-mark {
    font-size: var(--text-md);
  }
  .callout-list {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--sp-5);
  }
  .callout-item {
    display: grid;
    grid-template-columns: minmax(88px, 120px) 1fr;
    gap: var(--sp-2) var(--sp-6);
    align-items: baseline;
  }
  .callout-item dt {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--ink);
    margin: 0;
  }
  .callout-item dd {
    margin: 0;
    font-size: var(--text-sm);
    line-height: var(--lh-md);
    color: var(--ink);
  }
  .callout-item dd :global(strong) {
    font-weight: 700;
  }
  .callout-foot {
    font-size: var(--text-xs);
    line-height: var(--lh-sm);
    color: var(--muted);
    margin: var(--sp-5) 0 0;
    padding-top: var(--sp-4);
    border-top: var(--border-hairline);
  }

  @media (max-width: 720px) {
    .callout-item {
      grid-template-columns: 1fr;
      gap: var(--sp-1);
    }
  }
</style>

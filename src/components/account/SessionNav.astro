---
// SessionNav — the tiny signed-in indicator in the primary nav (CHK-6.9c).
//
// NO LOGIN WALL: this adds NO "Sign in" CTA and NO login prompt to the nav. Signed-out (the default,
// and the ONLY state when accounts are unconfigured) it shows NOTHING — the nav is unchanged. Only
// when a real session is present does it reveal a small "Account" link + "Sign out". Sign-in itself
// is offered ONCE, optionally, at the end of the /guide reading map (SaveMap) and on /account — never
// here. So a visitor is never nudged toward an account by the global chrome.
//
// NO LAYOUT SHIFT (SSG shell): the markup ships hidden (`hidden` attribute), so the server-rendered
// nav is identical to before. The client island reveals it only after confirming a session, and only
// when accounts are configured (getBrowserSupabase() non-null). Tokens only.
---

<li class="session" data-session hidden>
  <a class="session-link" href="/account" data-session-account>Account</a>
  <a class="session-link session-signout" href="/auth/signout" data-session-signout>Sign out</a>
</li>

<style>
  .session {
    display: flex;
    align-items: center;
    gap: var(--sp-4);
  }
  .session-link {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    color: var(--muted);
    text-decoration: none;
    transition: color var(--dur-fast) var(--ease-soft);
  }
  .session-link:hover {
    color: var(--ink);
  }
  .session-link:focus-visible {
    outline: none;
    box-shadow: var(--ring);
    border-radius: var(--r-sm);
  }
  .session-signout {
    color: var(--primary);
  }
  @media (prefers-reduced-motion: reduce) {
    .session-link {
      transition: none;
    }
  }
</style>

<script>
  // Reads the browser session. Unconfigured (no PUBLIC_SUPABASE_* keys) → getBrowserSupabase() is null
  // → we remove the placeholder entirely and the nav is exactly as server-rendered. Signed-out → stays
  // hidden (no CTA, no wall). Signed-in → reveal Account + Sign out.
  import { getBrowserSupabase } from '../../lib/auth.ts';

  const el = document.querySelector<HTMLElement>('[data-session]');
  if (el) {
    const supabase = getBrowserSupabase();
    if (!supabase) {
      el.remove();
    } else {
      void supabase.auth.getUser().then(({ data }) => {
        if (data?.user) el.hidden = false;
      });
    }
  }
</script>

---
// Base document layout. Imports the global stylesheet (Tailwind layers + DESIGN_SYSTEM
// tokens) and self-hosts the brand typefaces (DESIGN_SYSTEM v3 §2). Server-rendered
// shell so content is crawlable from day one.
// Typefaces (self-hosted via @fontsource — no CDN): Instrument Sans (variable weight
// axis) for everything. IBM Plex Mono retired 2026-07-09 (owner) — the mono font is gone
// site-wide; --font-mono now aliases Instrument Sans (see global.css).
import '@fontsource-variable/instrument-sans';
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  canonical?: string; // per-page canonical URL (SEO furniture — first used by remedy pages, CHK-2.1)
  ogType?: string; // open-graph type: 'website' (default) or 'article' for remedy pages (CHK-2.2)
  ogImage?: string; // absolute URL to a per-page OG image (remedy pages generate one, CHK-2.2)
}
const { title, description, canonical, ogType = 'website', ogImage } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    {canonical && <link rel="canonical" href={canonical} />}

    {/* Open Graph / Twitter (CHK-2.2). Per-remedy generated og:image is a follow-up. */}
    <meta property="og:site_name" content="Somnary" />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    {canonical && <meta property="og:url" content={canonical} />}
    {
      ogImage && (
        <>
          <meta property="og:image" content={ogImage} />
          <meta property="og:image:width" content="1200" />
          <meta property="og:image:height" content="630" />
        </>
      )
    }
    <meta name="twitter:card" content={ogImage ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}
    {ogImage && <meta name="twitter:image" content={ogImage} />}

    {/* Brand typefaces are self-hosted via @fontsource (imported in the frontmatter,
        bundled by Astro) — DESIGN_SYSTEM v3 §2: Instrument Sans display+body, IBM Plex
        Mono for data. No Google Fonts CDN. */}
  </head>
  <body>
    <Nav />
    <slot />
    <Footer />
  </body>
</html>

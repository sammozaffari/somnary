---
import Base from '../layouts/Base.astro';
import Disclaimer from '../components/Disclaimer.astro';
import TierBadge from '../components/TierBadge.astro';
import HeroCarousel from '../components/HeroCarousel.astro';
import type { SlideSpec } from '../lib/hero-slides';
import { TIERS } from '../lib/tiers';
import { Pill, Package, Timer, AlarmClock, ShieldAlert, Baby } from '@lucide/astro';

// Home — CHK-3.1 (strategy 03 "Homepage Above-The-Fold"; DESIGN_SYSTEM §1/§10).
// Decision-first front door: route by intent, not by molecule. Replaces the v1 "enemy hero".
// Three above-the-fold decision routes (check a remedy → /search · start from your problem →
// #situations · read safety red flags → /safety), then six situation tiles wired
// to REAL routes, the disavowal stat row read from actual data (never hardcoded), and a compact
// "how to read a grade" legend. The --action accent (oxblood) is spent exactly ONCE (the hero primary CTA),
// per the §10 budget. No search island is dropped here (SearchPalette has fixed IDs + a single
// trigger binding); the primary CTA is a plain crawlable anchor to /search plus popular-check
// pills to real remedy routes. No newsletter/forms (CHK-4.2), no commerce, no stack-builder (D4).
// Hero carousel slide order — one array, tweakable. Slide 1 (brand) carries the page H1 and
// the single oxblood CTA; remedy slides interleave with "useful ways to use the site" so the
// panel never reads as just a supplement reel. Remedy slugs are real routes in src/content/remedies/.
const heroSlides: SlideSpec[] = [
  { kind: 'brand' },
  { kind: 'remedy', slug: 'magnesium' },
  { kind: 'remedy', slug: 'valerian' },
  { kind: 'utility', key: 'situations' },
  { kind: 'remedy', slug: 'melatonin' },
  { kind: 'utility', key: 'blend' },
  { kind: 'remedy', slug: 'l-theanine' },
  { kind: 'utility', key: 'grades' },
  { kind: 'remedy', slug: 'ashwagandha' },
];

// Six situation tiles — labels verbatim from strategy 03, each wired to a route that resolves.
// Medications tile → /safety (the safety router; the dedicated meds page is CHK-5.2; no dead link).
const situations = [
  {
    href: '/r/melatonin',
    Icon: Pill,
    title: "I'm considering melatonin, or already take it",
    dek: 'The flagship decision hub: clock signal vs sedative, dose reality, the label-accuracy problem.',
  },
  {
    href: '/sleep-blends',
    Icon: Package,
    title: 'I bought a sleep blend',
    dek: 'Decode the label before you trust it — proprietary blends, missing doses, studied-dose mismatch.',
  },
  {
    href: '/outcome/fall-asleep-faster',
    Icon: Timer,
    title: 'I want to fall asleep faster',
    dek: 'Remedies with human evidence aimed at sleep-onset latency, ranked by the strength of that evidence.',
  },
  {
    href: '/outcome/stay-asleep',
    Icon: AlarmClock,
    title: 'I keep waking up at night',
    dek: 'The shorter list of remedies studied for staying asleep — wake after sleep onset, not just falling asleep.',
  },
  {
    href: '/safety',
    Icon: ShieldAlert,
    title: 'I take medications or have a health condition',
    dek: 'Using medications? Start with the safety boundary — interactions and red flags come before any remedy.',
  },
  {
    href: '/melatonin-children',
    Icon: Baby,
    title: "I'm considering this for a child",
    dek: 'The most cautious page on the site: what the evidence does and does not support for kids.',
  },
];
---

<Base
  title="Somnary: check a sleep remedy before you take it"
  description="Every natural sleep supplement, graded S–F on real human studies — not the hype on the label. Every claim cited. No affiliate links, no brand money."
  canonical="https://somnary.vercel.app/"
>
  <main class="home">
    <!-- hero — one full-width panel that morphs between slides (brand → remedies ⇄ utility) -->
    <HeroCarousel slides={heroSlides} />

    <!-- disclaimer — adjacent to the decision block, not footer-only -->
    <Disclaimer />

    <!-- situation route tiles — route by intent -->
    <section class="section" id="situations">
      <p class="section-eyebrow">What are you trying to decide?</p>
      <div class="tiles">
        {
          situations.map((t) => (
            <a class="tile" href={t.href}>
              <span class="tile-icon">
                <t.Icon size={30} strokeWidth={1.75} aria-hidden="true" />
              </span>
              <p class="tile-title">{t.title}</p>
              <p class="tile-dek">{t.dek}</p>
            </a>
          ))
        }
      </div>
    </section>

    <!-- how to read a grade — S–F legend, legible without color alone -->
    <section class="section" id="how-to-read">
      <p class="section-eyebrow">How to read a grade</p>
      <ul class="legend">
        {
          TIERS.map((t) => (
            <li class="legend-item">
              <TierBadge tier={t.id} size="card" />
              <span class="legend-name">
                <span class="legend-letter">{t.id}</span> {t.name}
              </span>
            </li>
          ))
        }
      </ul>
      <p class="legend-note">
        A grade rates how strong the human evidence is — not whether a remedy is safe for you.
        Safety lives on each remedy's page and the <a href="/when-to-see-a-doctor">safety boundary</a>.
        <a href="/methodology">See the full S–F rubric →</a>
      </p>
    </section>
  </main>

  {/* Hero carousel controller: crossfade slides, dots + arrows, auto-advance. No JS → slide 1
      shows and every other slide is real crawlable HTML with its own links. */}
  <script>
    const root = document.querySelector<HTMLElement>('[data-hero-carousel]');
    if (root) {
      const stack = root.querySelector<HTMLElement>('.hc-stack');
      const slidesEls = Array.from(root.querySelectorAll<HTMLElement>('[data-slide]'));
      const controls = root.querySelector<HTMLElement>('[data-hc-controls]');
      const dots = Array.from(root.querySelectorAll<HTMLButtonElement>('[data-hc-dot]'));
      const prev = root.querySelector<HTMLButtonElement>('[data-hc-prev]');
      const next = root.querySelector<HTMLButtonElement>('[data-hc-next]');
      const live = root.querySelector<HTMLElement>('[data-hc-live]');
      const count = slidesEls.length;
      // Intro showcase: reveal this many slides once, then settle back on the start slide and
      // rest. Not an infinite loop — a brief, self-ending morph. Manual controls still reach
      // every slide afterward.
      const AUTOPLAY_SLIDES = Math.min(4, count);
      const INTERVAL = 6000;
      let current = 0;

      function label(i: number): string {
        return dots[i]?.getAttribute('aria-label')?.replace(/^Show\s+/, '') ?? `Slide ${i + 1}`;
      }

      function show(i: number) {
        current = (i + count) % count;
        slidesEls.forEach((s, idx) => s.classList.toggle('is-active', idx === current));
        dots.forEach((d, idx) => {
          if (idx === current) d.setAttribute('aria-current', 'true');
          else d.removeAttribute('aria-current');
        });
        if (live) live.textContent = `${label(current)} — slide ${current + 1} of ${count}`;
      }

      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      let timer: ReturnType<typeof setInterval> | null = null;
      function stopAutoplay() {
        if (timer) {
          clearInterval(timer);
          timer = null;
        }
      }
      function autoplay() {
        if (reduce || timer || count < 2) return;
        let revealed = 1; // the start slide is already on screen
        timer = setInterval(() => {
          if (revealed < AUTOPLAY_SLIDES) {
            show(current + 1); // reveal the next slide (indices 1 … AUTOPLAY_SLIDES-1)
            revealed += 1;
          } else {
            show(0); // settle back on the start slide …
            stopAutoplay(); // … and rest there
          }
        }, INTERVAL);
      }

      // Manual controls drive freely and cancel the intro (they don't restart it).
      dots.forEach((d, idx) =>
        d.addEventListener('click', () => {
          stopAutoplay();
          show(idx);
        }),
      );
      prev?.addEventListener('click', () => {
        stopAutoplay();
        show(current - 1);
      });
      next?.addEventListener('click', () => {
        stopAutoplay();
        show(current + 1);
      });

      // If a keyboard/AT user tabs into the panel mid-intro, stop so a focused link isn't
      // yanked away. Reduced motion skips the intro entirely (guard in autoplay()).
      root.addEventListener('focusin', stopAutoplay);

      // upgrade from the no-JS single-slide fallback to the crossfade stack
      if (count > 1) {
        stack?.classList.add('is-live');
        slidesEls.forEach((s) => {
          s.hidden = false;
        });
        controls?.removeAttribute('hidden');
        show(0);
        autoplay();
      }
    }
  </script>
</Base>

<style>
  .home {
    max-width: var(--page);
    margin: 0 auto;
    padding: var(--sp-8) var(--sp-7) var(--sp-8);
  }
  .section-eyebrow {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    color: var(--muted);
    margin: 0;
  }

  /* sections */
  .section {
    margin-top: var(--sp-9);
    scroll-margin-top: var(--sp-8);
  }
  .section-eyebrow {
    margin-bottom: var(--sp-5);
  }

  /* situation tiles — 2×3 route cards */
  .tiles {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--sp-4);
  }
  .tile {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
    background: var(--surface);
    border: var(--border-hairline);
    border-radius: var(--r-lg);
    padding: var(--sp-6);
    text-decoration: none;
    color: var(--ink);
    transition:
      box-shadow var(--dur-base) var(--ease-settle),
      transform var(--dur-base) var(--ease-settle);
  }
  .tile:hover {
    box-shadow: var(--shadow-lift);
    transform: translateY(-2px);
  }
  .tile:focus-visible {
    outline: none;
    box-shadow: var(--ring);
  }
  /* bare oxblood affordance mark — no chip; the headline leads (brand accent, not --action) */
  .tile-icon {
    display: inline-flex;
    margin-bottom: var(--sp-3);
    color: var(--primary);
  }
  .tile-title {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    line-height: var(--lh-xl);
    letter-spacing: var(--tracking-tight);
    color: var(--ink);
    margin: 0;
  }
  .tile-dek {
    font-size: var(--text-sm);
    line-height: var(--lh-sm);
    color: var(--muted);
    margin: 0;
  }

  /* how to read a grade — one horizontal strip of six badges (was six stacked rows) */
  .legend {
    list-style: none;
    margin: 0;
    padding: var(--sp-5);
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: var(--sp-4);
    background: var(--surface);
    border: var(--border-hairline);
    border-radius: var(--r-lg);
  }
  .legend-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--sp-2);
    text-align: center;
  }
  /* letter + tier name — legible without color alone (the badge glyph is the letter, echoed here) */
  .legend-name {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    color: var(--muted);
  }
  .legend-letter {
    font-weight: 700;
    color: var(--ink);
  }
  .legend-note {
    font-size: var(--text-sm);
    line-height: var(--lh-sm);
    color: var(--muted);
    margin: var(--sp-5) 0 0;
    max-width: 70ch;
  }
  .legend-note a {
    color: var(--primary);
  }

  @media (max-width: 760px) {
    .tiles {
      grid-template-columns: 1fr;
    }
    /* six badges wrap to two rows of three on narrow viewports */
    .legend {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  @media (max-width: 640px) {
    .home {
      padding: var(--sp-7) var(--sp-5) var(--sp-7);
    }
  }
</style>

---
import Base from '../layouts/Base.astro';
import TokenProbe from '../components/TokenProbe.astro';
import Disclaimer from '../components/Disclaimer.astro';
import { contentIndex, plannedCount, liveRemedyCount, countByKind } from '../lib/content-index';

// Placeholder home (CHK-0.2, restyled with tokens in CHK-0.3). "Graded" counts read the
// content index at build time (CHK-0.6) — both figures derive from live entries, never hardcoded,
// so the tagline can't overstate. The tagline follows the locked pattern from CLAUDE.md.
// Rendered as static HTML so the text is in the page source, not injected by JS.
const remediesGraded = liveRemedyCount;
const sourcesCited = contentIndex
  .filter((e) => e.researchStatus === 'live')
  .reduce((n, e) => n + e.sourceCount, 0);
const tagline = `somnary · ${remediesGraded} remedies graded, ${sourcesCited} sources cited · zero brand money`;
const plannedLine = `${plannedCount} entries planned — ${countByKind('remedy')} remedies, ${countByKind('intervention')} interventions, ${countByKind('context')} context.`;
---

<Base
  title="somnary — evidence-graded sleep & natural-remedies wiki"
  description="An independent, evidence-graded sleep & natural-remedies wiki. Every remedy graded S–F by the strength of published human evidence, every claim cited, zero brand money."
>
  <main class="max-w-3xl mx-auto px-6 py-10 font-body text-ink">
    <p class="font-display text-lg">somnary<span class="text-lavender">.</span></p>

    <h1 class="font-display text-3xl mt-6">the sleep reference is being built.</h1>

    <p class="font-mono text-xs text-ink-faint mt-4">{tagline}</p>

    <p class="font-mono text-xs text-ink-faint mt-2">{plannedLine}</p>

    <p class="text-md text-ink-soft mt-5">
      independent · evidence-graded · reader-funded. zero affiliate links, zero
      brand sponsorship, zero hallucinated citations.
    </p>

    <div class="mt-8">
      <TokenProbe />
    </div>

    <div class="mt-8">
      <Disclaimer variant="standard" />
    </div>
  </main>
</Base>

---
import Base from '../layouts/Base.astro';
import StatRow from '../components/StatRow.astro';
import { contentIndex, liveRemedyCount } from '../lib/content-index';
import { OUTCOMES } from '../lib/outcomes';

// Home — CHK-5.3 (PLAN §1 positioning, DESIGN_SYSTEM §3.1). The hook + the disavowals, made real.
// The "enemy" strike-through (PLAN §1.1) + the disavowal stat row read from actual data (never
// hardcoded), so the numbers can't overstate. Newsletter band deferred to Phase 7 (CHK-7.1) — no
// non-functional signup (real-promises rule).
const remediesGraded = liveRemedyCount;
const sourcesCited = contentIndex
  .filter((e) => e.researchStatus === 'live')
  .reduce((n, e) => n + e.sourceCount, 0);

const statCells = [
  { value: String(remediesGraded), label: 'remedies graded' },
  { value: String(sourcesCited), label: 'sources cited' },
  { value: '0', label: 'hallucinated cites', accent: 'sage' as const },
  { value: '$0', label: 'brand money', accent: 'lavender' as const },
];

const ways = [
  { href: '/tiers', title: 'the tier board', dek: 'every remedy ranked S–F by the evidence. the leaderboard, and the hook.' },
  { href: '#by-outcome', title: 'by outcome', dek: 'start from your goal: fall asleep faster, stay asleep, jet lag, an anxious mind.' },
  { href: '/methodology', title: 'the methodology', dek: 'the full S–F rubric and evidence gates, specific enough to re-derive any grade.' },
  { href: '/search', title: 'search', dek: 'find any remedy by name, alias, latin name, compound, or symptom.' },
];

const featured = ['fall-asleep-faster', 'anxiety-driven-insomnia', 'jet-lag-shift-work'];
const outcomePreview = featured
  .map((id) => OUTCOMES.find((o) => o.id === id)!)
  .map((o) => ({ ...o, count: o.remedies.length }));
---

<Base
  title="somnary: every natural sleep remedy, graded by the evidence"
  description="an independent, evidence-graded sleep & natural-remedies wiki. every remedy graded S–F by the strength of published human evidence, every claim cited, weak evidence labelled weak, zero brand money."
  canonical="https://somnary.vercel.app/"
>
  <main class="home">
    <!-- hero -->
    <section class="hero">
      <p class="eyebrow">independent · evidence-graded · reader-funded</p>
      <h1 class="headline">
        the sleep-supplement internet is a <span class="strike">sales floor</span>. this is the
        <span class="mark">evidence layer</span><span class="dot">.</span>
      </h1>
      <p class="dek">
        every natural sleep remedy, graded S to F by the strength of the published human evidence.
        every claim footnoted to a real study, weak evidence labelled weak and shown, and zero brand
        money: no affiliate links, no supplement company pays us. we grade what the research shows,
        not what sells.
      </p>
      <div class="cta-row">
        <a class="cta cta-primary" href="/tiers">see the tier board →</a>
        <a class="cta cta-secondary" href="/methodology">how we grade</a>
      </div>
    </section>

    <StatRow cells={statCells} />

    <!-- four ways to read -->
    <section class="section">
      <p class="section-eyebrow">four ways to read</p>
      <div class="ways">
        {
          ways.map((w) => (
            <a class="way" href={w.href}>
              <p class="way-title">{w.title}<span class="dot">.</span></p>
              <p class="way-dek">{w.dek}</p>
            </a>
          ))
        }
      </div>
    </section>

    <!-- outcome preview -->
    <section class="section" id="by-outcome">
      <p class="section-eyebrow">start from your goal</p>
      <div class="outcomes">
        {
          outcomePreview.map((o) => (
            <a class="outcome" href={`/outcome/${o.id}`}>
              <p class="outcome-meta">outcome · {o.count} remedies</p>
              <p class="outcome-title">{o.title}<span class="dot">.</span></p>
              <p class="outcome-dek">{o.dek}</p>
            </a>
          ))
        }
      </div>
      <p class="all-outcomes">
        seven goals in all. <a href="/outcome/sleep-quality">browse every outcome →</a>
      </p>
    </section>
  </main>
</Base>

<style>
  .home {
    max-width: 1240px;
    margin: 0 auto;
    padding: var(--sp-9) var(--sp-7) var(--sp-9);
  }
  .dot {
    color: var(--lavender);
  }
  .eyebrow,
  .section-eyebrow {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--ink-faint);
    margin: 0;
  }

  /* hero */
  .hero {
    margin-bottom: var(--sp-8);
  }
  .headline {
    font-family: var(--font-display);
    font-size: var(--text-display);
    line-height: var(--lh-display);
    letter-spacing: var(--tracking-tight);
    color: var(--ink);
    margin: var(--sp-4) 0 var(--sp-5);
    max-width: 20ch;
  }
  .strike {
    text-decoration: line-through;
    text-decoration-color: var(--tier-d);
    text-decoration-thickness: 3px;
    color: var(--ink-faint);
  }
  .mark {
    background: var(--lavender-tint);
    border-radius: var(--r-sm);
    padding: 0 0.08em;
  }
  .dek {
    font-size: var(--text-md);
    line-height: var(--lh-md);
    color: var(--ink-soft);
    max-width: 62ch;
    margin: 0 0 var(--sp-6);
  }
  .cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-3);
  }
  .cta {
    display: inline-flex;
    align-items: center;
    min-height: 48px;
    padding: 0 var(--sp-5);
    border-radius: var(--r-pill);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    text-decoration: none;
    transition: transform var(--dur-fast) var(--ease-soft);
  }
  .cta:hover {
    transform: translateX(2px);
  }
  .cta:focus-visible {
    outline: none;
    box-shadow: var(--ring);
  }
  .cta-primary {
    background: var(--ink);
    color: var(--surface);
  }
  .cta-secondary {
    background: var(--surface);
    color: var(--ink);
    border: var(--border-strong);
  }

  /* sections */
  .section {
    margin-top: var(--sp-9);
  }
  .section-eyebrow {
    margin-bottom: var(--sp-5);
  }

  /* four ways to read — 2×2 */
  .ways {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--sp-4);
  }
  .way {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
    background: var(--surface);
    border: var(--border-hairline);
    border-radius: var(--r-lg);
    padding: var(--sp-6);
    text-decoration: none;
    color: var(--ink);
    transition:
      box-shadow var(--dur-base) var(--ease-settle),
      transform var(--dur-base) var(--ease-settle);
  }
  .way:hover {
    box-shadow: var(--shadow-lift);
    transform: translateY(-3px);
  }
  .way:focus-visible {
    outline: none;
    box-shadow: var(--ring);
  }
  .way-title {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    line-height: var(--lh-xl);
    color: var(--ink);
    margin: 0;
  }
  .way-dek {
    font-size: var(--text-sm);
    line-height: var(--lh-sm);
    color: var(--ink-soft);
    margin: 0;
  }

  /* outcome preview — 3 col */
  .outcomes {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--sp-4);
  }
  .outcome {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
    background: var(--lavender-tint);
    border-radius: var(--r-lg);
    padding: var(--sp-6);
    text-decoration: none;
    color: var(--ink);
    transition:
      box-shadow var(--dur-base) var(--ease-settle),
      transform var(--dur-base) var(--ease-settle);
  }
  .outcome:hover {
    box-shadow: var(--shadow-lift);
    transform: translateY(-3px);
  }
  .outcome:focus-visible {
    outline: none;
    box-shadow: var(--ring);
  }
  .outcome-meta {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--lavender-ink);
    margin: 0;
  }
  .outcome-title {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    line-height: var(--lh-xl);
    color: var(--ink);
    margin: 0;
  }
  .outcome-dek {
    font-size: var(--text-sm);
    line-height: var(--lh-sm);
    color: var(--ink-soft);
    margin: 0;
  }
  .all-outcomes {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--ink-faint);
    margin: var(--sp-5) 0 0;
  }
  .all-outcomes a {
    color: var(--lavender-ink);
  }

  @media (max-width: 760px) {
    .ways,
    .outcomes {
      grid-template-columns: 1fr;
    }
  }
  @media (max-width: 640px) {
    .home {
      padding: var(--sp-7) var(--sp-5) var(--sp-8);
    }
    .headline {
      font-size: 48px;
    }
  }
</style>

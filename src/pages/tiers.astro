---
// Remedies overview / tier board — CHK-3.4 (strategy 03: Remedies is a nav-peer REFERENCE
// OVERVIEW, not the site hero). Ranks every graded remedy S→F, reading the structured grades
// from the content collection (single source of truth — no hand-kept list, no re-derived grade).
// Server-rendered/static and crawlable: the flat, grade→name ordered grid below IS the canonical
// content. The empty S tier surfaces its "nothing qualifies" note (from tiers.ts) so the
// intentional-empty credibility signal survives. Sort control is progressive enhancement only —
// with JS off, the server order (grade→name) stands as the content.
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import TierBadge from '../components/TierBadge.astro';
import RemedyCard from '../components/RemedyCard.astro';
import Disclaimer from '../components/Disclaimer.astro';
import { TIERS, type TierId } from '../lib/tiers';
import { contentIndex } from '../lib/content-index';

interface Card {
  slug: string;
  name: string;
  tier: TierId;
  oneLiner: string;
  keyCompound: string | null;
  category: string;
}

// Category is a nav/sort facet that lives in the content-index store (already imported here);
// the remedy content schema carries no `category` field, so we read it by slug rather than add
// a schema field (a schema change is a [HUMAN-GATE]). No content is duplicated — this reads the
// one existing registry.
const categoryOf = new Map(contentIndex.map((e) => [e.slug, e.category]));

const remedies = await getCollection('remedies', (e) => !e.data.draft);
const byTier = new Map<TierId, Card[]>(TIERS.map((t) => [t.id, []]));
for (const e of remedies) {
  byTier.get(e.data.tier)!.push({
    slug: e.id,
    name: e.data.name,
    tier: e.data.tier,
    oneLiner: e.data.oneLineVerdict,
    keyCompound: e.data.keyCompound,
    category: categoryOf.get(e.id) ?? '',
  });
}
// Within each tier, name A–Z. Rank = position in the S→F TIERS order.
for (const arr of byTier.values()) arr.sort((a, b) => a.name.localeCompare(b.name));
const rankOf = new Map<TierId, number>(TIERS.map((t, i) => [t.id, i]));
// Canonical server order: grade(S→F) then name(A–Z). This flat list is the crawlable content.
const ordered = TIERS.flatMap((t) => byTier.get(t.id)!);

const sortModes = [
  { key: 'grade', label: 'Grade' },
  { key: 'name', label: 'A–Z' },
  { key: 'category', label: 'Category' },
] as const;
---

<Base
  title="Every remedy we've reviewed, graded S–F | Somnary"
  description="The full reference index of natural sleep remedies, each graded S to F by the strength of the published human evidence. Sort by grade, alphabetically, or by category. Weak evidence labelled weak, shown not hidden. Zero brand money."
  canonical="https://somnary.vercel.app/tiers"
>
  <main class="page">
    <header class="head">
      <p class="eyebrow">Remedies · Reference overview</p>
      <h1 class="title">Every remedy we've reviewed</h1>
      <p class="dek">
        The full index, graded S–F by one thing only: the strength of the published human evidence
        behind each remedy — not popularity, not tradition, not the marketing. Weak evidence is
        labelled weak and shown, never buried. Sort it however helps.
      </p>
      <Disclaimer variant="compact" />
    </header>

    <!-- overview legend: what each tier means + how many remedies sit in it -->
    <div class="legend" aria-label="The tiers, and how many remedies sit in each">
      {
        TIERS.map((t) => {
          const count = byTier.get(t.id)!.length;
          const empty = count === 0;
          return (
            <div class:list={['legend-item', { wide: empty && !!t.emptyNote }]}>
              <TierBadge tier={t.id} size="inline" />
              <span class="legend-name">{t.name}</span>
              <span class="legend-count">{count}</span>
              {empty && t.emptyNote && <span class="legend-note">{t.emptyNote}</span>}
            </div>
          );
        })
      }
    </div>

    <!-- sort control — progressive enhancement; server order (grade→name) is the default -->
    <div class="controls">
      <span id="sort-label" class="controls-label">Sort</span>
      <div class="segmented" role="group" aria-labelledby="sort-label">
        {
          sortModes.map((m) => (
            <button
              type="button"
              class="seg"
              data-sort={m.key}
              aria-pressed={m.key === 'grade' ? 'true' : 'false'}
            >
              {m.label}
            </button>
          ))
        }
      </div>
      <!-- CHK-3.4 deferred faceting now lives in the compare tool (CHK-6.1): filter by goal/category. -->
      <a class="compare-link" href="/compare">Compare remedies side by side →</a>
    </div>

    <!-- canonical flat grid: ALL remedies, grade(S→F)→name(A–Z). This is the crawlable content. -->
    <ul id="remedy-grid" class="grid">
      {
        ordered.map((c) => (
          <li
            class="cell"
            data-rank={rankOf.get(c.tier)}
            data-name={c.name.toLowerCase()}
            data-category={c.category}
          >
            <RemedyCard
              slug={c.slug}
              name={c.name}
              tier={c.tier}
              oneLiner={c.oneLiner}
              keyCompound={c.keyCompound}
            />
          </li>
        ))
      }
    </ul>
  </main>
</Base>

<script>
  // Sort island (CHK-3.4) — reorders the existing, server-rendered <li> nodes IN PLACE. It never
  // creates content: with JS off, the server order (grade→name) stands. Stateless; default 'grade'
  // simply restores the canonical order. No reorder animation, so prefers-reduced-motion is honored
  // by construction (nothing moves with a transition).
  const grid = document.getElementById('remedy-grid');
  const buttons = Array.from(document.querySelectorAll<HTMLButtonElement>('.seg'));
  if (grid && buttons.length) {
    const items = Array.from(grid.querySelectorAll<HTMLLIElement>('li.cell'));
    const num = (el: HTMLLIElement, k: string) => Number(el.dataset[k] ?? 0);
    const str = (el: HTMLLIElement, k: string) => el.dataset[k] ?? '';
    const comparators: Record<string, (a: HTMLLIElement, b: HTMLLIElement) => number> = {
      grade: (a, b) => num(a, 'rank') - num(b, 'rank') || str(a, 'name').localeCompare(str(b, 'name')),
      name: (a, b) => str(a, 'name').localeCompare(str(b, 'name')),
      category: (a, b) =>
        str(a, 'category').localeCompare(str(b, 'category')) || str(a, 'name').localeCompare(str(b, 'name')),
    };
    const apply = (key: string) => {
      const cmp = comparators[key];
      if (!cmp) return;
      const sorted = [...items].sort(cmp);
      grid.append(...sorted); // append() moves existing nodes — no re-render, no content change
      for (const b of buttons) b.setAttribute('aria-pressed', String(b.dataset.sort === key));
    };
    for (const b of buttons) b.addEventListener('click', () => apply(b.dataset.sort ?? 'grade'));
  }
</script>

<style>
  .page {
    max-width: 1240px;
    margin: 0 auto;
    padding: var(--sp-8) var(--sp-7) var(--sp-9);
  }
  .eyebrow {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    color: var(--muted);
    margin: 0;
  }
  .dot {
    color: var(--primary);
  }
  .head {
    margin-bottom: var(--sp-6);
  }
  .title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--text-3xl);
    line-height: var(--lh-3xl);
    letter-spacing: var(--tracking-tight);
    color: var(--ink);
    margin: var(--sp-3) 0 var(--sp-4);
  }
  .dek {
    font-size: var(--text-md);
    line-height: var(--lh-md);
    color: var(--muted);
    max-width: 70ch;
    margin: 0;
  }

  /* overview legend */
  .legend {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-3) var(--sp-5);
    align-items: center;
    margin: var(--sp-6) 0;
    padding: var(--sp-4) var(--sp-5);
    background: var(--surface);
    border: var(--border-hairline);
    border-radius: var(--r-lg);
  }
  .legend-item {
    display: flex;
    align-items: center;
    gap: var(--sp-2);
  }
  .legend-item.wide {
    flex-basis: 100%;
    flex-wrap: wrap;
  }
  .legend-name {
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    color: var(--ink);
  }
  .legend-count {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    color: var(--muted);
  }
  .legend-note {
    font-size: var(--text-sm);
    line-height: var(--lh-sm);
    color: var(--muted);
    max-width: 68ch;
  }

  /* sort control */
  .controls {
    display: flex;
    align-items: center;
    gap: var(--sp-4);
    margin-bottom: var(--sp-6);
    flex-wrap: wrap;
  }
  .compare-link {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    color: var(--primary);
    text-decoration: none;
    margin-left: auto;
    transition: color var(--dur-fast) var(--ease-soft);
  }
  .compare-link:hover {
    color: var(--primary-deep);
  }
  .compare-link:focus-visible {
    outline: none;
    box-shadow: var(--focus-ring);
    border-radius: var(--r-xs);
  }
  .controls-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    color: var(--muted);
  }
  .segmented {
    display: inline-flex;
    gap: var(--sp-1);
    padding: var(--sp-1);
    background: var(--surface);
    border: var(--border-hairline);
    border-radius: var(--r-pill);
  }
  .seg {
    font-family: var(--font-display);
    font-size: var(--text-xs);
    font-weight: 800;
    letter-spacing: var(--tracking-label);
    color: var(--muted);
    background: transparent;
    border: none;
    border-radius: var(--r-pill);
    padding: var(--sp-2) var(--sp-4);
    cursor: pointer;
    transition:
      color var(--dur-fast) var(--ease-soft),
      background var(--dur-fast) var(--ease-soft);
  }
  .seg:hover {
    color: var(--ink);
  }
  .seg[aria-pressed='true'] {
    color: var(--surface);
    background: var(--primary);
  }
  .seg:focus-visible {
    outline: none;
    box-shadow: var(--focus-ring);
  }

  /* canonical flat grid */
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--sp-5);
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .cell {
    display: flex;
  }
  .cell > :global(.card) {
    width: 100%;
  }

  @media (max-width: 640px) {
    .page {
      padding: var(--sp-6) var(--sp-5) var(--sp-8);
    }
    .title {
      font-weight: 700;
      font-size: var(--text-2xl);
    }
  }
</style>

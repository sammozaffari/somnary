---
// Remedy page template — CHK-2.1 (DESIGN_SYSTEM §2.5 / §3.2, PLAN §4). ONE dynamic route renders
// every remedy from its structured frontmatter; melatonin is the first content file and Phase 3's
// 25–30 pages inherit this exact template. Static / pre-rendered (crawlability non-negotiable):
// getStaticPaths enumerates non-draft remedies, and render() turns the MDX body into the
// evidence-summary block. The 12 PLAN §4 blocks are assembled below, each from a reusable component.
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import type { GateVariant } from '../../lib/evidence-gates';
import RemedyHero from '../../components/RemedyHero.astro';
import RemedyCoda from '../../components/RemedyCoda.astro';
import RemedyLeadBlock from '../../components/RemedyLeadBlock.astro';
import VerdictBand from '../../components/VerdictBand.astro';
import ClaimsDataTable from '../../components/ClaimsDataTable.astro';
import DosingGrid from '../../components/DosingGrid.astro';
import SafetyCallout from '../../components/SafetyCallout.astro';
import MetadataCard from '../../components/MetadataCard.astro';
import CommunityBar from '../../components/CommunityBar.astro';
import AskPanel from '../../components/AskPanel.astro';
import SourcesList from '../../components/SourcesList.astro';
import CitationPopover from '../../components/CitationPopover.astro';
import Disclaimer from '../../components/Disclaimer.astro';
import { remedyJsonLd } from '../../lib/seo';

export async function getStaticPaths() {
  const remedies = await getCollection('remedies', (e) => !e.data.draft);
  return remedies.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const d = entry.data;
const { Content } = await render(entry);

const isIntervention = d.format === 'intervention';
const studiedDose = d.doses.length ? d.doses[0].studiedDose : null;
const safetyFlag: { label: string; variant: GateVariant } = {
  label: d.safety.severity === 'serious' ? 'Serious — see safety' : 'Caution — see safety',
  variant: 'caution',
};

// SEO furniture (CHK-2.2): canonical + schema.org JSON-LD (MedicalWebPage + FAQ from the claims).
const site = Astro.site?.href?.replace(/\/$/, '') ?? 'https://somnary.vercel.app';
const canonical = d.seo.canonical ?? `${site}/r/${entry.id}`;
const jsonLd = remedyJsonLd(d, canonical, site);
---

<Base
  title={`${d.seo.questionTitle} — Somnary`}
  description={d.oneLineVerdict}
  canonical={canonical}
  ogType="article"
  ogImage={`${site}/r/${entry.id}/og.png`}
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
  {/* 1 — hero plate + label row (h1 + grade stamp), full-bleed above the content column
      (DESIGN_SYSTEM §11.3 "labeled plate"; crumb retired — navigation stays in the nav) */}
  <RemedyHero slug={entry.id} name={d.name} tier={d.tier} />
  <main class="remedy">
    <header class="head">
      <p class="dek">{d.oneLineVerdict}</p>
    </header>

    {/* 1b — decision-first lead block: grade + decision translation + best-for / not-for /
        biggest-risk / studied-dose (CHK-2.1, strategy doc 03) */}
    <RemedyLeadBlock
      tier={d.tier}
      format={d.format}
      bestFor={d.bestFor}
      notFor={d.notFor}
      biggestRisk={d.biggestRisk}
      studiedDose={studiedDose}
      reviewDate={d.reviewDate}
    />

    {/* 2 — verdict band */}
    <VerdictBand verdict={d.verdict} gates={d.evidenceGates} tier={d.tier} />

    <div class="body">
      <div class="main">
        {/* 3 — claims vs data */}
        <section class="block">
          <p class="eyebrow">Claims vs. data</p>
          <h2 class="block-title">What's claimed, what's shown</h2>
          <ClaimsDataTable claims={d.claims} />
        </section>

        {/* 4 — evidence summary (MDX body) */}
        <section class="block">
          <p class="eyebrow">Evidence summary</p>
          <h2 class="block-title">What the trials actually found</h2>
          <div class="prose"><Content /></div>
        </section>

        {/* 5 — dosing reality (supplements only; interventions have no dose) */}
        {d.doses.length > 0 && (
          <section class="block">
            <p class="eyebrow">Dosing reality</p>
            <h2 class="block-title">The studied dose vs. the shelf</h2>
            <DosingGrid doses={d.doses} />
          </section>
        )}

        {/* 6 — safety & interactions (prominent) */}
        <section class="block">
          <SafetyCallout
            severity={d.safety.severity}
            lead={d.safety.lead}
            risks={d.safety.risks}
            pregnancy={d.safety.pregnancy}
            interactions={d.safety.interactions}
            interactionsSources={d.safety.interactionsSources}
          />
        </section>

        {/* 7 — standardization note (reframed as fidelity for interventions) */}
        <section class="block">
          <p class="eyebrow">{isIntervention ? 'The real version' : 'Standardization'}</p>
          <h2 class="block-title">{isIntervention ? 'What counts as the real thing' : 'What to look for on a label'}</h2>
          <p class="prose-p">{d.standardization}</p>
        </section>

        {/* 8 — mechanism */}
        <section class="block">
          <p class="eyebrow">Mechanism</p>
          <h2 class="block-title">How it's thought to work</h2>
          <p class="prose-p">{d.mechanism}</p>
        </section>

        {/* 9 — sources */}
        <section class="block">
          <p class="eyebrow">Sources</p>
          <h2 class="block-title">Every claim, footnoted</h2>
          <SourcesList sources={d.sources} />
        </section>
      </div>

      {/* sidebar: 10 community (walled off) · metadata · 11 ask stub */}
      <div class="sidebar">
        <MetadataCard
          tier={d.tier}
          format={d.format}
          keyCompound={d.keyCompound}
          studiedDose={studiedDose}
          bestFor={d.bestFor}
          safetyFlag={safetyFlag}
        />
        <CommunityBar reportsCount={d.community.reportsCount} />
        <AskPanel remedyName={d.name} slug={entry.id} />
      </div>
    </div>

    {/* site-wide medical disclaimer on every remedy page (CHK-1.3 → CHK-2.1) */}
    <div class="disclaimer-slot">
      <Disclaimer variant="standard" />
    </div>
  </main>

  {/* coda plate — the hero's world settled toward sleep; the page leaves through it (§11.3) */}
  <RemedyCoda slug={entry.id} />

  {/* 9/12 — single shared citation popover for every .cite-sup on the page */}
  <CitationPopover sources={d.sources} />
</Base>

<style>
  /* content column starts right under the hero label row (§11.3) — the label owns the top */
  .remedy {
    max-width: 1180px;
    margin: 0 auto;
    padding: var(--sp-5) var(--sp-7) var(--sp-9);
  }

  .eyebrow {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    color: var(--muted);
    margin: 0;
  }
  .dot {
    color: var(--primary);
  }

  /* header: the one-line verdict, promoted — it reads as the plate's caption */
  .head {
    margin-bottom: var(--sp-6);
  }
  .dek {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    line-height: var(--lh-lg);
    color: var(--ink);
    max-width: 56ch;
    margin: 0;
  }

  /* body grid */
  .body {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: var(--sp-7);
    margin-top: var(--sp-8);
  }
  .main {
    min-width: 0;
  }
  .sidebar {
    position: sticky;
    top: 88px; /* clears the 64px nav */
    align-self: start;
    display: flex;
    flex-direction: column;
    gap: var(--sp-5);
  }

  .block {
    margin-bottom: var(--sp-8);
  }
  .block-title {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    line-height: var(--lh-xl);
    color: var(--ink);
    margin: var(--sp-2) 0 var(--sp-5);
  }

  /* MDX evidence-summary prose */
  .prose {
    max-width: 68ch;
  }
  .prose :global(p) {
    font-size: var(--text-base);
    line-height: var(--lh-base);
    color: var(--muted);
    margin: 0 0 var(--sp-4);
  }
  .prose :global(strong) {
    color: var(--ink);
    font-weight: 600;
  }
  .prose :global(a) {
    color: var(--primary);
  }
  .prose-p {
    max-width: 68ch;
    font-size: var(--text-base);
    line-height: var(--lh-base);
    color: var(--muted);
    margin: 0;
  }

  .disclaimer-slot {
    margin-top: var(--sp-8);
  }

  /* breakpoints (§3.2): body 1-col @900 (sidebar static below main); title lives in the
     hero label row (§11.3), which handles its own 46px floor */
  @media (max-width: 900px) {
    .body {
      grid-template-columns: 1fr;
    }
    .sidebar {
      position: static;
      top: auto;
    }
  }
  @media (max-width: 640px) {
    .remedy {
      padding: var(--sp-6) var(--sp-5) var(--sp-8);
    }
  }
</style>

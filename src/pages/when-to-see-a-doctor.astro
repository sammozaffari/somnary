    color: var(--ink);
    margin: 0;
  }
  .flag-detail {
    font-size: var(--text-sm);
    line-height: var(--lh-sm);
    color: var(--muted);
    margin: 0;
  }

  .prose {
    max-width: 68ch;
  }
  .prose p {
    font-size: var(--text-base);
    line-height: var(--lh-base);
    color: var(--muted);
    margin: 0 0 var(--sp-4);
  }
  .prose strong {
    color: var(--ink);
    font-weight: 600;
  }
  .prose ul {
    margin: 0;
    padding-left: var(--sp-5);
  }
  .prose li {
    font-size: var(--text-base);
    line-height: var(--lh-base);
    color: var(--muted);
    margin-bottom: var(--sp-3);
  }

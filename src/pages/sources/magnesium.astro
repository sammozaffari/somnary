---
import Base from '../../layouts/Base.astro';
import SafetyCallout from '../../components/scorecards/SafetyCallout.astro';
import RatingLegend from '../../components/scorecards/RatingLegend.astro';
import ScorecardGrid from '../../components/scorecards/ScorecardGrid.astro';
import { MAGNESIUM_SOURCES, type MagProduct } from '../../data/source-scorecards/magnesium';
import type { ScorecardCardData, Chip, DetailLine } from '../../data/source-scorecards/card';

const reviewDate = '2026-07-20';

// Map a magnesium product into the shared card shape.
function toCard(p: MagProduct): ScorecardCardData {
  const chips: Chip[] = [];
  if (p.b6) chips.push({ label: '⚠ Contains B6', kind: 'warn', note: p.b6.note });
  if (p.certVerified) chips.push({ label: '✓ Third-party tested', kind: 'good', note: p.certSummary });

  const detailLines: DetailLine[] = [];
  if (p.b6) detailLines.push({ tag: 'Safety', note: p.b6.note, kind: 'safety' });

  return {
    slug: p.slug,
    brand: p.brand,
    productName: p.productName,
    specLines: [`${p.elementalMg} mg elemental`, p.form],
    metaLine: `${p.ausL ? `AUST L ${p.ausL}` : (p.channel.includes('import') ? 'Not TGA-listed (import)' : 'AUST L — unconfirmed')} · ${p.channel}`,
    certSummary: p.certSummary,
    certVerified: p.certVerified,
    imagePath: p.imagePath,
    bottomLine: p.bottomLine,
    chips,
    scores: p.scores,
    verdict: p.verdict,
    detailLines,
    heldItems: p.heldItems,
    hasB6: !!p.b6,
  };
}

const cards = MAGNESIUM_SOURCES.filter((p) => p.ratified).map(toCard);

const ratingLegend = [
  { label: 'Testing & purity', plain: 'Has an independent lab checked what’s really inside? For most magnesium, no one has.' },
  { label: 'Label accuracy', plain: 'Does the amount inside actually match what the label promises?' },
  { label: 'Additives', plain: 'Any concerning extra ingredients — or just harmless fillers?' },
  { label: 'Regulatory record', plain: 'Has it been in trouble with the medicines regulator (the TGA here in Australia)?' },
  { label: 'Transparency', plain: 'Does the label tell you how much of each type of magnesium is inside, and who makes it?' },
  { label: 'Marketing honesty', plain: 'Do the claims on the box hold up, or is it overselling?' },
];

const safetyItems = [
  {
    label: 'Vitamin B6',
    body:
      'Many Australian magnesium supplements add <strong>vitamin B6</strong>, and the TGA is acting on it. Taking too much B6 over months can cause <strong>tingling or numbness in the hands and feet</strong> (nerve irritation — usually reversible if you stop); there have been 250+ adverse-event reports, mandated on-pack warnings, and product cancellations. It’s not the magnesium — it’s the added B6. Products that contain it carry a <strong>⚠ B6</strong> flag.',
  },
  {
    label: 'Pregnancy',
    body:
      'If you’re pregnant or breastfeeding, check any added ingredients with a pharmacist before taking magnesium supplements regularly.',
  },
];
---

<Base
  title="Where to source magnesium — Somnary source scorecards"
  description="Australian magnesium supplements for sleep, grouped into plain-English trust tiers and rated on six documented dimensions. No composite score, no #1, no affiliate links. Plus the vitamin-B6 safety flag the TGA is acting on."
>
  <main class="page">
    <header class="head">
      <p class="eyebrow">Source scorecards · Magnesium</p>
      <h1 class="title">Where to source magnesium</h1>
      <p class="dek">
        The <a href="/r/magnesium">evidence grade</a> answers whether magnesium helps you sleep.
        This page answers a different question: of the magnesium you can buy in an Australian
        chemist, which brands actually disclose what’s in the bottle and don’t overstate it? Each
        is rated on six documented dimensions — every point traces to a primary document. No overall
        score, no #1: <a href="/sources/methodology">a ranking would be a recommendation</a>, and we
        don’t make those.
      </p>
    </header>

    <aside class="banner">
      <p class="banner-line">
        These scorecards rate how a product is <strong>sourced and labeled</strong> — not whether
        you should take it. Educational, not medical advice.
      </p>
      <p class="banner-sub">
        No affiliate links — Somnary earns nothing if you buy. No brand pays to appear, to improve
        a score, or to remove one. <a href="/sources/methodology">How we rate →</a>
      </p>
    </aside>

    <SafetyCallout
      title="The vitamin-B6 warning worth knowing"
      tone="safety"
      items={safetyItems}
      foot="These flags are shown for your safety and sit apart from the scores — if you take magnesium daily, check your product’s B6 amount and talk to a pharmacist."
    />

    <RatingLegend items={ratingLegend} remedyHref="/r/magnesium" />

    <ScorecardGrid cards={cards} />

    <p class="footer-strip">
      Somnary · Magnesium source scorecards · Reviewed {reviewDate} · Educational, not medical
      advice · A scorecard is about what’s in a bottle, never about whether you should take it —
      talk to a clinician before changing what you take, especially about vitamin B6, or if you’re
      pregnant. Found an error, or a brand with a document to add? We aim to fix verified errors
      within 7 days — <a href="mailto:sammymoz@gmail.com">sammymoz@gmail.com</a>.
    </p>
  </main>
</Base>

<style>
  .page {
    max-width: 1040px;
    margin: 0 auto;
    padding: var(--sp-8) var(--sp-7) var(--sp-9);
  }
  .eyebrow {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    color: var(--muted);
    margin: 0;
  }
  .head {
    margin-bottom: var(--sp-6);
  }
  .title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--text-3xl);
    line-height: var(--lh-3xl);
    letter-spacing: var(--tracking-tight);
    color: var(--ink);
    margin: var(--sp-3) 0 var(--sp-5);
  }
  .dek {
    font-family: var(--font-body);
    font-size: var(--text-md);
    line-height: var(--lh-md);
    color: var(--muted);
    max-width: 68ch;
    margin: 0;
  }
  .dek a,
  .banner a,
  .footer-strip a {
    color: var(--primary);
  }

  .banner {
    background: var(--primary-soft);
    border-radius: var(--r-lg);
    padding: var(--sp-5) var(--sp-6);
    margin: var(--sp-6) 0 var(--sp-7);
  }
  .banner-line {
    font-size: var(--text-base);
    line-height: var(--lh-base);
    color: var(--ink);
    margin: 0 0 var(--sp-2);
  }
  .banner-sub {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    color: var(--muted);
    margin: 0;
  }

  .footer-strip {
    border-top: var(--border-hairline);
    margin-top: var(--sp-8);
    padding-top: var(--sp-5);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    line-height: var(--lh-sm);
    color: var(--muted);
  }

  @media (max-width: 720px) {
    .page {
      padding: var(--sp-7) var(--sp-5) var(--sp-8);
    }
  }
</style>

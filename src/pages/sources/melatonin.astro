---
import Base from '../../layouts/Base.astro';
import {
  MELATONIN_SOURCES,
  DIMENSION_ORDER,
  DIMENSION_LABELS,
  PRESCRIPTION_NOTE,
  type SourceProduct,
} from '../../data/source-scorecards/melatonin';

// Publish gate mirrors the Supabase view: only owner-ratified rows render.
// AU audience: melatonin is prescription-only here, so the only OTC route is personal import
// via iHerb. Withhold products an Australian can't actually buy OTC (availableInAU === false).
const products: SourceProduct[] = MELATONIN_SOURCES.filter(
  (p) => p.ratified && p.availableInAU !== false,
).sort((a, b) => a.brand.localeCompare(b.brand));

const reviewDate = '2026-07-19';
const segs = [1, 2, 3, 4, 5];
---

<Base
  title="Where to source melatonin — Somnary source scorecards"
  description="How melatonin products are sourced and labeled, rated on six documented dimensions: testing, label accuracy, additives, regulatory record, transparency, marketing honesty. No composite score, no #1, no affiliate links."
>
  <main class="page">
    <header class="head">
      <p class="eyebrow">Source scorecards · Melatonin</p>
      <h1 class="title">Where to source melatonin</h1>
      <p class="dek">
        The <a href="/r/melatonin">evidence grade</a> answers whether melatonin works. This page
        answers a different question: of the products you can actually buy, which contain what the
        label says, made by companies whose claims hold up? Each is rated on six documented
        dimensions — every point traces to a primary document. No overall score, no #1:
        <a href="/sources/methodology">a ranking would be a recommendation</a>, and we don’t make those.
      </p>
    </header>

    <aside class="banner">
      <p class="banner-line">
        These scorecards rate how a product is <strong>sourced and labeled</strong> — not whether
        you should take it. Educational, not medical advice.
      </p>
      <p class="banner-sub">
        No affiliate links — Somnary earns nothing if you buy. No brand pays to appear, to improve
        a score, or to remove one. <a href="/sources/methodology">How we rate →</a>
      </p>
    </aside>

    <aside class="au-note">
      <p class="au-note-title">Availability in Australia</p>
      <p class="au-note-body">
        Melatonin is <strong>prescription-only in Australia</strong> (Schedule 4; a narrow
        pharmacist-only exception covers low-dose modified-release for people 55+). Chemist
        Warehouse and Amazon AU don’t sell it over the counter — searches there return
        melatonin-<em>free</em> herbal sleep aids or products for pets. The only OTC route is
        <strong>personal import via iHerb</strong>, so the products below are the melatonin
        supplements Australians actually import. For a pharmacy option, <strong>Circadin</strong>
        (below) is available on prescription.
      </p>
    </aside>

    {
      products.length === 0 ? (
        <p class="empty">Scorecards are being finalized. Check back shortly.</p>
      ) : (
        <section class="stack" aria-label="Melatonin source scorecards">
          {products.map((p) => (
            <article class="card">
              <div class="shot">
                {p.imagePath ? (
                  <img src={p.imagePath} alt={`${p.brand} ${p.productName}`} loading="lazy" decoding="async" />
                ) : (
                  <span class="shot-fallback" aria-hidden="true">
                    {p.brand.charAt(0)}
                  </span>
                )}
              </div>

              <div class="body">
                <div class="body-head">
                  <div class="id">
                    <h2 class="brand">{p.brand}</h2>
                    <p class="product">
                      {p.productName} · {p.doseMg} mg · {p.form}
                    </p>
                  </div>
                  <p class="cert" data-kind={p.certVerified ? 'yes' : 'none'}>
                    {p.certSummary}
                  </p>
                </div>

                <p class="verdict">{p.verdict}</p>

                <div class="meters">
                  {DIMENSION_ORDER.map((key) => (
                    <div class="meter">
                      <span class="meter-label">{DIMENSION_LABELS[key]}</span>
                      <span class="meter-row">
                        <span class="bar" aria-hidden="true">
                          {segs.map((i) => (
                            <i class:list={['seg', { on: i <= p.scores[key].score }]} />
                          ))}
                        </span>
                        <span class="meter-num">{p.scores[key].score}<span class="of">/5</span></span>
                      </span>
                    </div>
                  ))}
                </div>

                <details class="why">
                  <summary>Why these scores</summary>
                  <dl class="why-list">
                    {DIMENSION_ORDER.map((key) => (
                      <div class="why-row">
                        <dt>
                          {DIMENSION_LABELS[key]} · {p.scores[key].score}/5
                        </dt>
                        <dd>{p.scores[key].note}</dd>
                      </div>
                    ))}
                  </dl>
                  {p.heldItems.length > 0 && (
                    <p class="held">
                      <span class="tag">Under review</span> {p.heldItems.join(' ')} — not counted
                      until confirmed against the primary regulator document.
                    </p>
                  )}
                </details>

                <div class="foot">
                  <p class="community">
                    <span class="tag">Community read</span>{' '}
                    {p.communityThemes && p.communityThemes.length > 0 ? (
                      p.communityThemes.map((t, i) => (
                        <>
                          {i > 0 && ' · '}
                          {t.url ? <a href={t.url} rel="nofollow noopener" target="_blank">{t.note}</a> : t.note}
                        </>
                      ))
                    ) : (
                      <>Gathering — shown for context only, never affects a score.</>
                    )}
                  </p>
                  <p class="links">
                    <a class="buy" href={p.manufacturerUrl} rel="nofollow noopener" target="_blank">
                      Product page ↗
                    </a>
                    <span class="nolink">No affiliate link</span>
                  </p>
                </div>
              </div>
            </article>
          ))}
        </section>
      )
    }

    <section class="rx">
      <h2 class="rx-title">Prescription option (not scored here)</h2>
      <p class="rx-body">
        <strong>{PRESCRIPTION_NOTE.brand}</strong> — {PRESCRIPTION_NOTE.productName}. {PRESCRIPTION_NOTE.note}
      </p>
    </section>

    <p class="footer-strip">
      Somnary · Melatonin source scorecards · Reviewed {reviewDate} · Educational, not medical
      advice · A scorecard is about what’s in a bottle, never about whether you should take it —
      talk to a clinician before changing what you take. Found an error, or a brand with a document
      to add? We aim to fix verified errors within 7 days —
      <a href="mailto:sammymoz@gmail.com">sammymoz@gmail.com</a>.
    </p>
  </main>
</Base>

<style>
  .page {
    max-width: 1040px;
    margin: 0 auto;
    padding: var(--sp-8) var(--sp-7) var(--sp-9);
  }
  .eyebrow {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    color: var(--muted);
    margin: 0;
  }
  .head {
    margin-bottom: var(--sp-6);
  }
  .title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--text-3xl);
    line-height: var(--lh-3xl);
    letter-spacing: var(--tracking-tight);
    color: var(--ink);
    margin: var(--sp-3) 0 var(--sp-5);
  }
  .dek {
    font-family: var(--font-body);
    font-size: var(--text-md);
    line-height: var(--lh-md);
    color: var(--muted);
    max-width: 68ch;
    margin: 0;
  }
  .dek a,
  .banner a,
  .au-note a,
  .buy,
  .community a,
  .footer-strip a {
    color: var(--primary);
  }

  .banner {
    background: var(--primary-soft);
    border-radius: var(--r-lg);
    padding: var(--sp-5) var(--sp-6);
    margin: var(--sp-6) 0 var(--sp-4);
  }
  .banner-line {
    font-size: var(--text-base);
    line-height: var(--lh-base);
    color: var(--ink);
    margin: 0 0 var(--sp-2);
  }
  .banner-sub {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    color: var(--muted);
    margin: 0;
  }

  .au-note {
    border: var(--border-hairline);
    border-radius: var(--r-lg);
    padding: var(--sp-5) var(--sp-6);
    margin: 0 0 var(--sp-7);
    background: var(--surface);
  }
  .au-note-title {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    color: var(--ink);
    margin: 0 0 var(--sp-2);
  }
  .au-note-body {
    font-size: var(--text-sm);
    line-height: var(--lh-sm);
    color: var(--muted);
    margin: 0;
  }
  .au-note-body strong {
    color: var(--ink);
  }

  .empty {
    color: var(--muted);
    font-size: var(--text-base);
  }

  /* scorecard stack — one wide card per product */
  .stack {
    display: flex;
    flex-direction: column;
    gap: var(--sp-5);
  }
  .card {
    display: grid;
    grid-template-columns: 168px 1fr;
    gap: var(--sp-6);
    border: var(--border-hairline);
    border-radius: var(--r-xl);
    background: var(--surface);
    padding: var(--sp-6);
  }

  /* product shot */
  .shot {
    display: flex;
    align-items: center;
    justify-content: center;
    aspect-ratio: 1;
    background: var(--primary-soft);
    border-radius: var(--r-lg);
    overflow: hidden;
  }
  .shot img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: var(--sp-3);
  }
  .shot-fallback {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--text-3xl);
    color: var(--primary);
  }

  .body {
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: var(--sp-4);
  }
  .body-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--sp-4);
  }
  .brand {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--text-xl);
    line-height: var(--lh-xl);
    color: var(--ink);
    margin: 0;
  }
  .product {
    font-size: var(--text-sm);
    color: var(--muted);
    margin: var(--sp-1) 0 0;
  }
  .cert {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    text-align: right;
    white-space: nowrap;
    margin: 0;
    flex-shrink: 0;
  }
  .cert[data-kind='yes'] {
    color: var(--eucalyptus, var(--primary));
  }
  .cert[data-kind='none'] {
    color: var(--muted);
  }

  .verdict {
    font-family: var(--font-body);
    font-size: var(--text-md);
    line-height: var(--lh-md);
    color: var(--ink);
    margin: 0;
    max-width: 62ch;
  }

  /* six-dimension meter grid — 3 across */
  .meters {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--sp-4) var(--sp-5);
    padding-top: var(--sp-4);
    border-top: var(--border-hairline);
  }
  .meter {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
  }
  .meter-label {
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    color: var(--muted);
    font-family: var(--font-mono);
  }
  .meter-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-2);
  }
  .bar {
    display: inline-flex;
    gap: var(--sp-1);
  }
  .seg {
    width: var(--sp-4);
    height: var(--sp-2);
    border-radius: var(--r-sm);
    background: var(--primary-soft);
  }
  .seg.on {
    background: var(--ink);
  }
  .meter-num {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--ink);
    font-weight: 600;
  }
  .meter-num .of {
    color: var(--muted);
    font-weight: 400;
  }

  /* expandable rationale */
  .why {
    border-top: var(--border-hairline);
    padding-top: var(--sp-3);
  }
  .why > summary {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    color: var(--primary);
    cursor: pointer;
  }
  .why-list {
    margin: var(--sp-4) 0 0;
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
  }
  .why-row dt {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--ink);
    margin: 0 0 var(--sp-1);
  }
  .why-row dd {
    font-size: var(--text-sm);
    line-height: var(--lh-sm);
    color: var(--muted);
    margin: 0;
  }
  .held {
    font-size: var(--text-xs);
    line-height: var(--lh-sm);
    color: var(--muted);
    margin: var(--sp-4) 0 0;
  }

  .foot {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: var(--sp-4);
    flex-wrap: wrap;
    padding-top: var(--sp-3);
    border-top: var(--border-hairline);
  }
  .community {
    font-size: var(--text-xs);
    line-height: var(--lh-sm);
    color: var(--muted);
    margin: 0;
    max-width: 52ch;
  }
  .tag {
    font-family: var(--font-mono);
    letter-spacing: var(--tracking-label);
    color: var(--ink);
    margin-right: var(--sp-1);
  }
  .links {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: var(--sp-1);
    margin: 0;
    flex-shrink: 0;
  }
  .buy {
    font-size: var(--text-sm);
    font-weight: 600;
  }
  .nolink {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    color: var(--muted);
  }

  .rx {
    border: var(--border-hairline);
    border-radius: var(--r-lg);
    background: var(--surface);
    padding: var(--sp-5) var(--sp-6);
    margin: var(--sp-7) 0 0;
  }
  .rx-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--text-md);
    color: var(--ink);
    margin: 0 0 var(--sp-2);
  }
  .rx-body {
    font-size: var(--text-sm);
    line-height: var(--lh-sm);
    color: var(--muted);
    margin: 0;
  }

  .footer-strip {
    border-top: var(--border-hairline);
    margin-top: var(--sp-8);
    padding-top: var(--sp-5);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    line-height: var(--lh-sm);
    color: var(--muted);
  }

  @media (max-width: 720px) {
    .page {
      padding: var(--sp-7) var(--sp-5) var(--sp-8);
    }
    .card {
      grid-template-columns: 1fr;
      gap: var(--sp-4);
    }
    .shot {
      aspect-ratio: auto;
      height: 200px;
    }
    .meters {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>

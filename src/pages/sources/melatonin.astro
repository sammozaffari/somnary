---
import Base from '../../layouts/Base.astro';
import SafetyCallout from '../../components/scorecards/SafetyCallout.astro';
import RatingLegend from '../../components/scorecards/RatingLegend.astro';
import ScorecardGrid from '../../components/scorecards/ScorecardGrid.astro';
import {
  MELATONIN_SOURCES,
  PRESCRIPTION_NOTE,
  type SourceProduct,
} from '../../data/source-scorecards/melatonin';
import type { ScorecardCardData, Chip, DetailLine } from '../../data/source-scorecards/card';

const reviewDate = '2026-07-19';

// Map a melatonin product into the shared card shape.
function toCard(p: SourceProduct): ScorecardCardData {
  const chips: Chip[] = [];
  if (p.certVerified)
    chips.push({ label: '✓ Third-party verified', kind: 'good', note: p.certSummary });

  const detailLines: DetailLine[] = [];

  return {
    slug: p.slug,
    brand: p.brand,
    productName: p.productName,
    specLines: [`${p.doseMg} mg`, p.form],
    metaLine: `${p.market} · ${p.singleOrCombo}`,
    certSummary: p.certSummary,
    certVerified: p.certVerified,
    imagePath: p.imagePath,
    bottomLine: p.bottomLine,
    chips,
    scores: p.scores,
    verdict: p.verdict,
    detailLines,
    heldItems: p.heldItems,
    hasB6: false,
  };
}

// Publish gate mirrors the Supabase view: only owner-ratified rows render.
// AU audience: melatonin is prescription-only here, so the only OTC route is personal import
// via iHerb. Withhold products an Australian can't actually buy OTC (availableInAU === false).
const cards = MELATONIN_SOURCES.filter((p) => p.ratified && p.availableInAU !== false).map(toCard);

const ratingLegend = [
  { label: 'Testing & purity', plain: 'Has an independent lab checked what’s really inside?' },
  { label: 'Label accuracy', plain: 'Does the amount inside actually match what the label promises?' },
  { label: 'Additives', plain: 'Any concerning extra ingredients — or just melatonin?' },
  { label: 'Regulatory record', plain: 'Has it been in trouble with a medicines regulator (FDA / TGA)?' },
  { label: 'Transparency', plain: 'Does the label tell you the dose, the form, and who makes it?' },
  { label: 'Marketing honesty', plain: 'Do the claims on the box hold up, or is it overselling?' },
];

const safetyItems = [
  {
    label: 'Prescription only',
    body:
      'In Australia, melatonin is a <strong>prescription medicine</strong> (with a limited pharmacist-only option for adults 55+). None of these are sold over the counter in Australian chemists — Amazon AU and Chemist Warehouse carry no OTC human melatonin. The ones here are imported for personal use via iHerb.',
  },
];
---

<Base
  title="Where to source melatonin — Somnary source scorecards"
  description="Melatonin supplements Australians import via iHerb, grouped into plain-English trust tiers and rated on six documented dimensions: testing, label accuracy, additives, regulatory record, transparency, marketing honesty. No composite score, no #1, no affiliate links. Plus the prescription-only reality in Australia."
>
  <main class="page">
    <header class="head">
      <p class="eyebrow">Source scorecards · Melatonin</p>
      <h1 class="title">Where to source melatonin</h1>
      <p class="dek">
        The <a href="/r/melatonin">evidence grade</a> answers whether melatonin works. This page
        answers a different question: of the melatonin an Australian can actually get — which, because
        it’s prescription-only here, means personal import — which products contain what the label
        says, made by companies whose claims hold up? Each is rated on six documented dimensions —
        every point traces to a primary document. No overall score, no #1:
        <a href="/sources/methodology">a ranking would be a recommendation</a>, and we don’t make those.
      </p>
    </header>

    <aside class="banner">
      <p class="banner-line">
        These scorecards rate how a product is <strong>sourced and labeled</strong> — not whether
        you should take it. Educational, not medical advice.
      </p>
      <p class="banner-sub">
        No affiliate links — Somnary earns nothing if you buy. No brand pays to appear, to improve
        a score, or to remove one. <a href="/sources/methodology">How we rate →</a>
      </p>
    </aside>

    <SafetyCallout
      title="Melatonin in Australia — the prescription reality"
      tone="info"
      items={safetyItems}
      foot="This is context on how you’d get melatonin in Australia — not medical advice. For a pharmacy option, Circadin (below) is available on prescription; talk to a pharmacist or doctor before starting melatonin."
    />

    <RatingLegend items={ratingLegend} remedyHref="/r/melatonin" />

    <ScorecardGrid cards={cards} />

    <section class="rx">
      <h2 class="rx-title">Prescription option (not scored here)</h2>
      <p class="rx-body">
        <strong>{PRESCRIPTION_NOTE.brand}</strong> — {PRESCRIPTION_NOTE.productName}. {PRESCRIPTION_NOTE.note}
      </p>
    </section>

    <p class="footer-strip">
      Somnary · Melatonin source scorecards · Reviewed {reviewDate} · Educational, not medical
      advice · A scorecard is about what’s in a bottle, never about whether you should take it —
      talk to a clinician before changing what you take, and remember melatonin is prescription-only
      in Australia. Found an error, or a brand with a document to add? We aim to fix verified errors
      within 7 days — <a href="mailto:sammymoz@gmail.com">sammymoz@gmail.com</a>.
    </p>
  </main>
</Base>

<style>
  .page {
    max-width: 1040px;
    margin: 0 auto;
    padding: var(--sp-8) var(--sp-7) var(--sp-9);
  }
  .eyebrow {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    color: var(--muted);
    margin: 0;
  }
  .head {
    margin-bottom: var(--sp-6);
  }
  .title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--text-3xl);
    line-height: var(--lh-3xl);
    letter-spacing: var(--tracking-tight);
    color: var(--ink);
    margin: var(--sp-3) 0 var(--sp-5);
  }
  .dek {
    font-family: var(--font-body);
    font-size: var(--text-md);
    line-height: var(--lh-md);
    color: var(--muted);
    max-width: 68ch;
    margin: 0;
  }
  .dek a,
  .banner a,
  .rx a,
  .footer-strip a {
    color: var(--primary);
  }

  .banner {
    background: var(--primary-soft);
    border-radius: var(--r-lg);
    padding: var(--sp-5) var(--sp-6);
    margin: var(--sp-6) 0 var(--sp-7);
  }
  .banner-line {
    font-size: var(--text-base);
    line-height: var(--lh-base);
    color: var(--ink);
    margin: 0 0 var(--sp-2);
  }
  .banner-sub {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    color: var(--muted);
    margin: 0;
  }

  .rx {
    border: var(--border-hairline);
    border-radius: var(--r-lg);
    background: var(--surface);
    padding: var(--sp-5) var(--sp-6);
    margin: var(--sp-7) 0 0;
  }
  .rx-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--text-md);
    color: var(--ink);
    margin: 0 0 var(--sp-2);
  }
  .rx-body {
    font-size: var(--text-sm);
    line-height: var(--lh-sm);
    color: var(--muted);
    margin: 0;
  }

  .footer-strip {
    border-top: var(--border-hairline);
    margin-top: var(--sp-8);
    padding-top: var(--sp-5);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    line-height: var(--lh-sm);
    color: var(--muted);
  }

  @media (max-width: 720px) {
    .page {
      padding: var(--sp-7) var(--sp-5) var(--sp-8);
    }
  }
</style>

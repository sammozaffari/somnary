---
import Base from '../../layouts/Base.astro';
import {
  ASHWAGANDHA_SOURCES,
  DIMENSION_ORDER,
  DIMENSION_LABELS,
} from '../../data/source-scorecards/ashwagandha';
import { groupByTier } from '../../data/source-scorecards/tiers';

// Only ratified rows render (mirrors the Supabase publish gate). Grouped into sourcing-trust tiers
// (best-documented first); within a tier, alphabetical — so no hard 1-2-3 ranking is implied.
const ratified = ASHWAGANDHA_SOURCES.filter((p) => p.ratified);
const grouped = groupByTier(ratified, (p) => !!p.b6, (a, b) => a.brand.localeCompare(b.brand));
const total = ratified.length;

const reviewDate = '2026-07-21';
const segs = [1, 2, 3, 4, 5];

// Plain-language legend — so anyone can read a card, not just someone who knows the jargon.
const ratingLegend = [
  { label: 'Testing & purity', plain: 'Has an independent lab checked what’s really inside? For ashwagandha, almost no one has.' },
  { label: 'Label accuracy', plain: 'Does the amount inside actually match what the label promises?' },
  { label: 'Additives', plain: 'Any concerning extra ingredients — or just the herb?' },
  { label: 'Regulatory record', plain: 'Has it been in trouble with the medicines regulator (the TGA here in Australia)?' },
  { label: 'Transparency', plain: 'Does the label tell you its active strength (withanolides), name its extract, and who makes it?' },
  { label: 'Marketing honesty', plain: 'Do the claims on the box hold up, or is it overselling?' },
];
---

<Base
  title="Where to source ashwagandha — Somnary source scorecards"
  description="Ashwagandha supplements for stress and sleep you can buy in Australia, rated on six documented dimensions: testing, label accuracy, additives, regulatory record, transparency, marketing honesty. No composite score, no #1, no affiliate links. Plus the liver-injury warning worth knowing."
>
  <main class="page">
    <header class="head">
      <p class="eyebrow">Source scorecards · Ashwagandha</p>
      <h1 class="title">Where to source ashwagandha</h1>
      <p class="dek">
        The <a href="/r/ashwagandha">evidence grade</a> answers whether ashwagandha helps with stress
        and sleep. This page answers a different question: of the ashwagandha you can buy in Australia,
        which names a real, studied extract, tells you its active strength, and is made by someone who
        stands behind it? Each is rated on six documented dimensions — every point traces to a primary
        document. No overall score, no #1:
        <a href="/sources/methodology">a ranking would be a recommendation</a>, and we don’t make those.
      </p>
    </header>

    <aside class="banner">
      <p class="banner-line">
        These scorecards rate how a product is <strong>sourced and labeled</strong> — not whether
        you should take it. Educational, not medical advice.
      </p>
      <p class="banner-sub">
        No affiliate links — Somnary earns nothing if you buy. No brand pays to appear, to improve
        a score, or to remove one. <a href="/sources/methodology">How we rate →</a>
      </p>
    </aside>

    <aside class="safety-note" aria-labelledby="safety-title">
      <h2 class="safety-note-title" id="safety-title"><span class="safety-note-mark" aria-hidden="true">⚠</span> Ashwagandha safety notes worth knowing</h2>
      <dl class="safety-list">
        <div class="safety-item">
          <dt>Liver</dt>
          <dd>
            Australia’s medicines regulator (the TGA) has a standing advisory that ashwagandha carries a
            <strong>very rare risk of liver injury</strong>, and it’s weighing the <strong>root vs leaf</strong>
            question (some countries restrict leaf use). Products made from <strong>root and leaf</strong> —
            flagged on their cards — sit on the higher-scrutiny side; the <strong>imported</strong> ones don’t
            carry Australia’s liver-caution wording at all.
          </dd>
        </div>
        <div class="safety-item">
          <dt>Vitamin B6</dt>
          <dd>
            One product here (Blackmores Ashwagandha+) also adds a notable amount of B6 and carries the
            mandated nerve-damage warning — shown as a <strong>⚠ B6</strong> flag.
          </dd>
        </div>
        <div class="safety-item">
          <dt>Pregnancy</dt>
          <dd>The standard advice is to avoid ashwagandha in pregnancy and breastfeeding.</dd>
        </div>
      </dl>
      <p class="safety-note-foot">
        These flags are shown for your safety and sit apart from the scores — talk to a pharmacist before
        taking ashwagandha regularly.
      </p>
    </aside>

    <section class="legend" aria-labelledby="legend-title">
      <h2 class="legend-title" id="legend-title">What the six ratings mean</h2>
      <p class="legend-sub">In plain words. Every product is scored 0–5 on each — more filled bars is better.</p>
      <dl class="legend-grid">
        {ratingLegend.map((r) => (
          <div class="legend-item">
            <dt>{r.label}</dt>
            <dd>{r.plain}</dd>
          </div>
        ))}
      </dl>
      <p class="legend-foot">
        To make the page quick to read, we group the products into four <strong>trust tiers</strong> below —
        a shorthand for how well-sourced and transparent each is, drawn straight from these six scores.
        <strong>A tier is about how much you can trust what’s on the label — not whether you should buy it or
        whether it works for you</strong> (that’s the <a href="/r/ashwagandha">evidence grade</a>). Tap
        “Why these scores” on any card for the specifics.
      </p>
    </section>

    {
      total === 0 ? (
        <p class="empty">Scorecards are being finalized. Check back shortly.</p>
      ) : (
        grouped.map((g) => (
          <section class="tiergroup" aria-label={`${g.tier.label} — ${g.items.length} product${g.items.length === 1 ? '' : 's'}`}>
            <div class="tierhead" data-tier={g.tier.key}>
              <h2 class="tierhead-title">
                <span class="tierhead-icon" aria-hidden="true">{g.tier.icon}</span>
                {g.tier.label}
                <span class="tierhead-count">{g.items.length}</span>
              </h2>
              <p class="tierhead-blurb">{g.tier.blurb}</p>
            </div>

            <div class="stack">
              {g.items.map((p) => (
                <article class="card">
                  <div class="shot">
                    {p.imagePath ? (
                      <img src={p.imagePath} alt={`${p.brand} ${p.productName}`} loading="lazy" decoding="async" />
                    ) : (
                      <span class="shot-fallback" aria-hidden="true">
                        {p.brand.charAt(0)}
                      </span>
                    )}
                  </div>

                  <div class="body">
                    <div class="id">
                      <h3 class="brand">{p.brand}</h3>
                      <p class="product">{p.productName}</p>
                      <p class="spec">{p.strength}</p>
                      <p class="cert" data-kind={p.certVerified ? 'yes' : 'none'}>{p.certSummary}</p>
                    </div>

                    <p class="bottomline">{p.bottomLine}</p>

                    {(p.trialFlag || p.rootPart === 'root+leaf' || p.b6 || p.importSafety) && (
                      <div class="chips">
                        {p.trialFlag && <span class="chip" data-kind="good" title={p.trialFlag.note}>🔬 Used in trials</span>}
                        {p.rootPart === 'root+leaf' && <span class="chip" data-kind="good" title="Made from root and leaf — the plant part under extra liver scrutiny (see the safety notes above).">🍃 Root + leaf</span>}
                        {p.b6 && <span class="chip" data-kind="warn" title={p.b6.note}>⚠ Contains B6</span>}
                        {p.importSafety && <span class="chip" data-kind="warn" title={p.importSafety.note}>⚠ Import — no AU warning</span>}
                      </div>
                    )}

                    <details class="why">
                      <summary>Why these scores</summary>
                      <div class="why-body">
                        <p class="verdict">{p.verdict}</p>

                        {p.b6 && (
                          <p class="safetyline"><span class="tag">Safety</span> {p.b6.note}</p>
                        )}
                        {p.importSafety && (
                          <p class="safetyline"><span class="tag">Safety</span> {p.importSafety.note}</p>
                        )}
                        {p.trialFlag && (
                          <p class="trialline"><span class="tag">Used in trials</span> {p.trialFlag.note}</p>
                        )}

                        <div class="meters">
                          {DIMENSION_ORDER.map((key) => (
                            <div class="meter">
                              <span class="meter-label">{DIMENSION_LABELS[key]}</span>
                              <span class="meter-row">
                                <span class="bar" aria-hidden="true">
                                  {segs.map((i) => (
                                    <i class:list={['seg', { on: i <= p.scores[key].score }]} />
                                  ))}
                                </span>
                                <span class="meter-num">{p.scores[key].score}<span class="of">/5</span></span>
                              </span>
                            </div>
                          ))}
                        </div>

                        <dl class="why-list">
                          {DIMENSION_ORDER.map((key) => (
                            <div class="why-row">
                              <dt>{DIMENSION_LABELS[key]} · {p.scores[key].score}/5</dt>
                              <dd>{p.scores[key].note}</dd>
                            </div>
                          ))}
                        </dl>

                        {p.heldItems.length > 0 && (
                          <p class="held"><span class="tag">Under review</span> {p.heldItems.join(' ')}</p>
                        )}
                      </div>
                    </details>

                    <p class="community">
                      <span class="tag">Community read · never scored</span>{' '}
                      {p.communityThemes && p.communityThemes.length > 0 ? (
                        p.communityThemes.map((t, i) => (
                          <>
                            {i > 0 && ' · '}
                            {t.url ? <a href={t.url} rel="nofollow noopener" target="_blank">{t.note}</a> : t.note}
                          </>
                        ))
                      ) : (
                        <>Gathering — forum context only.</>
                      )}
                    </p>
                  </div>
                </article>
              ))}
            </div>
          </section>
        ))
      )
    }

    <p class="footer-strip">
      Somnary · Ashwagandha source scorecards · Reviewed {reviewDate} · Educational, not medical
      advice · A scorecard is about what’s in a bottle, never about whether you should take it —
      talk to a clinician before changing what you take, especially about your liver, vitamin B6, or
      if you’re pregnant. Found an error, or a brand with a document to add? We aim to fix verified
      errors within 7 days — <a href="mailto:sammymoz@gmail.com">sammymoz@gmail.com</a>.
    </p>
  </main>
</Base>

<style>
  .page {
    max-width: 1040px;
    margin: 0 auto;
    padding: var(--sp-8) var(--sp-7) var(--sp-9);
  }
  .eyebrow {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    color: var(--muted);
    margin: 0;
  }
  .head {
    margin-bottom: var(--sp-6);
  }
  .title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--text-3xl);
    line-height: var(--lh-3xl);
    letter-spacing: var(--tracking-tight);
    color: var(--ink);
    margin: var(--sp-3) 0 var(--sp-5);
  }
  .dek {
    font-family: var(--font-body);
    font-size: var(--text-md);
    line-height: var(--lh-md);
    color: var(--muted);
    max-width: 68ch;
    margin: 0;
  }
  .dek a,
  .banner a,
  .safety-note a,
  .community a,
  .footer-strip a {
    color: var(--primary);
  }

  .banner {
    background: var(--primary-soft);
    border-radius: var(--r-lg);
    padding: var(--sp-5) var(--sp-6);
    margin: var(--sp-6) 0 var(--sp-4);
  }
  .banner-line {
    font-size: var(--text-base);
    line-height: var(--lh-base);
    color: var(--ink);
    margin: 0 0 var(--sp-2);
  }
  .banner-sub {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    color: var(--muted);
    margin: 0;
  }

  /* liver + B6 + pregnancy safety explainer — safety register, distinct from the primary banner */
  .safety-note {
    border: var(--border-hairline);
    border-left: 3px solid var(--safety-ink, var(--vermilion));
    border-radius: var(--r-lg);
    padding: var(--sp-6) var(--sp-7);
    margin: 0 0 var(--sp-8);
    background: var(--surface);
  }
  .safety-note-title {
    display: flex;
    align-items: center;
    gap: var(--sp-2);
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--text-lg);
    line-height: var(--lh-lg);
    letter-spacing: var(--tracking-tight);
    color: var(--safety-ink, var(--ink));
    margin: 0 0 var(--sp-5);
  }
  .safety-note-mark {
    font-size: var(--text-md);
  }
  .safety-list {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--sp-5);
  }
  .safety-item {
    display: grid;
    grid-template-columns: minmax(88px, 120px) 1fr;
    gap: var(--sp-2) var(--sp-6);
    align-items: baseline;
  }
  .safety-item dt {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--ink);
    margin: 0;
  }
  .safety-item dd {
    margin: 0;
    font-size: var(--text-sm);
    line-height: var(--lh-md);
    color: var(--ink);
  }
  .safety-item dd strong {
    font-weight: 700;
  }
  .safety-note-foot {
    font-size: var(--text-xs);
    line-height: var(--lh-sm);
    color: var(--muted);
    margin: var(--sp-5) 0 0;
    padding-top: var(--sp-4);
    border-top: var(--border-hairline);
  }

  .empty {
    color: var(--muted);
    font-size: var(--text-base);
  }

  /* plain-language legend */
  .legend {
    margin: 0 0 var(--sp-8);
  }
  .legend-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--text-2xl);
    line-height: var(--lh-2xl);
    letter-spacing: var(--tracking-tight);
    color: var(--ink);
    margin: 0 0 var(--sp-2);
  }
  .legend-sub {
    font-size: var(--text-sm);
    line-height: var(--lh-sm);
    color: var(--muted);
    margin: 0 0 var(--sp-6);
  }
  .legend-grid {
    margin: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--sp-6) var(--sp-8);
  }
  .legend-item {
    padding-top: var(--sp-4);
    border-top: var(--border-hairline);
  }
  .legend-item dt {
    font-family: var(--font-body);
    font-size: var(--text-base);
    font-weight: 700;
    color: var(--ink);
    margin: 0 0 var(--sp-2);
  }
  .legend-item dd {
    margin: 0;
    font-size: var(--text-sm);
    line-height: var(--lh-md);
    color: var(--muted);
  }
  .legend-foot {
    font-size: var(--text-sm);
    line-height: var(--lh-md);
    color: var(--muted);
    margin: var(--sp-6) 0 0;
    padding-top: var(--sp-5);
    border-top: var(--border-hairline);
    max-width: 74ch;
  }
  .legend-foot strong {
    color: var(--ink);
  }

  /* sourcing-trust tier groups */
  .tiergroup {
    margin: 0 0 var(--sp-8);
  }
  .tierhead {
    margin: 0 0 var(--sp-5);
    padding-left: var(--sp-4);
    border-left: 3px solid var(--muted);
  }
  .tierhead[data-tier='well-documented'],
  .tierhead[data-tier='reasonable'] {
    border-left-color: var(--eucalyptus, var(--primary));
  }
  .tierhead[data-tier='bare-bones'] {
    border-left-color: var(--muted);
  }
  .tierhead[data-tier='heads-up'] {
    border-left-color: var(--safety-ink, var(--vermilion));
  }
  .tierhead-title {
    display: flex;
    align-items: center;
    gap: var(--sp-2);
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--text-xl);
    line-height: var(--lh-xl);
    color: var(--ink);
    margin: 0;
  }
  .tierhead-icon {
    font-size: var(--text-lg);
  }
  .tierhead-count {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    color: var(--muted);
    font-weight: 400;
    background: var(--primary-soft);
    border-radius: var(--r-sm);
    padding: var(--sp-1) var(--sp-2);
    align-self: center;
  }
  .tierhead-blurb {
    font-size: var(--text-sm);
    line-height: var(--lh-sm);
    color: var(--muted);
    margin: var(--sp-2) 0 0;
    max-width: 72ch;
  }

  /* responsive grid of compact, decision-first cards — 3 across on desktop */
  .stack {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--sp-5);
    align-items: start;
  }
  .card {
    display: flex;
    flex-direction: column;
    border: var(--border-hairline);
    border-radius: var(--r-xl);
    background: var(--surface);
    overflow: hidden;
  }
  .shot {
    display: flex;
    align-items: center;
    justify-content: center;
    aspect-ratio: 4 / 3;
    background: var(--primary-soft);
    border-bottom: var(--border-hairline);
  }
  .shot img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: var(--sp-5);
  }
  .shot-fallback {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--text-3xl);
    color: var(--primary);
  }

  .body {
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
    padding: var(--sp-5);
    flex: 1 1 auto;
  }
  .id {
    display: flex;
    flex-direction: column;
    gap: var(--sp-1);
  }
  .brand {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--text-lg);
    line-height: var(--lh-lg);
    letter-spacing: var(--tracking-tight);
    color: var(--ink);
    margin: 0;
  }
  .product {
    font-size: var(--text-sm);
    line-height: var(--lh-sm);
    color: var(--ink);
    margin: 0;
  }
  .spec {
    font-size: var(--text-xs);
    line-height: var(--lh-sm);
    color: var(--muted);
    margin: 0;
  }
  .cert {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    margin: var(--sp-1) 0 0;
  }
  .cert[data-kind='yes'] {
    color: var(--eucalyptus, var(--primary));
  }
  .cert[data-kind='none'] {
    color: var(--muted);
  }
  .chips {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
  }
  .chip {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    border-radius: var(--r-sm);
    padding: var(--sp-1) var(--sp-2);
    margin: 0;
    white-space: nowrap;
  }
  .chip[data-kind='good'] {
    color: var(--eucalyptus, var(--primary));
    border: 1px solid var(--eucalyptus, var(--primary));
  }
  .chip[data-kind='warn'] {
    color: var(--safety-ink, var(--ink));
    border: 1px solid var(--safety-ink, var(--muted));
  }

  /* the 2-second read — bold lead line */
  .bottomline {
    font-family: var(--font-body);
    font-size: var(--text-base);
    line-height: var(--lh-base);
    font-weight: 600;
    color: var(--ink);
    margin: var(--sp-1) 0 0;
  }
  /* the fuller story — supporting, de-emphasised under the bottom line */
  .verdict {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    line-height: var(--lh-sm);
    color: var(--muted);
    margin: 0;
    max-width: 64ch;
  }

  .trialline,
  .safetyline {
    font-size: var(--text-sm);
    line-height: var(--lh-sm);
    color: var(--muted);
    margin: 0;
    padding: var(--sp-3) var(--sp-4);
    border-radius: var(--r-sm);
    background: var(--primary-soft);
  }
  .safetyline .tag {
    color: var(--safety-ink, var(--ink));
  }
  .trialline .tag {
    color: var(--eucalyptus, var(--ink));
  }

  .meters {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--sp-4) var(--sp-5);
  }
  .meter {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
  }
  .meter-label {
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    color: var(--muted);
    font-family: var(--font-mono);
  }
  .meter-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-2);
  }
  .bar {
    display: inline-flex;
    gap: var(--sp-1);
  }
  .seg {
    width: var(--sp-4);
    height: var(--sp-2);
    border-radius: var(--r-sm);
    background: var(--primary-soft);
  }
  .seg.on {
    background: var(--ink);
  }
  .meter-num {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--ink);
    font-weight: 600;
  }
  .meter-num .of {
    color: var(--muted);
    font-weight: 400;
  }

  .why {
    border-top: var(--border-hairline);
    padding-top: var(--sp-3);
    margin-top: var(--sp-1);
  }
  .why > summary {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    color: var(--primary);
    cursor: pointer;
  }
  .why-body {
    display: flex;
    flex-direction: column;
    gap: var(--sp-4);
    margin-top: var(--sp-4);
  }
  .why-list {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
  }
  .why-row dt {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--ink);
    margin: 0 0 var(--sp-1);
  }
  .why-row dd {
    font-size: var(--text-sm);
    line-height: var(--lh-sm);
    color: var(--muted);
    margin: 0;
  }
  .held {
    font-size: var(--text-xs);
    line-height: var(--lh-sm);
    color: var(--muted);
    margin: 0;
  }

  .community {
    font-size: var(--text-xs);
    line-height: var(--lh-sm);
    color: var(--muted);
    margin: auto 0 0;
    padding-top: var(--sp-4);

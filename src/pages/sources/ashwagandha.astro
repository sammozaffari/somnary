---
import Base from '../../layouts/Base.astro';
import SafetyCallout from '../../components/scorecards/SafetyCallout.astro';
import RatingLegend from '../../components/scorecards/RatingLegend.astro';
import ScorecardGrid from '../../components/scorecards/ScorecardGrid.astro';
import { ASHWAGANDHA_SOURCES, type AshProduct } from '../../data/source-scorecards/ashwagandha';
import type { ScorecardCardData, Chip, DetailLine } from '../../data/source-scorecards/card';

const reviewDate = '2026-07-21';

// Map an ashwagandha product into the shared card shape.
function toCard(p: AshProduct): ScorecardCardData {
  const chips: Chip[] = [];
  if (p.trialFlag) chips.push({ label: '🔬 Used in trials', kind: 'good', note: p.trialFlag.note });
  if (p.rootPart === 'root+leaf')
    chips.push({ label: '🍃 Root + leaf', kind: 'good', note: 'Made from root and leaf — the plant part under extra liver scrutiny (see the safety notes above).' });
  if (p.b6) chips.push({ label: '⚠ Contains B6', kind: 'warn', note: p.b6.note });
  if (p.importSafety) chips.push({ label: '⚠ Import — no AU warning', kind: 'warn', note: p.importSafety.note });

  const detailLines: DetailLine[] = [];
  if (p.b6) detailLines.push({ tag: 'Safety', note: p.b6.note, kind: 'safety' });
  if (p.importSafety) detailLines.push({ tag: 'Safety', note: p.importSafety.note, kind: 'safety' });
  if (p.trialFlag) detailLines.push({ tag: 'Used in trials', note: p.trialFlag.note, kind: 'trial' });

  return {
    slug: p.slug,
    brand: p.brand,
    productName: p.productName,
    specLines: [p.strength, p.form],
    metaLine: `${p.regulated === 'medicine' && p.ausL ? `AUST L ${p.ausL}` : 'Food · not TGA-listed (import)'} · ${p.channel}`,
    certSummary: p.certSummary,
    certVerified: p.certVerified,
    imagePath: p.imagePath,
    bottomLine: p.bottomLine,
    chips,
    scores: p.scores,
    verdict: p.verdict,
    detailLines,
    heldItems: p.heldItems,
    hasB6: !!p.b6,
  };
}

const cards = ASHWAGANDHA_SOURCES.filter((p) => p.ratified).map(toCard);

const ratingLegend = [
  { label: 'Testing & purity', plain: 'Has an independent lab checked what’s really inside? For ashwagandha, almost no one has.' },
  { label: 'Label accuracy', plain: 'Does the amount inside actually match what the label promises?' },
  { label: 'Additives', plain: 'Any concerning extra ingredients — or just the herb?' },
  { label: 'Regulatory record', plain: 'Has it been in trouble with the medicines regulator (the TGA here in Australia)?' },
  { label: 'Transparency', plain: 'Does the label tell you its active strength (withanolides), name its extract, and who makes it?' },
  { label: 'Marketing honesty', plain: 'Do the claims on the box hold up, or is it overselling?' },
];

const safetyItems = [
  {
    label: 'Liver',
    body:
      'Australia’s medicines regulator (the TGA) has a standing advisory that ashwagandha carries a <strong>very rare risk of liver injury</strong>, and it’s weighing the <strong>root vs leaf</strong> question (some countries restrict leaf use). Products made from <strong>root and leaf</strong> — flagged on their cards — sit on the higher-scrutiny side; the <strong>imported</strong> ones don’t carry Australia’s liver-caution wording at all.',
  },
  {
    label: 'Vitamin B6',
    body:
      'A few products here also add <strong>vitamin B6</strong> — one (Nature’s Own Mild Anxiety) at a high enough dose to carry Australia’s mandated warning. Taking too much B6 over months can cause <strong>tingling or numbness in the hands and feet</strong> (nerve irritation — usually reversible if you stop). We show a <strong>⚠ B6</strong> flag on every product that contains it.',
  },
  {
    label: 'Pregnancy',
    body: 'The standard advice is to avoid ashwagandha in pregnancy and breastfeeding.',
  },
];
---

<Base
  title="Where to source ashwagandha — Somnary source scorecards"
  description="Ashwagandha supplements for stress and sleep you can buy in Australia, grouped into plain-English trust tiers and rated on six documented dimensions. No composite score, no #1, no affiliate links. Plus the liver-injury and B6 warnings worth knowing."
>
  <main class="page">
    <header class="head">
      <p class="eyebrow">Source scorecards · Ashwagandha</p>
      <h1 class="title">Where to source ashwagandha</h1>
      <p class="dek">
        The <a href="/r/ashwagandha">evidence grade</a> answers whether ashwagandha helps with stress
        and sleep. This page answers a different question: of the ashwagandha you can buy in Australia,
        which names a real, studied extract, tells you its active strength, and is made by someone who
        stands behind it? Each is rated on six documented dimensions — every point traces to a primary
        document. No overall score, no #1:
        <a href="/sources/methodology">a ranking would be a recommendation</a>, and we don’t make those.
      </p>
    </header>

    <aside class="banner">
      <p class="banner-line">
        These scorecards rate how a product is <strong>sourced and labeled</strong> — not whether
        you should take it. Educational, not medical advice.
      </p>
      <p class="banner-sub">
        No affiliate links — Somnary earns nothing if you buy. No brand pays to appear, to improve
        a score, or to remove one. <a href="/sources/methodology">How we rate →</a>
      </p>
    </aside>

    <SafetyCallout
      title="Ashwagandha safety notes worth knowing"
      tone="safety"
      items={safetyItems}
      foot="These flags are shown for your safety and sit apart from the scores — talk to a pharmacist before taking ashwagandha regularly."
    />

    <RatingLegend items={ratingLegend} remedyHref="/r/ashwagandha" />

    <ScorecardGrid cards={cards} />

    <p class="footer-strip">
      Somnary · Ashwagandha source scorecards · Reviewed {reviewDate} · Educational, not medical
      advice · A scorecard is about what’s in a bottle, never about whether you should take it —
      talk to a clinician before changing what you take, especially about your liver, vitamin B6, or
      if you’re pregnant. Found an error, or a brand with a document to add? We aim to fix verified
      errors within 7 days — <a href="mailto:sammymoz@gmail.com">sammymoz@gmail.com</a>.
    </p>
  </main>
</Base>

<style>
  .page {
    max-width: 1040px;
    margin: 0 auto;
    padding: var(--sp-8) var(--sp-7) var(--sp-9);
  }
  .eyebrow {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    color: var(--muted);
    margin: 0;
  }
  .head {
    margin-bottom: var(--sp-6);
  }
  .title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--text-3xl);
    line-height: var(--lh-3xl);
    letter-spacing: var(--tracking-tight);
    color: var(--ink);
    margin: var(--sp-3) 0 var(--sp-5);
  }
  .dek {
    font-family: var(--font-body);
    font-size: var(--text-md);
    line-height: var(--lh-md);
    color: var(--muted);
    max-width: 68ch;
    margin: 0;
  }
  .dek a,
  .banner a,
  .footer-strip a {
    color: var(--primary);
  }

  .banner {
    background: var(--primary-soft);
    border-radius: var(--r-lg);
    padding: var(--sp-5) var(--sp-6);
    margin: var(--sp-6) 0 var(--sp-7);
  }
  .banner-line {
    font-size: var(--text-base);
    line-height: var(--lh-base);
    color: var(--ink);
    margin: 0 0 var(--sp-2);
  }
  .banner-sub {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    color: var(--muted);
    margin: 0;
  }

  .footer-strip {
    border-top: var(--border-hairline);
    margin-top: var(--sp-8);
    padding-top: var(--sp-5);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    line-height: var(--lh-sm);
    color: var(--muted);
  }

  @media (max-width: 720px) {
    .page {
      padding: var(--sp-7) var(--sp-5) var(--sp-8);
    }
  }
</style>

---
import Base from '../../layouts/Base.astro';
import SafetyCallout from '../../components/scorecards/SafetyCallout.astro';
import RatingLegend from '../../components/scorecards/RatingLegend.astro';
import ScorecardGrid from '../../components/scorecards/ScorecardGrid.astro';
import { GLYCINE_SOURCES, type GlyProduct } from '../../data/source-scorecards/glycine';
import type { ScorecardCardData, Chip, DetailLine } from '../../data/source-scorecards/card';

const reviewDate = '2026-07-20';

// Map a glycine product into the shared card shape.
function toCard(p: GlyProduct): ScorecardCardData {
  const chips: Chip[] = [
    p.doseReach.reaches
      ? { label: '✓ Reaches the studied 3 g', kind: 'good', note: p.doseReach.note }
      : { label: '⚠ Below the studied 3 g', kind: 'warn', note: p.doseReach.note },
  ];

  const detailLines: DetailLine[] = [];

  return {
    slug: p.slug,
    brand: p.brand,
    productName: p.productName,
    specLines: [p.dose, p.form],
    metaLine: `${p.regulated === 'medicine' && p.ausL ? `AUST L ${p.ausL}` : 'Food · not TGA-listed'} · ${p.channel}`,
    certSummary: p.certSummary,
    certVerified: p.certVerified,
    imagePath: p.imagePath,
    bottomLine: p.bottomLine,
    chips,
    scores: p.scores,
    verdict: p.verdict,
    detailLines,
    heldItems: p.heldItems,
    hasB6: false,
  };
}

const cards = GLYCINE_SOURCES.filter((p) => p.ratified).map(toCard);

const ratingLegend = [
  { label: 'Testing & purity', plain: 'Has an independent lab checked what’s really inside? For glycine, almost no one has.' },
  { label: 'Label accuracy', plain: 'Does the amount inside actually match what the label promises?' },
  { label: 'Additives', plain: 'Any concerning extra ingredients — or just pure glycine?' },
  { label: 'Regulatory record', plain: 'Has it been in trouble with the medicines regulator (the TGA here in Australia)?' },
  { label: 'Transparency', plain: 'Does the brand tell you its dose, who makes it, and is its "grade" claim actually backed?' },
  { label: 'Marketing honesty', plain: 'Do the claims on the box hold up, or is it overselling?' },
];

const safetyItems = [
  {
    label: 'Food, not medicine',
    body:
      'The pure glycine people take for sleep is sold as a <strong>food</strong> — so its label, claims and quality sit outside the medicines regulator (the TGA). Only the magnesium sleep-combos here are TGA-listed medicines. It’s not that the foods are unsafe — it’s that no medicines regulator is pre-checking the label.',
  },
  {
    label: 'The studied dose',
    body:
      'The sleep studies use about <strong>3 g</strong>. Some products reach that in one serving; others need up to <strong>six capsules</strong>; the combos hold far less. Each card notes what its serving delivers — it doesn’t change the score, but it changes what you’d actually take.',
  },
];
---

<Base
  title="Where to source glycine — Somnary source scorecards"
  description="Glycine supplements for sleep you can buy in Australia, rated on six documented dimensions: testing, label accuracy, additives, regulatory record, transparency, marketing honesty. No composite score, no #1, no affiliate links. Plus which reach the studied dose."
>
  <main class="page">
    <header class="head">
      <p class="eyebrow">Source scorecards · Glycine</p>
      <h1 class="title">Where to source glycine</h1>
      <p class="dek">
        The <a href="/r/glycine">evidence grade</a> answers whether glycine helps you sleep. This
        page answers a different question: of the glycine you can buy in Australia, which is genuinely
        pure, honest about its dose, and made by someone who tells you who they are? Each is rated on
        six documented dimensions — every point traces to a primary document. No overall score, no #1:
        <a href="/sources/methodology">a ranking would be a recommendation</a>, and we don’t make
        those.
      </p>
    </header>

    <aside class="banner">
      <p class="banner-line">
        These scorecards rate how a product is <strong>sourced and labeled</strong> — not whether
        you should take it. Educational, not medical advice.
      </p>
      <p class="banner-sub">
        No affiliate links — Somnary earns nothing if you buy. No brand pays to appear, to improve
        a score, or to remove one. <a href="/sources/methodology">How we rate →</a>
      </p>
    </aside>

    <SafetyCallout
      title="Two things worth knowing before you read"
      tone="info"
      items={safetyItems}
    />

    <RatingLegend items={ratingLegend} remedyHref="/r/glycine" />

    <ScorecardGrid cards={cards} />

    <p class="footer-strip">
      Somnary · Glycine source scorecards · Reviewed {reviewDate} · Educational, not medical
      advice · A scorecard is about what’s in a bottle, never about whether you should take it —
      talk to a clinician before changing what you take. Found an error, or a brand with a document
      to add? We aim to fix verified errors within 7 days —
      <a href="mailto:sammymoz@gmail.com">sammymoz@gmail.com</a>.
    </p>
  </main>
</Base>

<style>
  .page {
    max-width: 1040px;
    margin: 0 auto;
    padding: var(--sp-8) var(--sp-7) var(--sp-9);
  }
  .eyebrow {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    color: var(--muted);
    margin: 0;
  }
  .head {
    margin-bottom: var(--sp-6);
  }
  .title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--text-3xl);
    line-height: var(--lh-3xl);
    letter-spacing: var(--tracking-tight);
    color: var(--ink);
    margin: var(--sp-3) 0 var(--sp-5);
  }
  .dek {
    font-family: var(--font-body);
    font-size: var(--text-md);
    line-height: var(--lh-md);
    color: var(--muted);
    max-width: 68ch;
    margin: 0;
  }
  .dek a,
  .banner a,
  .footer-strip a {
    color: var(--primary);
  }

  .banner {
    background: var(--primary-soft);
    border-radius: var(--r-lg);
    padding: var(--sp-5) var(--sp-6);
    margin: var(--sp-6) 0 var(--sp-7);
  }
  .banner-line {
    font-size: var(--text-base);
    line-height: var(--lh-base);
    color: var(--ink);
    margin: 0 0 var(--sp-2);
  }
  .banner-sub {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    color: var(--muted);
    margin: 0;
  }

  .footer-strip {
    border-top: var(--border-hairline);
    margin-top: var(--sp-8);
    padding-top: var(--sp-5);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    line-height: var(--lh-sm);
    color: var(--muted);
  }

  @media (max-width: 720px) {
    .page {
      padding: var(--sp-7) var(--sp-5) var(--sp-8);
    }
  }
</style>

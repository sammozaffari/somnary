---
import Base from '../../layouts/Base.astro';
import {
  GLYCINE_SOURCES,
  DIMENSION_ORDER,
  DIMENSION_LABELS,
  type GlyProduct,
} from '../../data/source-scorecards/glycine';

// Only ratified rows render (mirrors the Supabase publish gate). Ordered alphabetically —
// never by score — so no ranking is implied.
const products: GlyProduct[] = GLYCINE_SOURCES.filter((p) => p.ratified).sort((a, b) =>
  a.brand.localeCompare(b.brand),
);

const reviewDate = '2026-07-20';
const segs = [1, 2, 3, 4, 5];

// Plain-language legend — so anyone can read a card, not just someone who knows the jargon.
const ratingLegend = [
  { label: 'Testing & purity', plain: 'Has an independent lab checked what’s really inside? For glycine, almost no one has.' },
  { label: 'Label accuracy', plain: 'Does the amount inside actually match what the label promises?' },
  { label: 'Additives', plain: 'Any concerning extra ingredients — or just pure glycine?' },
  { label: 'Regulatory record', plain: 'Has it been in trouble with the medicines regulator (the TGA here in Australia)?' },
  { label: 'Transparency', plain: 'Does the brand tell you its dose, who makes it, and is its "grade" claim actually backed?' },
  { label: 'Marketing honesty', plain: 'Do the claims on the box hold up, or is it overselling?' },
];
---

<Base
  title="Where to source glycine — Somnary source scorecards"
  description="Glycine supplements for sleep you can buy in Australia, rated on six documented dimensions: testing, label accuracy, additives, regulatory record, transparency, marketing honesty. No composite score, no #1, no affiliate links. Plus which reach the studied dose."
>
  <main class="page">
    <header class="head">
      <p class="eyebrow">Source scorecards · Glycine</p>
      <h1 class="title">Where to source glycine</h1>
      <p class="dek">
        The <a href="/r/glycine">evidence grade</a> answers whether glycine helps you sleep. This
        page answers a different question: of the glycine you can buy in Australia, which is genuinely
        pure, honest about its dose, and made by someone who tells you who they are? Each is rated on
        six documented dimensions — every point traces to a primary document. No overall score, no #1:
        <a href="/sources/methodology">a ranking would be a recommendation</a>, and we don’t make
        those.
      </p>
    </header>

    <aside class="banner">
      <p class="banner-line">
        These scorecards rate how a product is <strong>sourced and labeled</strong> — not whether
        you should take it. Educational, not medical advice.
      </p>
      <p class="banner-sub">
        No affiliate links — Somnary earns nothing if you buy. No brand pays to appear, to improve
        a score, or to remove one. <a href="/sources/methodology">How we rate →</a>
      </p>
    </aside>

    <aside class="context-note">
      <p class="context-note-title">Two things worth knowing before you read</p>
      <p class="context-note-body">
        <strong>1. Most glycine for sleep is a food, not a medicine.</strong> The pure glycine powders
        and capsules here are sold as <strong>foods</strong> — so their label, claims, and quality
        sit <strong>outside</strong> the medicines regulator (the TGA). Only the two magnesium
        sleep-combos are TGA-listed medicines. It’s not that the foods are unsafe — it’s that no
        medicines regulator is pre-checking the label.<br />
        <strong>2. The sleep studies use about 3 g.</strong> Some products reach that in one serving;
        others need up to <strong>six capsules</strong>; and the combos contain far less (as little as
        0.74 g). Each card notes what its serving actually delivers — it doesn’t change the score, but
        it changes what you’d actually take.
      </p>
    </aside>

    <aside class="legend">
      <p class="legend-title">What the six ratings mean — in plain words</p>
      <dl class="legend-grid">
        {ratingLegend.map((r) => (
          <div class="legend-item">
            <dt>{r.label}</dt>
            <dd>{r.plain}</dd>
          </div>
        ))}
      </dl>
      <p class="legend-foot">
        Each is scored 0–5 (more filled bars = better). There’s no overall score — the six are kept
        separate on purpose. Glycine’s pattern is unusual: it’s a genuinely <strong>pure</strong>
        single ingredient (so additives score well), but <strong>almost no one independently tests
        it</strong> (so testing and label accuracy are near-zero across the board). What separates
        products is transparency — dose, maker, and whether a "grade" claim is actually backed. Tap
        “Why these scores” on any card for the exact reason and the document behind it.
      </p>
    </aside>

    {
      products.length === 0 ? (
        <p class="empty">Scorecards are being finalized. Check back shortly.</p>
      ) : (
        <section class="stack" aria-label="Glycine source scorecards">
          {products.map((p) => (
            <article class="card">
              <div class="shot">
                {p.imagePath ? (
                  <img src={p.imagePath} alt={`${p.brand} ${p.productName}`} loading="lazy" decoding="async" />
                ) : (
                  <span class="shot-fallback" aria-hidden="true">
                    {p.brand.charAt(0)}
                  </span>
                )}
              </div>

              <div class="body">
                <div class="body-head">
                  <div class="id">
                    <h2 class="brand">{p.brand}</h2>
                    <p class="product">
                      {p.productName} · {p.dose} · {p.form}
                    </p>
                    <p class="meta">
                      {p.regulated === 'medicine' && p.ausL ? `AUST L ${p.ausL}` : 'Food · not TGA-listed'} · {p.channel}
                    </p>
                  </div>
                  <div class="flags">
                    <p class="cert" data-kind={p.certVerified ? 'yes' : 'none'}>{p.certSummary}</p>
                    <p class="dose" data-reaches={p.doseReach.reaches ? 'yes' : 'no'}>
                      {p.doseReach.reaches ? '✓' : '○'} {p.doseReach.note}
                    </p>
                  </div>
                </div>

                <p class="verdict">{p.verdict}</p>

                <div class="meters">
                  {DIMENSION_ORDER.map((key) => (
                    <div class="meter">
                      <span class="meter-label">{DIMENSION_LABELS[key]}</span>
                      <span class="meter-row">
                        <span class="bar" aria-hidden="true">
                          {segs.map((i) => (
                            <i class:list={['seg', { on: i <= p.scores[key].score }]} />
                          ))}
                        </span>
                        <span class="meter-num">{p.scores[key].score}<span class="of">/5</span></span>
                      </span>
                    </div>
                  ))}
                </div>

                <details class="why">
                  <summary>Why these scores</summary>
                  <dl class="why-list">
                    {DIMENSION_ORDER.map((key) => (
                      <div class="why-row">
                        <dt>
                          {DIMENSION_LABELS[key]} · {p.scores[key].score}/5
                        </dt>
                        <dd>{p.scores[key].note}</dd>
                      </div>
                    ))}
                  </dl>
                  {p.heldItems.length > 0 && (
                    <p class="held">
                      <span class="tag">Under review</span> {p.heldItems.join(' ')}
                    </p>
                  )}
                </details>

                <div class="foot">
                  <p class="community">
                    <span class="tag">Community read · never scored</span>{' '}
                    {p.communityThemes && p.communityThemes.length > 0 ? (
                      p.communityThemes.map((t, i) => (
                        <>
                          {i > 0 && ' · '}
                          {t.url ? <a href={t.url} rel="nofollow noopener" target="_blank">{t.note}</a> : t.note}
                        </>
                      ))
                    ) : (
                      <>Gathering — forum context only.</>
                    )}
                  </p>
                </div>
              </div>
            </article>
          ))}
        </section>
      )
    }

    <p class="footer-strip">
      Somnary · Glycine source scorecards · Reviewed {reviewDate} · Educational, not medical
      advice · A scorecard is about what’s in a bottle, never about whether you should take it —
      talk to a clinician before changing what you take. Found an error, or a brand with a document
      to add? We aim to fix verified errors within 7 days —
      <a href="mailto:sammymoz@gmail.com">sammymoz@gmail.com</a>.
    </p>
  </main>
</Base>

<style>
  .page {
    max-width: 1040px;
    margin: 0 auto;
    padding: var(--sp-8) var(--sp-7) var(--sp-9);
  }
  .eyebrow {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    color: var(--muted);
    margin: 0;
  }
  .head {
    margin-bottom: var(--sp-6);
  }
  .title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--text-3xl);
    line-height: var(--lh-3xl);
    letter-spacing: var(--tracking-tight);
    color: var(--ink);
    margin: var(--sp-3) 0 var(--sp-5);
  }
  .dek {
    font-family: var(--font-body);
    font-size: var(--text-md);
    line-height: var(--lh-md);
    color: var(--muted);
    max-width: 68ch;
    margin: 0;
  }
  .dek a,
  .banner a,
  .context-note a,
  .community a,
  .footer-strip a {
    color: var(--primary);
  }

  .banner {
    background: var(--primary-soft);
    border-radius: var(--r-lg);
    padding: var(--sp-5) var(--sp-6);
    margin: var(--sp-6) 0 var(--sp-4);
  }
  .banner-line {
    font-size: var(--text-base);
    line-height: var(--lh-base);
    color: var(--ink);
    margin: 0 0 var(--sp-2);
  }
  .banner-sub {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    color: var(--muted);
    margin: 0;
  }

  /* food-vs-medicine + dose explainer — informational register (not safety), distinct from the banner */
  .context-note {
    border: var(--border-hairline);
    border-left: 3px solid var(--eucalyptus, var(--primary));
    border-radius: var(--r-lg);
    padding: var(--sp-5) var(--sp-6);
    margin: 0 0 var(--sp-7);
    background: var(--surface);
  }
  .context-note-title {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    color: var(--ink);
    margin: 0 0 var(--sp-2);
  }
  .context-note-body {
    font-size: var(--text-sm);
    line-height: var(--lh-sm);
    color: var(--muted);
    margin: 0;
  }
  .context-note-body strong {
    color: var(--ink);
  }

  .empty {
    color: var(--muted);
    font-size: var(--text-base);
  }

  /* plain-language legend */
  .legend {
    margin: 0 0 var(--sp-7);
  }
  .legend-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--text-md);
    color: var(--ink);
    margin: 0 0 var(--sp-4);
  }
  .legend-grid {
    margin: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--sp-4) var(--sp-6);
  }
  .legend-item dt {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    color: var(--ink);
    margin: 0 0 var(--sp-1);
  }
  .legend-item dd {
    margin: 0;
    font-size: var(--text-sm);
    line-height: var(--lh-sm);
    color: var(--muted);
  }
  .legend-foot {
    font-size: var(--text-sm);
    line-height: var(--lh-sm);
    color: var(--muted);
    margin: var(--sp-4) 0 0;
    max-width: 72ch;
  }
  .legend-foot strong {
    color: var(--ink);
  }

  .stack {
    display: flex;
    flex-direction: column;
    gap: var(--sp-5);
  }
  .card {
    display: grid;
    grid-template-columns: 168px 1fr;
    gap: var(--sp-6);
    border: var(--border-hairline);
    border-radius: var(--r-xl);
    background: var(--surface);
    padding: var(--sp-6);
  }
  .shot {
    display: flex;
    align-items: center;
    justify-content: center;
    aspect-ratio: 1;
    background: var(--primary-soft);
    border-radius: var(--r-lg);
    overflow: hidden;
  }
  .shot img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: var(--sp-3);
  }
  .shot-fallback {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--text-3xl);
    color: var(--primary);
  }

  .body {
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: var(--sp-4);
  }
  .body-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--sp-4);
  }
  .brand {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--text-xl);
    line-height: var(--lh-xl);
    color: var(--ink);
    margin: 0;
  }
  .product {
    font-size: var(--text-sm);
    color: var(--muted);
    margin: var(--sp-1) 0 0;
  }
  .meta {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    color: var(--muted);
    margin: var(--sp-1) 0 0;
  }
  .flags {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: var(--sp-2);
    flex-shrink: 0;
    max-width: 38%;
  }
  .cert {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    text-align: right;
    margin: 0;
  }
  .cert[data-kind='yes'] {
    color: var(--eucalyptus, var(--primary));
  }
  .cert[data-kind='none'] {
    color: var(--muted);
  }
  .dose {
    font-size: var(--text-xs);
    line-height: var(--lh-sm);
    text-align: right;
    margin: 0;
  }
  .dose[data-reaches='yes'] {
    color: var(--eucalyptus, var(--primary));
  }
  .dose[data-reaches='no'] {
    color: var(--muted);
  }

  .verdict {
    font-family: var(--font-body);
    font-size: var(--text-md);
    line-height: var(--lh-md);
    color: var(--ink);
    margin: 0;
    max-width: 62ch;
  }

  .meters {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--sp-4) var(--sp-5);
    padding-top: var(--sp-4);
    border-top: var(--border-hairline);
  }
  .meter {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
  }
  .meter-label {
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    color: var(--muted);
    font-family: var(--font-mono);
  }
  .meter-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-2);
  }
  .bar {
    display: inline-flex;
    gap: var(--sp-1);
  }
  .seg {
    width: var(--sp-4);
    height: var(--sp-2);
    border-radius: var(--r-sm);
    background: var(--primary-soft);
  }
  .seg.on {
    background: var(--ink);
  }
  .meter-num {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--ink);
    font-weight: 600;
  }
  .meter-num .of {
    color: var(--muted);
    font-weight: 400;
  }

  .why {
    border-top: var(--border-hairline);
    padding-top: var(--sp-3);
  }
  .why > summary {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    color: var(--primary);
    cursor: pointer;
  }
  .why-list {
    margin: var(--sp-4) 0 0;
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
  }
  .why-row dt {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--ink);
    margin: 0 0 var(--sp-1);
  }
  .why-row dd {
    font-size: var(--text-sm);
    line-height: var(--lh-sm);
    color: var(--muted);
    margin: 0;
  }
  .held {
    font-size: var(--text-xs);
    line-height: var(--lh-sm);
    color: var(--muted);
    margin: var(--sp-4) 0 0;
  }

  .foot {
    padding-top: var(--sp-3);
    border-top: var(--border-hairline);
  }
  .community {
    font-size: var(--text-xs);
    line-height: var(--lh-sm);
    color: var(--muted);
    margin: 0;
  }
  .tag {
    font-family: var(--font-mono);
    letter-spacing: var(--tracking-label);
    color: var(--ink);
    margin-right: var(--sp-1);
  }

  .footer-strip {
    border-top: var(--border-hairline);
    margin-top: var(--sp-8);
    padding-top: var(--sp-5);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    line-height: var(--lh-sm);
    color: var(--muted);
  }

  @media (max-width: 720px) {
    .legend-grid {
      grid-template-columns: 1fr;
    }
    .page {
      padding: var(--sp-7) var(--sp-5) var(--sp-8);
    }
    .card {
      grid-template-columns: 1fr;
      gap: var(--sp-4);
    }
    .shot {
      aspect-ratio: auto;
      height: 200px;
    }
    .flags {
      max-width: none;
    }
    .meters {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>

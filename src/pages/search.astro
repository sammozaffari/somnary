---
// Crawlable search results page — CHK-4.3 (DESIGN_SYSTEM §3.7, PLAN §2a). The no-JS / deep-link /
// SEO fallback for the ⌘K palette: it renders results SERVER-SIDE from ?q=, so query pages are
// crawlable and work with JavaScript off. Same index + ranker as the palette (getSearchDocs +
// searchDocs). This is the project's FIRST server-rendered route (prerender=false) — every other
// page stays static; the astro.config note anticipated opting specific routes into server mode.
export const prerender = false;

import Base from '../layouts/Base.astro';
import TierBadge from '../components/TierBadge.astro';
import { getSearchDocs, searchDocs } from '../lib/search';

const q = (Astro.url.searchParams.get('q') ?? '').trim();
const docs = await getSearchDocs();
const results = q ? searchDocs(q, docs) : [];

// group by kind (only 'remedy' today; interventions/outcomes/context join as they ship)
const KIND_LABEL: Record<string, string> = {
  remedy: 'remedies',
  intervention: 'interventions',
  outcome: 'outcomes',
  context: 'context',
};
const groups = new Map<string, typeof results>();
for (const r of results) {
  const arr = groups.get(r.kind) ?? [];
  arr.push(r);
  groups.set(r.kind, arr);
}

const suggestions = ['melatonin', 'magnesium', 'jet lag', "can't fall asleep", 'passionflower'];
---

<Base
  title={q ? `search: ${q} — Somnary` : 'search — Somnary'}
  description="search Somnary: every remedy by name, alias, latin name, outcome, or symptom."
>
  <main class="page">
    <header class="head">
      <p class="eyebrow">search</p>
      <h1 class="title">{q ? <>results for “{q}”</> : 'search the wiki'}</h1>

      {/* real <form> GET → works with JS off; the palette is the enhanced surface */}
      <form class="searchbar" role="search" method="get" action="/search">
        <label for="q" class="sr-only">search remedies, outcomes, and symptoms</label>
        <span class="mag" aria-hidden="true">⌕</span>
        <input
          type="search"
          id="q"
          name="q"
          value={q}
          placeholder="a remedy, a compound, an outcome, a symptom…"
          autocomplete="off"
          autofocus
        />
        <button type="submit">search</button>
      </form>
    </header>

    {
      q && results.length > 0 && (
        <div class="results">
          {[...groups.entries()].map(([kind, rows]) => (
            <section class="group" aria-label={KIND_LABEL[kind] ?? kind}>
              <p class="group-head">
                {KIND_LABEL[kind] ?? kind} · {rows.length}
              </p>
              <ul class="rows">
                {rows.map((r) => (
                  <li>
                    <a class="row" href={r.url}>
                      <TierBadge tier={r.tier} size="inline" />
                      <span class="row-main">
                        <span class="row-name">{r.name}</span>
                        <span class="row-cat">{r.category}</span>
                        <span class="row-dek">{r.oneLiner}</span>
                      </span>
                    </a>
                  </li>
                ))}
              </ul>
            </section>
          ))}
        </div>
      )
    }

    {
      q && results.length === 0 && (
        <div class="empty">
          <p class="empty-lead">no matches. try a compound, an outcome, or a symptom.</p>
          <p class="empty-sub">
            popular:
            {suggestions.map((s) => (
              <a class="chip" href={`/search?q=${encodeURIComponent(s)}`}>
                {s}
              </a>
            ))}
          </p>
        </div>
      )
    }

    {
      !q && (
        <div class="empty">
          <p class="empty-lead">search remedies by name, alias, latin name, outcome, or symptom.</p>
          <p class="empty-sub">
            try:
            {suggestions.map((s) => (
              <a class="chip" href={`/search?q=${encodeURIComponent(s)}`}>
                {s}
              </a>
            ))}
          </p>
        </div>
      )
    }
  </main>
</Base>

<style>
  .page {
    max-width: 820px;
    margin: 0 auto;
    padding: var(--sp-8) var(--sp-7) var(--sp-9);
  }
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
  .eyebrow {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--muted);
    margin: 0;
  }
  .head {
    margin-bottom: var(--sp-7);
  }
  .title {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    line-height: var(--lh-2xl);
    color: var(--ink);
    margin: var(--sp-3) 0 var(--sp-5);
  }

  .searchbar {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    background: var(--surface);
    border: var(--border-strong);
    border-radius: var(--r-lg);
    padding: var(--sp-3) var(--sp-4);
  }
  .searchbar:focus-within {
    box-shadow: var(--ring);
  }
  .mag {
    color: var(--muted);
    font-size: var(--text-lg);
    line-height: 1;
  }
  .searchbar input {
    flex: 1;
    min-width: 0;
    border: none;
    background: transparent;
    font-family: var(--font-body);
    font-size: var(--text-md);
    color: var(--ink);
    min-height: 36px;
  }
  .searchbar input:focus {
    outline: none;
  }
  .searchbar button {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--surface);
    background: var(--ink);
    border: none;
    border-radius: var(--r-pill);
    padding: 0 var(--sp-4);
    min-height: 40px;
    cursor: pointer;
  }

  .results {
    display: flex;
    flex-direction: column;
    gap: var(--sp-7);
  }
  .group-head {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--muted);
    margin: 0 0 var(--sp-3);
  }
  .rows {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .row {
    display: grid;
    grid-template-columns: 38px 1fr;
    gap: var(--sp-4);
    align-items: start;
    padding: var(--sp-4);
    border-radius: var(--r-md);
    text-decoration: none;
    color: var(--ink);
    transition: background var(--dur-fast) var(--ease-soft);
  }
  .row:hover {
    background: var(--stone);
  }
  .row:focus-visible {
    outline: none;
    box-shadow: var(--ring);
  }
  .row-main {
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .row-name {
    font-size: var(--text-base);
    color: var(--ink);
  }
  .row-cat {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--muted);
  }
  .row-dek {
    font-size: var(--text-sm);
    line-height: var(--lh-sm);
    color: var(--muted);
  }

  .empty {
    padding: var(--sp-7) 0;
  }
  .empty-lead {
    font-size: var(--text-md);
    color: var(--muted);
    margin: 0 0 var(--sp-4);
  }
  .empty-sub {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--muted);
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
    align-items: center;
  }
  .chip {
    color: var(--primary);
    background: var(--primary-soft);
    border-radius: var(--r-pill);
    padding: 4px 10px;
    text-decoration: none;
    text-transform: none;
    letter-spacing: normal;
    font-size: var(--text-sm);
  }
  .chip:focus-visible {
    outline: none;
    box-shadow: var(--ring);
  }

  @media (max-width: 640px) {
    .page {
      padding: var(--sp-6) var(--sp-5) var(--sp-8);
    }
  }
</style>
